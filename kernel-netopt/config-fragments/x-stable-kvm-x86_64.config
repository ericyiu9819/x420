# x-stable TCP REALITY KVM x86_64 kernel profile
#
# Target workload:
# - Xray VLESS + REALITY + Vision over TCP/443
# - single KVM/VPS, TCP-only proxy path
# - low retransmission, low jitter, simple rollback
#
# Merge this fragment on top of a known-good distro or upstream x86_64
# defconfig, then run `make olddefconfig`.

CONFIG_64BIT=y
CONFIG_SMP=y
CONFIG_MODULES=y
CONFIG_BLK_DEV_INITRD=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# Timer and scheduler profile. HZ_1000 gives tighter pacing/latency behavior
# for proxy workloads, while PREEMPT_DYNAMIC keeps boot-time flexibility.
CONFIG_HZ_1000=y
CONFIG_HZ=1000
CONFIG_PREEMPT_DYNAMIC=y
CONFIG_HIGH_RES_TIMERS=y
CONFIG_NO_HZ_IDLE=y

# KVM/VPS boot path.
CONFIG_EFI=y
CONFIG_EFI_STUB=y
CONFIG_ACPI=y
CONFIG_PCI=y
CONFIG_PCI_MSI=y
CONFIG_VIRTUALIZATION=y
CONFIG_KVM_GUEST=y
CONFIG_HYPERVISOR_GUEST=y
CONFIG_PARAVIRT=y
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_PCI_LEGACY=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_CONSOLE=y
CONFIG_VIRTIO_BALLOON=y

# Common VPS disk paths.
CONFIG_SCSI=y
CONFIG_BLK_DEV_SD=y
CONFIG_SCSI_VIRTIO=y
CONFIG_ATA=y
CONFIG_ATA_PIIX=y
CONFIG_ATA_GENERIC=y
CONFIG_PATA_ACPI=y
CONFIG_NVME_CORE=y
CONFIG_BLK_DEV_NVME=y

# Package/kernel identity.
CONFIG_LOCALVERSION="-x"

# Network core for TCP-only x.
CONFIG_NET=y
CONFIG_INET=y
CONFIG_IPV6=y
CONFIG_INET_DIAG=y
CONFIG_INET_TCP_DIAG=y

# Production congestion/pacing path. Build BBR and fq in so the kernel is
# usable before module loading; still keep runtime sysctl as the source of truth.
CONFIG_TCP_CONG_BBR=y
CONFIG_DEFAULT_BBR=y
CONFIG_DEFAULT_TCP_CONG="bbr"
CONFIG_NET_SCH_FQ=y
CONFIG_NET_SCH_FQ_CODEL=m
CONFIG_NET_SCH_INGRESS=m
CONFIG_NET_CLS_ACT=m

# Keep firewall compatibility as modules. x defaults to a small runtime policy,
# but VPS users often still need nftables/iptables for provider hardening.
CONFIG_NETFILTER=y
CONFIG_NF_TABLES=m
CONFIG_NFT_CT=m
CONFIG_NFT_NAT=m
CONFIG_NFT_MASQ=m
CONFIG_NFT_REDIR=m
CONFIG_NF_CONNTRACK=m
CONFIG_NF_NAT=m
CONFIG_IP_NF_IPTABLES=m
CONFIG_IP_NF_FILTER=m
CONFIG_IP_NF_NAT=m
CONFIG_IP_NF_MANGLE=m
CONFIG_NETFILTER_XT_MATCH_ADDRTYPE=m
CONFIG_NETFILTER_XT_MATCH_CONNTRACK=m
CONFIG_NETFILTER_XT_TARGET_MASQUERADE=m

# Cloud/VPS NICs beyond virtio.
CONFIG_NET_VENDOR_AMAZON=y
CONFIG_ENA_ETHERNET=m
CONFIG_GVE=m
CONFIG_MLX4_EN=m
CONFIG_MLX5_CORE=m
CONFIG_IXGBE=m
CONFIG_I40E=m
CONFIG_NET_FAILOVER=y
CONFIG_FAILOVER=y

# Optional tunnel/container compatibility. Server-side x does not need
# WireGuard, but TUN is useful for client-side sing-box and diagnostics.
CONFIG_TUN=m
CONFIG_VETH=m
CONFIG_BRIDGE=m
CONFIG_VLAN_8021Q=m
CONFIG_DUMMY=m
CONFIG_NAMESPACES=y
CONFIG_NET_NS=y
CONFIG_PID_NS=y
CONFIG_USER_NS=y
CONFIG_UTS_NS=y
CONFIG_IPC_NS=y
CONFIG_CGROUPS=y
CONFIG_CGROUP_BPF=y
CONFIG_BPF=y
CONFIG_BPF_SYSCALL=y

# Filesystems: keep common VPS roots built in; trim desktop/storage extras.
CONFIG_EXT4_FS=y
CONFIG_XFS_FS=y
CONFIG_XFS_POSIX_ACL=y
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y
# CONFIG_BTRFS_FS is not set
# CONFIG_FAT_FS is not set
# CONFIG_MSDOS_FS is not set
# CONFIG_VFAT_FS is not set
# CONFIG_ISO9660_FS is not set
# CONFIG_UDF_FS is not set
# CONFIG_NFS_FS is not set
# CONFIG_NFSD is not set
# CONFIG_CIFS is not set
# CONFIG_SMB_SERVER is not set

# Remove unused desktop/radio stacks for a smaller VPS kernel.
# CONFIG_WIREGUARD is not set
# CONFIG_WIRELESS is not set
# CONFIG_WLAN is not set
# CONFIG_BT is not set
# CONFIG_SOUND is not set
# CONFIG_DRM is not set
# CONFIG_DRM_QXL is not set
# CONFIG_DRM_VIRTIO_GPU is not set

# Console/debugging.
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_VT=y
CONFIG_VT_CONSOLE=y
CONFIG_UNIX98_PTYS=y
CONFIG_FB=y
CONFIG_FRAMEBUFFER_CONSOLE=y
CONFIG_DEBUG_INFO_NONE=y
