EOF

      if [ "$BAREMETAL_SET_GOMAXPROCS" = "1" ] && [ -n "$gomaxprocs" ]; then
        printf 'Environment=GOMAXPROCS=%s\n' "$gomaxprocs"
      fi
    fi
  } > "$dropin_dir/20-vless-reality-performance.conf"

  systemctl daemon-reload || true
  log "systemd limits written: $dropin_dir/20-vless-reality-performance.conf"
