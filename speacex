#!/usr/bin/env bash
# Deploy one direct VLESS + TCP + REALITY + XTLS Vision endpoint.
# Supported hosts: Ubuntu 22.04/24.04 or Debian 12 with systemd.
# Run as root: SERVER_ADDR=<VPS IPv4-or-domain> bash setup-vless-reality.sh
# To archive and replace an existing Xray deployment first, add CLEAN_EXISTING=1.

set -Eeuo pipefail
umask 077

CONFIG_DIR="/usr/local/etc/xray"
CONFIG_FILE="$CONFIG_DIR/config.json"
DATA_DIR="/usr/local/share/xray"
SERVICE_FILE="/etc/systemd/system/xray.service"
CLIENT_FILE="/root/vless-reality-shadowrocket.txt"
INSTALLER_URL="https://github.com/XTLS/Xray-install/raw/main/install-release.sh"
CLEAN_EXISTING="${CLEAN_EXISTING:-0}"

fail() {
  echo "Error: $*" >&2
  exit 1
}

note() {
  echo "==> $*"
}

[[ "${EUID}" -eq 0 ]] || fail "Run this script as root."
[[ -r /etc/os-release ]] || fail "Cannot identify the operating system."
. /etc/os-release
case "${ID}" in
  ubuntu|debian) ;;
  *) fail "Only Ubuntu and Debian are supported." ;;
esac

public_ipv4() {
  curl -4 --fail --silent --show-error --max-time 8 https://api.ipify.org 2>/dev/null || true
}

ensure_dependencies() {
  local missing=()
  command -v curl >/dev/null 2>&1 || missing+=(curl)
  command -v openssl >/dev/null 2>&1 || missing+=(openssl)
  [[ -e /etc/ssl/certs/ca-certificates.crt ]] || missing+=(ca-certificates)

  ((${#missing[@]} == 0)) && return 0
  command -v apt-get >/dev/null 2>&1 || fail "curl and openssl are required."

  note "Installing missing prerequisites: ${missing[*]}"
  export DEBIAN_FRONTEND=noninteractive
  apt-get update || true
  apt-get install -y --no-install-recommends "${missing[@]}" \
    || fail "Could not install prerequisites. Check the VPS outbound network or install: ${missing[*]}."
}

archive_existing() {
  [[ "$CLEAN_EXISTING" == "1" ]] || return 0

  local backup_dir="/root/xray-backup-$(date +%Y%m%d%H%M%S)"
  note "Archiving the existing Xray deployment to $backup_dir"
  mkdir -p "$backup_dir"
  systemctl disable --now xray.service xray@.service 2>/dev/null || true
  mapfile -t template_units < <(systemctl list-units --all --plain 'xray@*.service' --no-legend 2>/dev/null | awk '{print $1}')
  ((${#template_units[@]} == 0)) || systemctl disable --now "${template_units[@]}" 2>/dev/null || true

  for entry in \
    "$CONFIG_DIR:usr-local-etc-xray" \
    "/etc/xray:etc-xray" \
    "/usr/local/bin/xray:usr-local-bin-xray" \
    "$SERVICE_FILE:systemd-xray.service" \
    "/etc/systemd/system/xray@.service:systemd-xray-at.service" \
    "/etc/systemd/system/xray.service.d:systemd-xray.service.d" \
    "/etc/systemd/system/xray@.service.d:systemd-xray-at.service.d" \
    "/var/log/xray:var-log-xray"; do
    src="${entry%%:*}"
    label="${entry#*:}"
    [[ -e "$src" ]] && mv "$src" "$backup_dir/$label"
  done
  systemctl daemon-reload
}

# Optional overrides, for example:
# SERVER_ADDR=203.0.113.10 REALITY_SNI=www.tesla.com REALITY_TARGET=www.tesla.com:443 bash setup-vless-reality.sh
SERVER_ADDR="${SERVER_ADDR:-}"
REALITY_SNI="${REALITY_SNI:-www.tesla.com}"
REALITY_TARGET="${REALITY_TARGET:-${REALITY_SNI}:443}"

ensure_dependencies

if [[ -z "$SERVER_ADDR" ]]; then
  DEFAULT_ADDR="$(public_ipv4)"
  read -r -p "Client connection address [${DEFAULT_ADDR:-enter VPS IPv4 or domain}]: " SERVER_ADDR || true
  SERVER_ADDR="${SERVER_ADDR:-$DEFAULT_ADDR}"
fi

[[ -n "$SERVER_ADDR" ]] || fail "A public IPv4 address or domain is required."
[[ "$SERVER_ADDR" =~ ^[A-Za-z0-9.-]+$ ]] || fail "SERVER_ADDR must be an IPv4 address or a domain name."
[[ "$REALITY_SNI" =~ ^[A-Za-z0-9.-]+$ ]] || fail "REALITY_SNI contains unsupported characters."
[[ "$REALITY_TARGET" =~ ^[A-Za-z0-9.-]+:[0-9]{1,5}$ ]] || fail "REALITY_TARGET must look like domain:port."

archive_existing

note "Installing or updating Xray from the official installer"
INSTALLER="$(mktemp)"
trap 'rm -f "$INSTALLER"' EXIT
curl --fail --location --silent --show-error --retry 2 "$INSTALLER_URL" -o "$INSTALLER" \
  || fail "Could not download the official Xray installer. Check VPS outbound HTTPS access."
# The official documentation uses `bash -c ... @ install`; when executing a
# downloaded file directly, `install` is the first script argument instead.
bash "$INSTALLER" install

XRAY="/usr/local/bin/xray"
[[ -x "$XRAY" ]] || fail "Xray installation did not create $XRAY."

note "Checking the selected REALITY target: $REALITY_TARGET"
timeout 20 "$XRAY" tls ping "$REALITY_TARGET" >/dev/null \
  || fail "The selected REALITY target is unreachable or unsuitable from this VPS. Choose another target and retry."

UUID="$($XRAY uuid)"
KEYPAIR="$($XRAY x25519)"
# Xray 26+ prints PrivateKey / Password (PublicKey); older releases print Private key / Public key.
PRIVATE_KEY="$(sed -nE 's/^(PrivateKey|Private key):[[:space:]]+//p' <<<"$KEYPAIR" | head -n 1)"
PUBLIC_KEY="$(sed -nE 's/^Password \(PublicKey\):[[:space:]]+//p; s/^Public key:[[:space:]]+//p' <<<"$KEYPAIR" | head -n 1)"
SHORT_ID="$(openssl rand -hex 8)"

[[ "$UUID" =~ ^[0-9a-fA-F-]{36}$ ]] || fail "Failed to generate a UUID."
[[ "$PRIVATE_KEY" =~ ^[A-Za-z0-9_-]{43}$ ]] || fail "Failed to parse the Xray REALITY private key."
[[ "$PUBLIC_KEY" =~ ^[A-Za-z0-9_-]{43}$ ]] || fail "Failed to parse the Xray REALITY public key."
[[ "$SHORT_ID" =~ ^[0-9a-f]{16}$ ]] || fail "Failed to generate a REALITY short ID."

install -d -m 755 "$CONFIG_DIR" "$DATA_DIR"
if [[ -f "$CONFIG_FILE" ]]; then
  cp -a "$CONFIG_FILE" "${CONFIG_FILE}.backup.$(date +%Y%m%d%H%M%S)"
fi

cat >"$CONFIG_FILE" <<EOF
{
  "log": {
    "loglevel": "warning"
  },
  "inbounds": [
    {
      "listen": "0.0.0.0",
      "port": 443,
      "protocol": "vless",
      "settings": {
        "clients": [
          {
            "id": "$UUID",
            "flow": "xtls-rprx-vision",
            "email": "shadowrocket"
          }
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "tcp",
        "security": "reality",
        "realitySettings": {
          "show": false,
          "target": "$REALITY_TARGET",
          "xver": 0,
          "serverNames": ["$REALITY_SNI"],
          "privateKey": "$PRIVATE_KEY",
          "shortIds": ["$SHORT_ID"]
        }
      }
    }
  ],
  "outbounds": [
    {
      "protocol": "freedom",
      "tag": "direct"
    }
  ]
}
EOF
chmod 644 "$CONFIG_FILE"

# Use a dedicated unprivileged account instead of the system-wide nobody account.
id -u xray >/dev/null 2>&1 || useradd --system --no-create-home --shell /usr/sbin/nologin xray
cat >"$SERVICE_FILE" <<'EOF'
[Unit]
Description=Xray Service
Documentation=https://github.com/XTLS/Xray-core
After=network-online.target nss-lookup.target
Wants=network-online.target

[Service]
User=xray
Group=xray
CapabilityBoundingSet=CAP_NET_BIND_SERVICE
AmbientCapabilities=CAP_NET_BIND_SERVICE
NoNewPrivileges=true
ExecStart=/usr/local/bin/xray run -config /usr/local/etc/xray/config.json
Restart=on-failure
RestartSec=5
LimitNOFILE=1048576

[Install]
WantedBy=multi-user.target
EOF

note "Validating and starting Xray"
"$XRAY" run -test -config "$CONFIG_FILE"
systemctl daemon-reload
systemctl enable --now xray
systemctl is-active --quiet xray || fail "Xray did not start. Check: journalctl -u xray -e"

VLESS_LINK="vless://${UUID}@${SERVER_ADDR}:443?encryption=none&flow=xtls-rprx-vision&security=reality&sni=${REALITY_SNI}&fp=chrome&pbk=${PUBLIC_KEY}&sid=${SHORT_ID}&type=tcp&headerType=none#SR-VLESS-REALITY"
{
  echo "Shadowrocket import link (keep this private):"
  echo "$VLESS_LINK"
  echo
  echo "Service status: systemctl status xray"
  echo "Server config: $CONFIG_FILE"
} >"$CLIENT_FILE"
chmod 600 "$CLIENT_FILE"

echo
echo "Deployment complete. Import this link into Shadowrocket:"
echo "$VLESS_LINK"
echo
echo "A protected copy is saved at: $CLIENT_FILE"
echo "The script does not alter host firewalls. Ensure your VPS provider and host firewall allow TCP port 443."
