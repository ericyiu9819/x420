  else if (strcmp(key, "PORT") == 0) cfg->port = atoi(value);
  else if (strcmp(key, "NETWORK_SYSCTL_FILE") == 0) copy_str(cfg->network_sysctl_file, sizeof(cfg->network_sysctl_file), value);
  else if (strcmp(key, "TUNING_STATE_FILE") == 0) copy_str(cfg->tuning_state_file, sizeof(cfg->tuning_state_file), value);
  else if (strcmp(key, "OUTPUT_DIR") == 0) copy_str(cfg->output_dir, sizeof(cfg->output_dir), value);
  else if (strcmp(key, "RESTART_COOLDOWN_SEC") == 0) cfg->restart_cooldown_sec = atoi(value);
  else if (strcmp(key, "ENABLE_ADAPTIVE_GUARD") == 0) cfg->enable_adaptive_guard = atoi(value);
  else if (strcmp(key, "ADAPTIVE_RESTORE_AFTER_SEC") == 0) cfg->adaptive_restore_after_sec = atoi(value);
  else if (strcmp(key, "ADAPTIVE_MEMORY_LOW_PCT") == 0) cfg->adaptive_memory_low_pct = atoi(value);
  else if (strcmp(key, "ADAPTIVE_STEAL_HIGH_PCT") == 0) cfg->adaptive_steal_high_pct = atoi(value);
  else if (strcmp(key, "ADAPTIVE_LOAD_HIGH_PCT") == 0) cfg->adaptive_load_high_pct = atoi(value);
  else if (strcmp(key, "ADAPTIVE_RETRANS_HIGH_PCT") == 0) cfg->adaptive_retrans_high_pct = atoi(value);
}

static void load_config_file(struct guard_config *cfg, const char *path) {
  FILE *fp = fopen(path, "r");
  char line[4096];
  if (!fp) return;

  while (fgets(line, sizeof(line), fp)) {
    char *hash = strchr(line, '#');
    char *eq;
    char *key;
    char *value;
    if (hash) *hash = '\0';
    key = trim(line);
    if (*key == '\0') continue;
    eq = strchr(key, '=');
    if (!eq) continue;
    *eq = '\0';
    value = trim(eq + 1);
    key = trim(key);
    unescape_value(value);
    set_config_value(cfg, key, value);
  }

  fclose(fp);
}

static int run_cmd(char *const argv[]) {
  pid_t pid = fork();
  int status = 0;
  if (pid < 0) return 0;
  if (pid == 0) {
    execvp(argv[0], argv);
    _exit(127);
  }
  if (waitpid(pid, &status, 0) < 0) return 0;
  return WIFEXITED(status) && WEXITSTATUS(status) == 0;
}

static int run_sysctl_p(const char *path) {
  char *const argv[] = {"sysctl", "-p", (char *)path, NULL};
  return run_cmd(argv);
}

static int systemctl_is_active(const char *service) {
  char *const argv[] = {"systemctl", "is-active", "--quiet", (char *)service, NULL};
  return run_cmd(argv);
}

static int systemctl_restart(const char *service) {
  char *const argv[] = {"systemctl", "restart", (char *)service, NULL};
  return run_cmd(argv);
}

static int config_is_valid(const struct guard_config *cfg) {
  char *const argv[] = {(char *)cfg->xray_bin, "run", "-test", "-config", (char *)cfg->xray_config, NULL};
  return run_cmd(argv);
}

static void sysctl_proc_path(const char *key, char *out, size_t size) {
  size_t pos = 0;
  const char *prefix = "/proc/sys/";
  snprintf(out, size, "%s", prefix);
  pos = strlen(out);
  for (const char *p = key; *p && pos + 1 < size; p++) {
    out[pos++] = (*p == '.') ? '/' : *p;
  }
  out[pos] = '\0';
}

static int set_sysctl_value(const char *key, const char *value) {
  char path[PATH_MAX];
  int fd;
  ssize_t len;
  sysctl_proc_path(key, path, sizeof(path));
  fd = open(path, O_WRONLY);
  if (fd < 0) return 0;
  len = (ssize_t)strlen(value);
  if (write(fd, value, (size_t)len) != len) {
    close(fd);
    return 0;
  }
  (void)write(fd, "\n", 1);
  close(fd);
  return 1;
}

static int read_sysctl_value(const char *key, char *out, size_t size) {
  char path[PATH_MAX];
  sysctl_proc_path(key, path, sizeof(path));
  if (read_first_line(path, out, size) != 0) return 0;
  normalize_spaces(out);
  return 1;
}

static int adaptive_dynamic_key(const char *key) {
  return strcmp(key, "net.core.netdev_max_backlog") == 0 ||
         strcmp(key, "net.core.rmem_max") == 0 ||
         strcmp(key, "net.core.wmem_max") == 0 ||
         strcmp(key, "net.ipv4.tcp_rmem") == 0 ||
         strcmp(key, "net.ipv4.tcp_wmem") == 0 ||
         strcmp(key, "net.ipv4.tcp_notsent_lowat") == 0;
}

static void reload_sysctl_if_drifted(const struct guard_config *cfg) {
  FILE *fp = fopen(cfg->network_sysctl_file, "r");
  char line[4096];
  int drift = 0;
  if (!fp) return;

  while (fgets(line, sizeof(line), fp)) {
    char *hash = strchr(line, '#');
    char *eq;
    char *key;
    char *expected;
    char current[1024];
    if (hash) *hash = '\0';
    key = trim(line);
    if (*key == '\0') continue;
    eq = strchr(key, '=');
    if (!eq) continue;
    *eq = '\0';
    expected = trim(eq + 1);
    key = trim(key);
    normalize_spaces(expected);

    if (cfg->enable_adaptive_guard && file_exists_nonempty(current_profile_file) && adaptive_dynamic_key(key)) {
      continue;
    }

    if (!read_sysctl_value(key, current, sizeof(current))) continue;
    if (strcmp(current, expected) != 0) {
      drift = 1;
      log_msg("sysctl drift: %s current=%s expected=%s", key, current, expected);
    }
  }

  fclose(fp);
  if (drift) {
    if (run_sysctl_p(cfg->network_sysctl_file)) log_msg("sysctl reloaded from %s", cfg->network_sysctl_file);
    else log_msg("sysctl reload failed from %s", cfg->network_sysctl_file);
  }
}

static void cleanup_legacy_files(const struct guard_config *cfg) {
  const char *files[] = {
    "/etc/sysctl.d/99-proxy-aggressive.conf",
    "/etc/sysctl.d/99-shadowrocket-vless-tcp.conf",
    "/etc/sysctl.d/99-ctrojan-rescue.conf",
    NULL
  };
  char backup_dir[PATH_MAX * 2];
  int moved = 0;
  time_t now = time(NULL);

  snprintf(backup_dir, sizeof(backup_dir), "%s/backups/guard-legacy-%ld", cfg->output_dir, (long)now);

  for (int i = 0; files[i]; i++) {
    struct stat st;
    char dest[PATH_MAX * 2];
    const char *base = strrchr(files[i], '/');
    if (stat(files[i], &st) != 0 || !S_ISREG(st.st_mode)) continue;
    if (!moved) {
      if (mkdir_p(backup_dir, 0700) != 0) break;
      moved = 1;
    }
    base = base ? base + 1 : files[i];
    if (strlen(backup_dir) + 1 + strlen(base) + 1 > sizeof(dest)) {
      log_msg("skip legacy sysctl move: backup path too long for %s", files[i]);
      continue;
    }
    copy_str(dest, sizeof(dest), backup_dir);
    strncat(dest, "/", sizeof(dest) - strlen(dest) - 1);
    strncat(dest, base, sizeof(dest) - strlen(dest) - 1);
    if (rename(files[i], dest) == 0) log_msg("moved legacy sysctl file: %s -> %s", files[i], backup_dir);
  }

  if (moved) run_sysctl_p(cfg->network_sysctl_file);
}

static int profile_rank(const char *profile) {
  if (strcmp(profile, "compact") == 0) return 0;
  if (strcmp(profile, "stable") == 0) return 1;
  if (strcmp(profile, "throughput") == 0) return 2;
  if (strcmp(profile, "extreme") == 0) return 3;
  return 1;
}

static const char *lower_profile(const char *profile) {
  if (strcmp(profile, "extreme") == 0) return "throughput";
  if (strcmp(profile, "throughput") == 0) return "stable";
  if (strcmp(profile, "stable") == 0) return "compact";
  return "compact";
}

static const char *raise_profile_toward(const char *current, const char *base) {
  if (profile_rank(current) >= profile_rank(base)) return base;
  if (strcmp(current, "compact") == 0) return "stable";
  if (strcmp(current, "stable") == 0) return "throughput";
  if (strcmp(current, "throughput") == 0) return "extreme";
  return base;
}

static void set_profile_values(const char *profile, int *backlog, int *rmem, int *wmem, char *tcp_rmem, size_t tcp_rmem_size, char *tcp_wmem, size_t tcp_wmem_size, int *notsent) {
  if (strcmp(profile, "compact") == 0) {
    *backlog = 2048; *rmem = 8388608; *wmem = 8388608; *notsent = 65536;
  } else if (strcmp(profile, "throughput") == 0) {
    *backlog = 8192; *rmem = 33554432; *wmem = 33554432; *notsent = 262144;
  } else if (strcmp(profile, "extreme") == 0) {
    *backlog = 16384; *rmem = 67108864; *wmem = 67108864; *notsent = 262144;
  } else {
    *backlog = 4096; *rmem = 16777216; *wmem = 16777216; *notsent = 131072;
  }
  snprintf(tcp_rmem, tcp_rmem_size, "4096 87380 %d", *rmem);
  snprintf(tcp_wmem, tcp_wmem_size, "4096 65536 %d", *wmem);
}

static void cap_profile_values(const struct tuning_state *state, int *rmem, int *wmem, char *tcp_rmem, size_t tcp_rmem_size, char *tcp_wmem, size_t tcp_wmem_size) {
  long long cap;
  long long min_cap = 4194304;
  if (state->memory_mb <= 0) return;
  cap = (long long)state->memory_mb * 1024LL * 1024LL / 64LL;
  if (state->expected_connections >= 512) cap = (long long)state->memory_mb * 1024LL * 1024LL / 96LL;
  if (cap < min_cap) cap = min_cap;
  cap = cap / 4096LL * 4096LL;
  if (*rmem > cap) {
    *rmem = (int)cap;
    *wmem = (int)cap;
    snprintf(tcp_rmem, tcp_rmem_size, "4096 87380 %d", *rmem);
    snprintf(tcp_wmem, tcp_wmem_size, "4096 65536 %d", *wmem);
  }
}

static int parse_state_value(struct tuning_state *state, const char *key, const char *value) {
  if (strcmp(key, "TUNE_PROFILE") == 0) copy_str(state->profile, sizeof(state->profile), value);
  else if (strcmp(key, "TUNE_MEMORY_MB") == 0) state->memory_mb = atoi(value);
  else if (strcmp(key, "TUNE_EXPECTED_CONNECTIONS") == 0) state->expected_connections = atoi(value);
  else if (strcmp(key, "TUNE_CPU_COUNT") == 0) state->cpu_count = atoi(value);
  else return 0;
  return 1;
}

static int load_tuning_state(const char *path, struct tuning_state *state) {
  FILE *fp = fopen(path, "r");
  char line[4096];
  copy_str(state->profile, sizeof(state->profile), "stable");
  state->memory_mb = 0;
  state->expected_connections = 128;
  state->cpu_count = 1;
  if (!fp) return 0;
  while (fgets(line, sizeof(line), fp)) {
    char *eq;
    char *key = trim(line);
    char *value;
    if (*key == '\0' || *key == '#') continue;
    eq = strchr(key, '=');
    if (!eq) continue;
    *eq = '\0';
    value = trim(eq + 1);
    key = trim(key);
    unescape_value(value);
    parse_state_value(state, key, value);
  }
  fclose(fp);
  if (state->cpu_count < 1) state->cpu_count = 1;
  if (state->expected_connections < 1) state->expected_connections = 128;
  return 1;
}

static void apply_profile_runtime(const char *profile, const struct tuning_state *state) {
  int backlog = 4096, rmem = 16777216, wmem = 16777216, notsent = 131072;
  char value[64];
  char tcp_rmem[128];
  char tcp_wmem[128];

  set_profile_values(profile, &backlog, &rmem, &wmem, tcp_rmem, sizeof(tcp_rmem), tcp_wmem, sizeof(tcp_wmem), &notsent);
  cap_profile_values(state, &rmem, &wmem, tcp_rmem, sizeof(tcp_rmem), tcp_wmem, sizeof(tcp_wmem));

  snprintf(value, sizeof(value), "%d", backlog);
  set_sysctl_value("net.core.netdev_max_backlog", value);
  snprintf(value, sizeof(value), "%d", rmem);
  set_sysctl_value("net.core.rmem_max", value);
  snprintf(value, sizeof(value), "%d", wmem);
  set_sysctl_value("net.core.wmem_max", value);
  set_sysctl_value("net.ipv4.tcp_rmem", tcp_rmem);
  set_sysctl_value("net.ipv4.tcp_wmem", tcp_wmem);
  snprintf(value, sizeof(value), "%d", notsent);
  set_sysctl_value("net.ipv4.tcp_notsent_lowat", value);

  mkdir_p(state_dir, 0700);
  write_text_file(current_profile_file, profile);
  log_msg("adaptive profile applied: %s", profile);
}

static int memory_available_pct(void) {
  char current_s[64], limit_s[64];
  unsigned long long current = 0, limit = 0;

  if (read_first_line("/sys/fs/cgroup/memory.current", current_s, sizeof(current_s)) == 0 &&
      read_first_line("/sys/fs/cgroup/memory.max", limit_s, sizeof(limit_s)) == 0 &&
      sscanf(current_s, "%llu", &current) == 1 &&
      sscanf(limit_s, "%llu", &limit) == 1 &&
      limit > 0) {
    unsigned long long free_bytes = current >= limit ? 0 : limit - current;
    return (int)((free_bytes * 100ULL + limit / 2ULL) / limit);
  }

  FILE *fp = fopen("/proc/meminfo", "r");
  char line[256];
  unsigned long long total = 0, available = 0;
  if (!fp) return 100;
  while (fgets(line, sizeof(line), fp)) {
    sscanf(line, "MemTotal: %llu kB", &total);
    sscanf(line, "MemAvailable: %llu kB", &available);
  }
  fclose(fp);
  if (total == 0 || available == 0) return 100;
  return (int)((available * 100ULL + total / 2ULL) / total);
}

static int read_cpu_total_steal(unsigned long long *total, unsigned long long *steal) {
  FILE *fp = fopen("/proc/stat", "r");
  char line[512];
  unsigned long long v[10] = {0};
  if (!fp) return 0;
  if (!fgets(line, sizeof(line), fp)) {
    fclose(fp);
    return 0;
  }
  fclose(fp);
  if (sscanf(line, "cpu %llu %llu %llu %llu %llu %llu %llu %llu %llu %llu",
             &v[0], &v[1], &v[2], &v[3], &v[4], &v[5], &v[6], &v[7], &v[8], &v[9]) < 8) {
    return 0;
  }
  *total = 0;
  for (int i = 0; i < 10; i++) *total += v[i];
  *steal = v[7];
  return 1;
}

static int cpu_steal_pct(void) {
  unsigned long long total_a, steal_a, total_b, steal_b;
  if (!read_cpu_total_steal(&total_a, &steal_a)) return 0;
  sleep(1);
  if (!read_cpu_total_steal(&total_b, &steal_b)) return 0;
  if (total_b <= total_a || steal_b < steal_a) return 0;
  return (int)(((steal_b - steal_a) * 100ULL + (total_b - total_a) / 2ULL) / (total_b - total_a));
}

static int load_pct(int cpu_count) {
  FILE *fp = fopen("/proc/loadavg", "r");
  double load = 0.0;
  if (cpu_count < 1) cpu_count = 1;
  if (!fp) return 0;
  if (fscanf(fp, "%lf", &load) != 1) load = 0.0;
  fclose(fp);
  return (int)(load * 100.0 / (double)cpu_count + 0.5);
}

static int read_tcp_snmp(unsigned long long *out_segs, unsigned long long *retrans_segs) {
  FILE *fp = fopen("/proc/net/snmp", "r");
  char header[4096], values[4096];
  if (!fp) return 0;
  while (fgets(header, sizeof(header), fp)) {
    if (strncmp(header, "Tcp:", 4) != 0) continue;
    if (!fgets(values, sizeof(values), fp)) break;
    if (strncmp(values, "Tcp:", 4) != 0) continue;

    char hcopy[4096], vcopy[4096];
    char *hctx = NULL, *vctx = NULL;
    char *htok, *vtok;
    int index = 0, out_index = -1, retrans_index = -1;
    copy_str(hcopy, sizeof(hcopy), header);
    copy_str(vcopy, sizeof(vcopy), values);
    htok = strtok_r(hcopy, " \t\r\n", &hctx);
    while (htok) {
      if (strcmp(htok, "OutSegs") == 0) out_index = index;
      if (strcmp(htok, "RetransSegs") == 0) retrans_index = index;
      htok = strtok_r(NULL, " \t\r\n", &hctx);
      index++;
    }
    index = 0;
    vtok = strtok_r(vcopy, " \t\r\n", &vctx);
    while (vtok) {
      if (index == out_index) *out_segs = strtoull(vtok, NULL, 10);
      if (index == retrans_index) *retrans_segs = strtoull(vtok, NULL, 10);
      vtok = strtok_r(NULL, " \t\r\n", &vctx);
      index++;
    }
    fclose(fp);
    return out_index >= 0 && retrans_index >= 0;
  }
  fclose(fp);
  return 0;
}

static int retrans_pct(void) {
  unsigned long long out = 0, retrans = 0, prev_out = 0, prev_retrans = 0;
  char buf[128];
  if (!read_tcp_snmp(&out, &retrans)) return 0;
  mkdir_p(state_dir, 0700);
  if (read_first_line(snmp_prev_file, buf, sizeof(buf)) != 0 ||
      sscanf(buf, "%llu %llu", &prev_out, &prev_retrans) != 2) {
    snprintf(buf, sizeof(buf), "%llu %llu\n", out, retrans);
    write_text_file(snmp_prev_file, buf);
    return 0;
  }
  snprintf(buf, sizeof(buf), "%llu %llu\n", out, retrans);
  write_text_file(snmp_prev_file, buf);
  if (out <= prev_out || retrans < prev_retrans || out - prev_out < 1000) return 0;
  return (int)(((retrans - prev_retrans) * 100ULL + (out - prev_out) / 2ULL) / (out - prev_out));
}

static int pressure_detected(const struct guard_config *cfg, const struct tuning_state *state) {
  int pressure = 0;
  int mem_pct = memory_available_pct();
  int steal = cpu_steal_pct();
  int load = load_pct(state->cpu_count);
  int retrans = retrans_pct();

  if (mem_pct < cfg->adaptive_memory_low_pct) {
    pressure = 1;
    log_msg("adaptive pressure: memory_available_pct=%d threshold=%d", mem_pct, cfg->adaptive_memory_low_pct);
  }
  if (steal >= cfg->adaptive_steal_high_pct) {
    pressure = 1;
    log_msg("adaptive pressure: cpu_steal_pct=%d threshold=%d", steal, cfg->adaptive_steal_high_pct);
  }
  if (load >= cfg->adaptive_load_high_pct) {
    pressure = 1;
    log_msg("adaptive pressure: load_pct=%d threshold=%d", load, cfg->adaptive_load_high_pct);
  }
  if (retrans >= cfg->adaptive_retrans_high_pct) {
    pressure = 1;
    log_msg("adaptive pressure: retrans_pct=%d threshold=%d", retrans, cfg->adaptive_retrans_high_pct);
  }
  return pressure;
}

static void adaptive_tuning(const struct guard_config *cfg) {
  struct tuning_state state;
  char current[64];
  const char *base;
  time_t now;

  if (!cfg->enable_adaptive_guard) return;
  if (!load_tuning_state(cfg->tuning_state_file, &state)) return;
  base = state.profile[0] ? state.profile : "stable";
  mkdir_p(state_dir, 0700);

  if (read_first_line(current_profile_file, current, sizeof(current)) != 0) copy_str(current, sizeof(current), base);
  if (profile_rank(current) > profile_rank(base)) copy_str(current, sizeof(current), base);

  now = time(NULL);
  if (pressure_detected(cfg, &state)) {
    const char *target = lower_profile(current);
    char stamp[64];
    snprintf(stamp, sizeof(stamp), "%ld\n", (long)now);
    write_text_file(last_pressure_file, stamp);
    if (strcmp(target, current) != 0) apply_profile_runtime(target, &state);
    return;
  }

  if (profile_rank(current) < profile_rank(base)) {
    char stamp[64];
    long last_pressure = 0;
    if (read_first_line(last_pressure_file, stamp, sizeof(stamp)) == 0) last_pressure = atol(stamp);
    if (now - last_pressure >= cfg->adaptive_restore_after_sec) {
      const char *target = raise_profile_toward(current, base);
      apply_profile_runtime(target, &state);
      if (strcmp(target, base) == 0) unlink(current_profile_file);
    }
  } else {
    unlink(current_profile_file);
  }
}

static int port_is_listening_file(const char *path, int port) {
  FILE *fp = fopen(path, "r");
  char line[1024];
  if (!fp) return 0;
  if (!fgets(line, sizeof(line), fp)) {
    fclose(fp);
    return 0;
  }
  while (fgets(line, sizeof(line), fp)) {
    char local[128], remote[128], st[16];
    char *colon;
    long local_port;
    if (sscanf(line, " %*d: %127s %127s %15s", local, remote, st) != 3) continue;
    colon = strrchr(local, ':');
    if (!colon) continue;
    local_port = strtol(colon + 1, NULL, 16);
    if (local_port == port && strcmp(st, "0A") == 0) {
      fclose(fp);
      return 1;
    }
  }
  fclose(fp);
  return 0;
}

static int port_is_listening(int port) {
  return port_is_listening_file("/proc/net/tcp", port) || port_is_listening_file("/proc/net/tcp6", port);
}

static void restart_xray_throttled(const struct guard_config *cfg, const char *reason) {
  char stamp_file[PATH_MAX];
  char buf[64];
  long last = 0;
  long now = (long)time(NULL);

  if (!config_is_valid(cfg)) {
    log_msg("skip restart for %s: xray config invalid", reason);
    return;
  }

  mkdir_p(state_dir, 0700);
  snprintf(stamp_file, sizeof(stamp_file), "%s/last_restart", state_dir);
  if (read_first_line(stamp_file, buf, sizeof(buf)) == 0) last = atol(buf);
  if (now - last < cfg->restart_cooldown_sec) {
    log_msg("skip restart for %s: cooldown active", reason);
    return;
  }

  if (systemctl_restart(cfg->xray_service)) {
    snprintf(buf, sizeof(buf), "%ld\n", now);
    write_text_file(stamp_file, buf);
    log_msg("restarted %s: %s", cfg->xray_service, reason);
  } else {
    log_msg("restart failed for %s: %s", cfg->xray_service, reason);
  }
}

int main(int argc, char **argv) {
  struct guard_config cfg;
  const char *config_path = argc > 1 ? argv[1] : "/etc/vless-reality/guard.conf";
  time_t now;

  openlog("vless-reality-guard", LOG_PID, LOG_DAEMON);
  init_config(&cfg);
  load_config_file(&cfg, config_path);

  now = time(NULL);
  if (mkdir(lock_dir, 0700) != 0) {
    if (errno == EEXIST) {
      struct stat st;
      if (stat(lock_dir, &st) == 0 && now - st.st_mtime > 600) {
        rmdir(lock_dir);
        if (mkdir(lock_dir, 0700) == 0) goto locked;
      }
      return 0;
    }
    log_msg("lock failed: %s", strerror(errno));
    return 0;
  }

locked:
  cleanup_legacy_files(&cfg);
  reload_sysctl_if_drifted(&cfg);
  adaptive_tuning(&cfg);

  if (!systemctl_is_active(cfg.xray_service)) {
    restart_xray_throttled(&cfg, "service inactive");
    rmdir(lock_dir);
    return 0;
  }

  if (!port_is_listening(cfg.port)) {
    restart_xray_throttled(&cfg, "port not listening");
  }

  rmdir(lock_dir);
  closelog();
  return 0;
}
