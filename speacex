STATE_DIR="/run/vless-reality-guard"
CURRENT_PROFILE_FILE="${STATE_DIR}/current_profile"
LAST_PRESSURE_FILE="${STATE_DIR}/last_pressure"
NSTAT_PREV_FILE="${STATE_DIR}/nstat.prev"

log() {
  logger -t vless-reality-guard -- "$*"
}

trim() {
  awk '{$1=$1; print}' <<<"$1"
}

profile_rank() {
  case "$1" in
    compact) printf '0\n' ;;
    stable) printf '1\n' ;;
    throughput) printf '2\n' ;;
    extreme) printf '3\n' ;;
    *) printf '1\n' ;;
  esac
}

lower_profile() {
  case "$1" in
    extreme) printf 'throughput\n' ;;
    throughput) printf 'stable\n' ;;
    stable) printf 'compact\n' ;;
    *) printf 'compact\n' ;;
  esac
}

raise_profile_toward() {
  local current="$1"
  local base="$2"

  if [ "$(profile_rank "$current")" -ge "$(profile_rank "$base")" ]; then
    printf '%s\n' "$base"
    return
  fi

  case "$current" in
    compact) printf 'stable\n' ;;
    stable) printf 'throughput\n' ;;
    throughput) printf 'extreme\n' ;;
    *) printf '%s\n' "$base" ;;
  esac
}

set_profile_values() {
  case "$1" in
    compact)
      TUNE_NETDEV_BACKLOG=2048
      TUNE_RMEM_MAX=8388608
      TUNE_WMEM_MAX=8388608
      TUNE_TCP_RMEM="4096 87380 8388608"
      TUNE_TCP_WMEM="4096 65536 8388608"
      TUNE_TCP_NOTSENT_LOWAT=65536
      ;;
    stable)
      TUNE_NETDEV_BACKLOG=4096
      TUNE_RMEM_MAX=16777216
      TUNE_WMEM_MAX=16777216
      TUNE_TCP_RMEM="4096 87380 16777216"
      TUNE_TCP_WMEM="4096 65536 16777216"
      TUNE_TCP_NOTSENT_LOWAT=131072
      ;;
    throughput)
      TUNE_NETDEV_BACKLOG=8192
      TUNE_RMEM_MAX=33554432
      TUNE_WMEM_MAX=33554432
      TUNE_TCP_RMEM="4096 87380 33554432"
      TUNE_TCP_WMEM="4096 65536 33554432"
      TUNE_TCP_NOTSENT_LOWAT=262144
      ;;
    extreme)
      TUNE_NETDEV_BACKLOG=16384
      TUNE_RMEM_MAX=67108864
      TUNE_WMEM_MAX=67108864
      TUNE_TCP_RMEM="4096 87380 67108864"
      TUNE_TCP_WMEM="4096 65536 67108864"
      TUNE_TCP_NOTSENT_LOWAT=262144
      ;;
    *)
      return 1
      ;;
  esac
}

cap_profile_values_by_state() {
  local memory_mb="${TUNE_MEMORY_MB:-0}"
  local expected_connections="${TUNE_EXPECTED_CONNECTIONS:-128}"
  local cap_bytes min_cap_bytes

  if ! printf '%s\n' "$memory_mb" | awk '$1 ~ /^[0-9]+$/ && $1 > 0 {ok=1} END {exit ok ? 0 : 1}'; then
    return 0
  fi

  min_cap_bytes=4194304
  cap_bytes=$((memory_mb * 1024 * 1024 / 64))

  if printf '%s\n' "$expected_connections" | awk '$1 ~ /^[0-9]+$/ && $1 >= 512 {ok=1} END {exit ok ? 0 : 1}'; then
    cap_bytes=$((memory_mb * 1024 * 1024 / 96))
  fi

  [ "$cap_bytes" -ge "$min_cap_bytes" ] || cap_bytes="$min_cap_bytes"
  cap_bytes=$((cap_bytes / 4096 * 4096))

  if [ "$TUNE_RMEM_MAX" -gt "$cap_bytes" ]; then
    TUNE_RMEM_MAX="$cap_bytes"
    TUNE_WMEM_MAX="$cap_bytes"
    TUNE_TCP_RMEM="4096 87380 ${cap_bytes}"
    TUNE_TCP_WMEM="4096 65536 ${cap_bytes}"
  fi
}

set_sysctl_if_exists() {
  local key="$1"
  local value="$2"
  local proc_path="/proc/sys/${key//./\/}"

  if [ -e "$proc_path" ]; then
    sysctl -qw "$key=$value" >/dev/null 2>&1 || true
  fi
}

adaptive_dynamic_key() {
  case "$1" in
    net.core.netdev_max_backlog | \
    net.core.rmem_max | \
    net.core.wmem_max | \
    net.ipv4.tcp_rmem | \
    net.ipv4.tcp_wmem | \
    net.ipv4.tcp_notsent_lowat)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

apply_profile_runtime() {
  local profile="$1"

  set_profile_values "$profile" || return 1
  cap_profile_values_by_state
  mkdir -p "$STATE_DIR"

  set_sysctl_if_exists net.core.netdev_max_backlog "$TUNE_NETDEV_BACKLOG"
  set_sysctl_if_exists net.core.rmem_max "$TUNE_RMEM_MAX"
  set_sysctl_if_exists net.core.wmem_max "$TUNE_WMEM_MAX"
  set_sysctl_if_exists net.ipv4.tcp_rmem "$TUNE_TCP_RMEM"
  set_sysctl_if_exists net.ipv4.tcp_wmem "$TUNE_TCP_WMEM"
  set_sysctl_if_exists net.ipv4.tcp_notsent_lowat "$TUNE_TCP_NOTSENT_LOWAT"

  printf '%s\n' "$profile" > "$CURRENT_PROFILE_FILE"
  log "adaptive profile applied: $profile"
}

with_lock() {
  if ! mkdir "$LOCK_DIR" 2>/dev/null; then
    exit 0
  fi
  trap 'rmdir "$LOCK_DIR" 2>/dev/null || true' EXIT
}

config_is_valid() {
  [ -x "$XRAY_BIN" ] || return 1
  "$XRAY_BIN" run -test -config "$XRAY_CONFIG" >/dev/null 2>&1
}

reload_sysctl_if_drifted() {
  [ -s "$NETWORK_SYSCTL_FILE" ] || return 0

  local drift=0
  local line key expected current
  while IFS= read -r line || [ -n "$line" ]; do
    line="${line%%#*}"
    [ -n "$(trim "$line")" ] || continue
    case "$line" in
      *=*) ;;
      *) continue ;;
    esac

    key="$(trim "${line%%=*}")"
    expected="$(trim "${line#*=}")"
    if [ "$ENABLE_ADAPTIVE_GUARD" = "1" ] && [ -s "$CURRENT_PROFILE_FILE" ] && adaptive_dynamic_key "$key"; then
      continue
    fi
    current="$(sysctl -n "$key" 2>/dev/null | tr '\t' ' ' | awk '{$1=$1; print}' || true)"
    [ -n "$current" ] || continue

    if [ "$current" != "$expected" ]; then
      drift=1
      log "sysctl drift: $key current=$current expected=$expected"
    fi
  done < "$NETWORK_SYSCTL_FILE"

  if [ "$drift" -eq 1 ]; then
    if sysctl -p "$NETWORK_SYSCTL_FILE" >/dev/null 2>&1; then
      log "sysctl reloaded from $NETWORK_SYSCTL_FILE"
    else
      log "sysctl reload failed from $NETWORK_SYSCTL_FILE"
    fi
  fi
}

cleanup_legacy_files() {
  local backup_dir="${OUTPUT_DIR}/backups/guard-legacy-$(date +%Y%m%d-%H%M%S)"
  local moved=0
  local file

  for file in \
    /etc/sysctl.d/99-proxy-aggressive.conf \
    /etc/sysctl.d/99-shadowrocket-vless-tcp.conf \
    /etc/sysctl.d/99-ctrojan-rescue.conf
  do
    if [ -f "$file" ]; then
      if [ "$moved" -eq 0 ]; then
        mkdir -p "$backup_dir"
        moved=1
      fi
      mv "$file" "$backup_dir/"
      log "moved legacy sysctl file: $file -> $backup_dir/"
    fi
  done

  if [ "$moved" -eq 1 ] && [ -s "$NETWORK_SYSCTL_FILE" ]; then
    sysctl -p "$NETWORK_SYSCTL_FILE" >/dev/null 2>&1 || log "sysctl reload failed after legacy cleanup"
  fi
}

memory_available_pct() {
  local current limit

  if [ -r /sys/fs/cgroup/memory.current ] && [ -r /sys/fs/cgroup/memory.max ]; then
    current="$(cat /sys/fs/cgroup/memory.current 2>/dev/null || true)"
    limit="$(cat /sys/fs/cgroup/memory.max 2>/dev/null || true)"
    if printf '%s %s\n' "$current" "$limit" | awk '$1 ~ /^[0-9]+$/ && $2 ~ /^[0-9]+$/ && $2 > 0 {ok=1} END {exit ok ? 0 : 1}'; then
      awk -v current="$current" -v limit="$limit" 'BEGIN {free = limit - current; if (free < 0) free = 0; printf "%d\n", (free * 100 / limit) + 0.5}'
      return
    fi
  fi

  awk '
    /MemTotal:/ {total = $2}
    /MemAvailable:/ {available = $2}
    END {
      if (total > 0 && available > 0) {
        printf "%d\n", (available * 100 / total) + 0.5
      } else {
        print 100
      }
    }
  ' /proc/meminfo 2>/dev/null
}

cpu_steal_pct() {
  local first second total_a steal_a total_b steal_b total_delta steal_delta

  [ -r /proc/stat ] || {
    printf '0\n'
    return
  }

  first="$(awk '/^cpu / {for (i=2; i<=NF; i++) total += $i; print total, $9; exit}' /proc/stat 2>/dev/null || true)"
  sleep 1
  second="$(awk '/^cpu / {for (i=2; i<=NF; i++) total += $i; print total, $9; exit}' /proc/stat 2>/dev/null || true)"

  total_a="$(printf '%s\n' "$first" | awk '{print $1 + 0}')"
  steal_a="$(printf '%s\n' "$first" | awk '{print $2 + 0}')"
  total_b="$(printf '%s\n' "$second" | awk '{print $1 + 0}')"
  steal_b="$(printf '%s\n' "$second" | awk '{print $2 + 0}')"
  total_delta=$((total_b - total_a))
  steal_delta=$((steal_b - steal_a))

  if [ "$total_delta" -gt 0 ] && [ "$steal_delta" -ge 0 ]; then
    awk -v steal="$steal_delta" -v total="$total_delta" 'BEGIN {printf "%d\n", (steal * 100 / total) + 0.5}'
  else
    printf '0\n'
  fi
}

load_pct() {
  local cpu_count="${TUNE_CPU_COUNT:-1}"

  if ! printf '%s\n' "$cpu_count" | awk '$1 ~ /^[0-9]+$/ && $1 > 0 {ok=1} END {exit ok ? 0 : 1}'; then
    cpu_count=1
  fi

  awk -v cpu="$cpu_count" '
    NR == 1 {
      printf "%d\n", ($1 * 100 / cpu) + 0.5
      exit
    }
  ' /proc/loadavg 2>/dev/null
}

retrans_pct() {
  local current previous out retrans prev_out prev_retrans delta_out delta_retrans

  command -v nstat >/dev/null 2>&1 || {
    printf '0\n'
    return
  }

  current="$(nstat -az TcpOutSegs TcpRetransSegs 2>/dev/null | awk '$1 == "TcpOutSegs" {out = $2} $1 == "TcpRetransSegs" {retrans = $2} END {printf "%d %d\n", out, retrans}')"
  out="$(printf '%s\n' "$current" | awk '{print $1 + 0}')"
  retrans="$(printf '%s\n' "$current" | awk '{print $2 + 0}')"

  mkdir -p "$STATE_DIR"
  if [ ! -s "$NSTAT_PREV_FILE" ]; then
    printf '%s %s\n' "$out" "$retrans" > "$NSTAT_PREV_FILE"
    printf '0\n'
    return
  fi

  previous="$(cat "$NSTAT_PREV_FILE" 2>/dev/null || printf '0 0')"
  prev_out="$(printf '%s\n' "$previous" | awk '{print $1 + 0}')"
  prev_retrans="$(printf '%s\n' "$previous" | awk '{print $2 + 0}')"
  printf '%s %s\n' "$out" "$retrans" > "$NSTAT_PREV_FILE"

  delta_out=$((out - prev_out))
  delta_retrans=$((retrans - prev_retrans))

  if [ "$delta_out" -lt 1000 ] || [ "$delta_retrans" -le 0 ]; then
    printf '0\n'
  else
    awk -v retrans="$delta_retrans" -v out="$delta_out" 'BEGIN {printf "%d\n", (retrans * 100 / out) + 0.5}'
  fi
}

pressure_detected() {
  local mem_pct steal_pct load_now_pct retrans_now_pct pressure=0

  mem_pct="$(memory_available_pct)"
  steal_pct="$(cpu_steal_pct)"
  load_now_pct="$(load_pct)"
  retrans_now_pct="$(retrans_pct)"

  if [ "$mem_pct" -lt "$ADAPTIVE_MEMORY_LOW_PCT" ]; then
    log "adaptive pressure: memory_available_pct=$mem_pct threshold=$ADAPTIVE_MEMORY_LOW_PCT"
    pressure=1
  fi

  if [ "$steal_pct" -ge "$ADAPTIVE_STEAL_HIGH_PCT" ]; then
    log "adaptive pressure: cpu_steal_pct=$steal_pct threshold=$ADAPTIVE_STEAL_HIGH_PCT"
    pressure=1
  fi

  if [ "$load_now_pct" -ge "$ADAPTIVE_LOAD_HIGH_PCT" ]; then
    log "adaptive pressure: load_pct=$load_now_pct threshold=$ADAPTIVE_LOAD_HIGH_PCT"
    pressure=1
  fi

  if [ "$retrans_now_pct" -ge "$ADAPTIVE_RETRANS_HIGH_PCT" ]; then
    log "adaptive pressure: retrans_pct=$retrans_now_pct threshold=$ADAPTIVE_RETRANS_HIGH_PCT"
    pressure=1
  fi

  [ "$pressure" -eq 1 ]
}

adaptive_tuning() {
  local base_profile current_profile target_profile now last_pressure restore_after

  [ "$ENABLE_ADAPTIVE_GUARD" = "1" ] || return 0
  [ -r "$TUNING_STATE_FILE" ] || return 0

  # shellcheck disable=SC1090
  . "$TUNING_STATE_FILE" || return 0
  base_profile="${TUNE_PROFILE:-stable}"
  mkdir -p "$STATE_DIR"

  if [ -s "$CURRENT_PROFILE_FILE" ]; then
    current_profile="$(cat "$CURRENT_PROFILE_FILE" 2>/dev/null || printf '%s' "$base_profile")"
  else
    current_profile="$base_profile"
  fi

  if [ "$(profile_rank "$current_profile")" -gt "$(profile_rank "$base_profile")" ]; then
    current_profile="$base_profile"
  fi

  now="$(date +%s)"
  restore_after="$ADAPTIVE_RESTORE_AFTER_SEC"

  if pressure_detected; then
    printf '%s\n' "$now" > "$LAST_PRESSURE_FILE"
    target_profile="$(lower_profile "$current_profile")"
    if [ "$target_profile" != "$current_profile" ]; then
      apply_profile_runtime "$target_profile" || true
    fi
    return 0
  fi

  if [ "$(profile_rank "$current_profile")" -lt "$(profile_rank "$base_profile")" ]; then
    last_pressure="0"
    [ ! -s "$LAST_PRESSURE_FILE" ] || last_pressure="$(cat "$LAST_PRESSURE_FILE" 2>/dev/null || printf '0')"
    if [ $((now - last_pressure)) -ge "$restore_after" ]; then
      target_profile="$(raise_profile_toward "$current_profile" "$base_profile")"
      apply_profile_runtime "$target_profile" || true
      if [ "$target_profile" = "$base_profile" ]; then
        rm -f "$CURRENT_PROFILE_FILE"
      fi
    fi
  else
    rm -f "$CURRENT_PROFILE_FILE"
  fi
}

port_is_listening() {
  command -v ss >/dev/null 2>&1 || return 0
  ss -ltn "( sport = :${PORT} )" 2>/dev/null | awk 'NR > 1 {found=1} END {exit found ? 0 : 1}'
}

restart_xray_throttled() {
  local reason="$1"
  local state_dir="/run/vless-reality-guard"
  local stamp_file="${state_dir}/last_restart"
  local now last

  if ! config_is_valid; then
    log "skip restart for $reason: xray config invalid"
    return 0
  fi

  mkdir -p "$state_dir"
  now="$(date +%s)"
  last="0"
  [ ! -f "$stamp_file" ] || last="$(cat "$stamp_file" 2>/dev/null || printf '0')"

  if [ $((now - last)) -lt "$RESTART_COOLDOWN_SEC" ]; then
    log "skip restart for $reason: cooldown active"
    return 0
  fi

  if systemctl restart "$XRAY_SERVICE"; then
    printf '%s\n' "$now" > "$stamp_file"
    log "restarted $XRAY_SERVICE: $reason"
  else
    log "restart failed for $XRAY_SERVICE: $reason"
  fi
}

main() {
  with_lock
  cleanup_legacy_files
  reload_sysctl_if_drifted
  adaptive_tuning

  if ! systemctl is-active --quiet "$XRAY_SERVICE"; then
    restart_xray_throttled "service inactive"
    return 0
  fi

  if ! port_is_listening; then
    restart_xray_throttled "port ${PORT} not listening"
  fi
}

