disable_redundant_services() {
  if [ "$DISABLE_REDUNDANT" != "1" ]; then
    return
  fi

  local unit
  for unit in \
    vless-c-proxy.service \
    cvless.service \
    trafficctl.service \
    trafficctl-mock-metrics.service \
    shadowrocket-vless-tcp-optimizer.timer
  do
    if systemctl list-unit-files "$unit" >/dev/null 2>&1; then
      systemctl disable --now "$unit" >/dev/null 2>&1 || true
      systemctl reset-failed "$unit" >/dev/null 2>&1 || true
      log "disabled old unit if present: $unit"
    fi
  done
}

cleanup_legacy_tuning() {
  if [ "$CLEAN_LEGACY_TUNING" != "1" ]; then
    return
  fi

  local backup_dir="${OUTPUT_DIR}/backups/legacy-$(date +%Y%m%d-%H%M%S)"
  local moved=0
  local file

  for file in \
    /etc/sysctl.d/99-proxy-aggressive.conf \
    /etc/sysctl.d/99-shadowrocket-vless-tcp.conf \
    /etc/sysctl.d/99-ctrojan-rescue.conf
  do
    if [ -f "$file" ]; then
      if [ "$moved" -eq 0 ]; then
        mkdir -p "$backup_dir"
        moved=1
      fi
      mv "$file" "$backup_dir/"
      log "moved legacy sysctl file: $file -> $backup_dir/"
    fi
  done

  local managed_dropin="/etc/systemd/system/${XRAY_SERVICE}.service.d/20-vless-reality-performance.conf"
  local legacy_dropin="/etc/systemd/system/${XRAY_SERVICE}.service.d/override.conf"
  if [ -f "$managed_dropin" ] && [ -f "$legacy_dropin" ] && cmp -s "$managed_dropin" "$legacy_dropin"; then
    if [ "$moved" -eq 0 ]; then
      mkdir -p "$backup_dir"
      moved=1
    fi
    mv "$legacy_dropin" "$backup_dir/"
    systemctl daemon-reload || true
    log "moved duplicate systemd drop-in: $legacy_dropin -> $backup_dir/"
  fi

  if [ "$moved" -eq 1 ] && [ -s "$NETWORK_SYSCTL_FILE" ]; then
    sysctl -p "$NETWORK_SYSCTL_FILE" >/dev/null || true
  fi
}

find_c_compiler() {
  local candidate

  for candidate in "${CC:-}" cc gcc clang; do
    [ -n "$candidate" ] || continue
    if command -v "$candidate" >/dev/null 2>&1; then
      command -v "$candidate"
      return 0
    fi
  done

  return 1
}

configure_c_guard() {
  local guard_service="$1"
  local guard_timer="$2"
  local compiler
  local guard_bin="/usr/local/sbin/vless-reality-guard"
  local guard_source="/usr/local/src/vless-reality-guard.c"
  local guard_config="/etc/vless-reality/guard.conf"

  if [ "$ENABLE_C_GUARD" != "1" ]; then
    return 1
  fi

  if ! compiler="$(find_c_compiler)"; then
    log "c guard skipped: no C compiler found"
    return 1
  fi

  mkdir -p "$(dirname "$guard_bin")" "$(dirname "$guard_source")" "$(dirname "$guard_config")"

  cat > "$guard_source" <<'EOF'
#include <ctype.h>
#include <errno.h>
#include <limits.h>
#include <stdarg.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <sys/stat.h>
#include <sys/types.h>
#include <sys/wait.h>
#include <syslog.h>
#include <time.h>
#include <unistd.h>

#ifndef PATH_MAX
#define PATH_MAX 4096
#endif

struct guard_config {
  char xray_bin[PATH_MAX];
  char xray_config[PATH_MAX];
  char xray_service[128];
  char network_sysctl_file[PATH_MAX];
  int port;
  int restart_cooldown_sec;
};

static const char *lock_dir = "/run/vless-reality-guard.lock";
static const char *state_dir = "/run/vless-reality-guard";

static void copy_str(char *dst, size_t size, const char *src) {
  if (size == 0) return;
  if (!src) src = "";
  snprintf(dst, size, "%s", src);
}

static void log_msg(const char *fmt, ...) {
  va_list ap;
  va_start(ap, fmt);
  vsyslog(LOG_INFO, fmt, ap);
  va_end(ap);
}

static char *trim(char *s) {
  char *end;
  while (*s && isspace((unsigned char)*s)) s++;
  if (*s == '\0') return s;
  end = s + strlen(s) - 1;
  while (end > s && isspace((unsigned char)*end)) *end-- = '\0';
  return s;
}

static void normalize_spaces(char *s) {
  char *r = s, *w = s;
  int in_space = 0;

  while (*r && isspace((unsigned char)*r)) r++;
  for (; *r; r++) {
    if (isspace((unsigned char)*r)) {
      if (!in_space) *w++ = ' ';
      in_space = 1;
    } else {
      *w++ = *r;
      in_space = 0;
    }
  }
  if (w > s && w[-1] == ' ') w--;
  *w = '\0';
}

static void unescape_value(char *s) {
  char *r = s, *w = s;
  size_t len = strlen(s);

  if (len >= 2 && ((s[0] == '\'' && s[len - 1] == '\'') || (s[0] == '"' && s[len - 1] == '"'))) {
    s[len - 1] = '\0';
    r = s + 1;
  }

  while (*r) {
    if (*r == '\\' && r[1]) r++;
    *w++ = *r++;
  }
  *w = '\0';
}

static int mkdir_p(const char *path, mode_t mode) {
  char tmp[PATH_MAX];
  size_t len;

  if (!path || !*path) return -1;
  copy_str(tmp, sizeof(tmp), path);
  len = strlen(tmp);
  if (len == 0) return -1;
  if (tmp[len - 1] == '/') tmp[len - 1] = '\0';

  for (char *p = tmp + 1; *p; p++) {
    if (*p == '/') {
      *p = '\0';
      if (mkdir(tmp, mode) != 0 && errno != EEXIST) return -1;
      *p = '/';
    }
  }

  if (mkdir(tmp, mode) != 0 && errno != EEXIST) return -1;
  return 0;
}

static int ensure_parent_dir(const char *path, mode_t mode) {
  char tmp[PATH_MAX];
  char *slash;

  copy_str(tmp, sizeof(tmp), path);
  slash = strrchr(tmp, '/');
  if (!slash || slash == tmp) return 0;
  *slash = '\0';
  return mkdir_p(tmp, mode);
}

static int read_first_line(const char *path, char *buf, size_t size) {
  FILE *fp = fopen(path, "r");
  char *nl;
  if (!fp) return -1;
  if (!fgets(buf, (int)size, fp)) {
    fclose(fp);
    return -1;
  }
  fclose(fp);
  nl = strchr(buf, '\n');
  if (nl) *nl = '\0';
  return 0;
}

static int write_text_file(const char *path, const char *value) {
  FILE *fp;
  if (ensure_parent_dir(path, 0700) != 0) return -1;
  fp = fopen(path, "w");
  if (!fp) return -1;
  if (fputs(value, fp) == EOF) {
    fclose(fp);
    return -1;
  }
  fclose(fp);
  return 0;
}

static void init_config(struct guard_config *cfg) {
  copy_str(cfg->xray_bin, sizeof(cfg->xray_bin), "/usr/local/bin/xray");
  copy_str(cfg->xray_config, sizeof(cfg->xray_config), "/usr/local/etc/xray/config.json");
  copy_str(cfg->xray_service, sizeof(cfg->xray_service), "xray");
  copy_str(cfg->network_sysctl_file, sizeof(cfg->network_sysctl_file), "/etc/sysctl.d/99-vless-reality-performance.conf");
  cfg->port = 443;
  cfg->restart_cooldown_sec = 300;
}

static void set_config_value(struct guard_config *cfg, const char *key, const char *value) {
  if (strcmp(key, "XRAY_BIN") == 0) copy_str(cfg->xray_bin, sizeof(cfg->xray_bin), value);
  else if (strcmp(key, "XRAY_CONFIG") == 0) copy_str(cfg->xray_config, sizeof(cfg->xray_config), value);
  else if (strcmp(key, "XRAY_SERVICE") == 0) copy_str(cfg->xray_service, sizeof(cfg->xray_service), value);
  else if (strcmp(key, "PORT") == 0) cfg->port = atoi(value);
  else if (strcmp(key, "NETWORK_SYSCTL_FILE") == 0) copy_str(cfg->network_sysctl_file, sizeof(cfg->network_sysctl_file), value);
  else if (strcmp(key, "RESTART_COOLDOWN_SEC") == 0) cfg->restart_cooldown_sec = atoi(value);
}

static void load_config_file(struct guard_config *cfg, const char *path) {
  FILE *fp = fopen(path, "r");
  char line[4096];
  if (!fp) return;

  while (fgets(line, sizeof(line), fp)) {
    char *hash = strchr(line, '#');
    char *eq;
    char *key;
    char *value;
    if (hash) *hash = '\0';
    key = trim(line);
    if (*key == '\0') continue;
    eq = strchr(key, '=');
    if (!eq) continue;
    *eq = '\0';
    value = trim(eq + 1);
    key = trim(key);
    unescape_value(value);
    set_config_value(cfg, key, value);
  }

  fclose(fp);
}

static int run_cmd(char *const argv[]) {
  pid_t pid = fork();
  int status = 0;
  if (pid < 0) return 0;
  if (pid == 0) {
    execvp(argv[0], argv);
    _exit(127);
  }
  if (waitpid(pid, &status, 0) < 0) return 0;
  return WIFEXITED(status) && WEXITSTATUS(status) == 0;
}

static int run_sysctl_p(const char *path) {
  char *const argv[] = {"sysctl", "-p", (char *)path, NULL};
  return run_cmd(argv);
}

static int systemctl_is_active(const char *service) {
  char *const argv[] = {"systemctl", "is-active", "--quiet", (char *)service, NULL};
  return run_cmd(argv);
}

static int systemctl_restart(const char *service) {
  char *const argv[] = {"systemctl", "restart", (char *)service, NULL};
  return run_cmd(argv);
}

static int config_is_valid(const struct guard_config *cfg) {
  char *const argv[] = {(char *)cfg->xray_bin, "run", "-test", "-config", (char *)cfg->xray_config, NULL};
  return run_cmd(argv);
}

static void sysctl_proc_path(const char *key, char *out, size_t size) {
  size_t pos = 0;
  const char *prefix = "/proc/sys/";
  snprintf(out, size, "%s", prefix);
  pos = strlen(out);
  for (const char *p = key; *p && pos + 1 < size; p++) {
    out[pos++] = (*p == '.') ? '/' : *p;
  }
  out[pos] = '\0';
}

static int read_sysctl_value(const char *key, char *out, size_t size) {
  char path[PATH_MAX];
  sysctl_proc_path(key, path, sizeof(path));
  if (read_first_line(path, out, size) != 0) return 0;
  normalize_spaces(out);
  return 1;
}

static void reload_sysctl_if_drifted(const struct guard_config *cfg) {
  FILE *fp = fopen(cfg->network_sysctl_file, "r");
  char line[4096];
  int drift = 0;
  if (!fp) return;

  while (fgets(line, sizeof(line), fp)) {
    char *hash = strchr(line, '#');
    char *eq;
    char *key;
    char *expected;
    char current[1024];
    if (hash) *hash = '\0';
    key = trim(line);
    if (*key == '\0') continue;
    eq = strchr(key, '=');
    if (!eq) continue;
    *eq = '\0';
    expected = trim(eq + 1);
    key = trim(key);
    normalize_spaces(expected);

    if (!read_sysctl_value(key, current, sizeof(current))) continue;
    if (strcmp(current, expected) != 0) {
      drift = 1;
      log_msg("sysctl drift: %s current=%s expected=%s", key, current, expected);
    }
  }

  fclose(fp);
  if (drift) {
    if (run_sysctl_p(cfg->network_sysctl_file)) log_msg("sysctl reloaded from %s", cfg->network_sysctl_file);
    else log_msg("sysctl reload failed from %s", cfg->network_sysctl_file);
  }
}

static int port_is_listening_file(const char *path, int port) {
  FILE *fp = fopen(path, "r");
  char line[1024];
  if (!fp) return 0;
  if (!fgets(line, sizeof(line), fp)) {
    fclose(fp);
    return 0;
  }
  while (fgets(line, sizeof(line), fp)) {
    char local[128], st[16];
    char *colon;
    long local_port;
    if (sscanf(line, " %*d: %127s %*127s %15s", local, st) != 2) continue;
    colon = strrchr(local, ':');
    if (!colon) continue;
    local_port = strtol(colon + 1, NULL, 16);
    if (local_port == port && strcmp(st, "0A") == 0) {
      fclose(fp);
      return 1;
    }
  }
  fclose(fp);
  return 0;
}

static int port_is_listening(int port) {
  return port_is_listening_file("/proc/net/tcp", port) || port_is_listening_file("/proc/net/tcp6", port);
}

static void restart_xray_throttled(const struct guard_config *cfg, const char *reason) {
  char stamp_file[PATH_MAX];
  char buf[64];
  long last = 0;
  long now = (long)time(NULL);

  if (!config_is_valid(cfg)) {
    log_msg("skip restart for %s: xray config invalid", reason);
    return;
  }

  mkdir_p(state_dir, 0700);
  snprintf(stamp_file, sizeof(stamp_file), "%s/last_restart", state_dir);
  if (read_first_line(stamp_file, buf, sizeof(buf)) == 0) last = atol(buf);
  if (now - last < cfg->restart_cooldown_sec) {
    log_msg("skip restart for %s: cooldown active", reason);
    return;
  }

  if (systemctl_restart(cfg->xray_service)) {
    snprintf(buf, sizeof(buf), "%ld\n", now);
    write_text_file(stamp_file, buf);
    log_msg("restarted %s: %s", cfg->xray_service, reason);
  } else {
    log_msg("restart failed for %s: %s", cfg->xray_service, reason);
  }
}

int main(int argc, char **argv) {
  struct guard_config cfg;
  const char *config_path = argc > 1 ? argv[1] : "/etc/vless-reality/guard.conf";
  time_t now;

  openlog("vless-reality-guard", LOG_PID, LOG_DAEMON);
  init_config(&cfg);
  load_config_file(&cfg, config_path);
  if (cfg.port <= 0) cfg.port = 443;
  if (cfg.restart_cooldown_sec <= 0) cfg.restart_cooldown_sec = 300;

  now = time(NULL);
  if (mkdir(lock_dir, 0700) != 0) {
    if (errno == EEXIST) {
      struct stat st;
      if (stat(lock_dir, &st) == 0 && now - st.st_mtime > 600) {
        rmdir(lock_dir);
        if (mkdir(lock_dir, 0700) == 0) goto locked;
      }
      closelog();
      return 0;
    }
    log_msg("lock failed: %s", strerror(errno));
    closelog();
    return 0;
  }

locked:
  reload_sysctl_if_drifted(&cfg);

  if (!systemctl_is_active(cfg.xray_service)) {
    restart_xray_throttled(&cfg, "service inactive");
    rmdir(lock_dir);
    closelog();
    return 0;
  }

  if (!port_is_listening(cfg.port)) {
    restart_xray_throttled(&cfg, "port not listening");
  }

  rmdir(lock_dir);
  closelog();
  return 0;
}
EOF

  if ! "$compiler" -O2 -Wall -Wextra -o "$guard_bin" "$guard_source"; then
    log "c guard compile failed with $compiler"
    rm -f "$guard_bin"
    return 1
  fi

  chmod 0755 "$guard_bin"

  cat > "$guard_config" <<EOF
XRAY_BIN=$XRAY_BIN
XRAY_CONFIG=$XRAY_CONFIG
XRAY_SERVICE=$XRAY_SERVICE
PORT=$PORT
NETWORK_SYSCTL_FILE=$NETWORK_SYSCTL_FILE
RESTART_COOLDOWN_SEC=$GUARD_RESTART_COOLDOWN_SEC
EOF
  chmod 0600 "$guard_config"

  cat > "$guard_service" <<EOF
