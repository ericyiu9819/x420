    printf 'RESTART_COOLDOWN_SEC=%q\n' "$GUARD_RESTART_COOLDOWN_SEC"
    printf 'ENABLE_ADAPTIVE_GUARD=%q\n' "$ENABLE_ADAPTIVE_GUARD"
    printf 'ADAPTIVE_RESTORE_AFTER_SEC=%q\n' "$ADAPTIVE_RESTORE_AFTER_SEC"
