#!/usr/bin/env bash
set -Eeuo pipefail

# Slim balanced VLESS REALITY installer with first-run VPS parameter tuning.
# Runtime path:
# Client -> VLESS + TCP + REALITY + XTLS Vision -> Xray:443 -> freedom direct.

XRAY_BIN="${XRAY_BIN:-/usr/local/bin/xray}"
XRAY_CONFIG="${XRAY_CONFIG:-/usr/local/etc/xray/config.json}"
XRAY_SERVICE="${XRAY_SERVICE:-xray}"

SERVER_ADDRESS="${SERVER_ADDRESS:-}"
PORT="${PORT:-443}"
UUID="${UUID:-}"
REALITY_DEST_DOMAIN="${REALITY_DEST_DOMAIN:-www.cloudflare.com}"
REALITY_DEST_PORT="${REALITY_DEST_PORT:-443}"
REALITY_PRIVATE_KEY="${REALITY_PRIVATE_KEY:-}"
REALITY_PUBLIC_KEY="${REALITY_PUBLIC_KEY:-}"
SHORT_ID="${SHORT_ID:-}"
OUTPUT_DIR="${OUTPUT_DIR:-/root/vless-reality}"
DEPLOY_RUN_ID="${DEPLOY_RUN_ID:-}"

INSTALL_XRAY_IF_MISSING="${INSTALL_XRAY_IF_MISSING:-1}"
ENABLE_BBR="${ENABLE_BBR:-1}"
ENABLE_NETWORK_OPTIMIZATION="${ENABLE_NETWORK_OPTIMIZATION:-1}"
ENABLE_XRAY_SOCKOPT="${ENABLE_XRAY_SOCKOPT:-1}"
ENABLE_SYSTEMD_LIMITS="${ENABLE_SYSTEMD_LIMITS:-1}"
DISABLE_REDUNDANT="${DISABLE_REDUNDANT:-1}"
CLEAN_LEGACY_TUNING="${CLEAN_LEGACY_TUNING:-1}"
ENABLE_GUARD="${ENABLE_GUARD:-1}"
ENABLE_C_GUARD="${ENABLE_C_GUARD:-1}"
GUARD_INTERVAL_SEC="${GUARD_INTERVAL_SEC:-60}"
GUARD_RESTART_COOLDOWN_SEC="${GUARD_RESTART_COOLDOWN_SEC:-300}"
NETWORK_TUNING_PROFILE="${NETWORK_TUNING_PROFILE:-auto}"
EXPECTED_CONNECTIONS="${EXPECTED_CONNECTIONS:-128}"
NETWORK_SYSCTL_FILE="${NETWORK_SYSCTL_FILE:-/etc/sysctl.d/99-vless-reality-performance.conf}"
TUNING_STATE_DIR="${TUNING_STATE_DIR:-/var/lib/vless-reality}"
TUNING_STATE_FILE="${TUNING_STATE_FILE:-${TUNING_STATE_DIR}/tuning.env}"
BAREMETAL_MODE="${BAREMETAL_MODE:-1}"
BAREMETAL_SET_GOMAXPROCS="${BAREMETAL_SET_GOMAXPROCS:-1}"
BAREMETAL_XRAY_NICE="${BAREMETAL_XRAY_NICE:--5}"
BAREMETAL_XRAY_IO_CLASS="${BAREMETAL_XRAY_IO_CLASS:-best-effort}"
BAREMETAL_XRAY_IO_PRIORITY="${BAREMETAL_XRAY_IO_PRIORITY:-0}"
BAREMETAL_CPU_WEIGHT="${BAREMETAL_CPU_WEIGHT:-10000}"
BAREMETAL_IO_WEIGHT="${BAREMETAL_IO_WEIGHT:-10000}"
ENABLE_BAREMETAL_NET_QUEUES="${ENABLE_BAREMETAL_NET_QUEUES:-auto}"

log() {
  printf '[vless-reality-slim] %s\n' "$*"
}

fail() {
  printf '[vless-reality-slim] ERROR: %s\n' "$*" >&2
  exit 1
}

require_root() {
  if [ "$(id -u)" -ne 0 ]; then
    fail "run as root"
  fi
}

need_cmd() {
  command -v "$1" >/dev/null 2>&1 || fail "missing command: $1"
}

install_xray_if_needed() {
  if [ -x "$XRAY_BIN" ]; then
    return
  fi

  if [ "$INSTALL_XRAY_IF_MISSING" != "1" ]; then
    fail "xray not found at $XRAY_BIN; set INSTALL_XRAY_IF_MISSING=1 or install Xray first"
  fi

  need_cmd curl
  log "xray not found, installing Xray with official installer"
  tmp_installer="/tmp/xray-install-release.sh"
  curl -fsSL https://github.com/XTLS/Xray-install/raw/main/install-release.sh -o "$tmp_installer"
  bash "$tmp_installer" install
  rm -f "$tmp_installer"

  [ -x "$XRAY_BIN" ] || fail "xray install finished but $XRAY_BIN is still missing"
}

detect_server_address() {
  if [ -n "$SERVER_ADDRESS" ]; then
    return
  fi

  if command -v curl >/dev/null 2>&1; then
    SERVER_ADDRESS="$(curl -4 -fsS --max-time 5 https://api.ipify.org 2>/dev/null || true)"
  fi

  if [ -z "$SERVER_ADDRESS" ] && command -v hostname >/dev/null 2>&1; then
    SERVER_ADDRESS="$(hostname -I 2>/dev/null | awk '{print $1}' || true)"
  fi

  [ -n "$SERVER_ADDRESS" ] || fail "cannot detect public IP; rerun with SERVER_ADDRESS=your_ip"
}

generate_uuid() {
  if [ -n "$UUID" ]; then
    return
  fi

  UUID="$("$XRAY_BIN" uuid 2>/dev/null || true)"
  if [ -z "$UUID" ] && [ -r /proc/sys/kernel/random/uuid ]; then
    UUID="$(cat /proc/sys/kernel/random/uuid)"
  fi

  [ -n "$UUID" ] || fail "cannot generate UUID"
}

generate_reality_keys() {
  if [ -n "$REALITY_PRIVATE_KEY" ] || [ -n "$REALITY_PUBLIC_KEY" ]; then
    [ -n "$REALITY_PRIVATE_KEY" ] || fail "REALITY_PUBLIC_KEY is set but REALITY_PRIVATE_KEY is missing"
    [ -n "$REALITY_PUBLIC_KEY" ] || fail "REALITY_PRIVATE_KEY is set but REALITY_PUBLIC_KEY is missing"
    PRIVATE_KEY="$REALITY_PRIVATE_KEY"
    PUBLIC_KEY="$REALITY_PUBLIC_KEY"
    return
  fi

  local key_output
  key_output="$("$XRAY_BIN" x25519)"

  PRIVATE_KEY="$(printf '%s\n' "$key_output" | awk '/^PrivateKey:/ {print $2; exit}')"
  PUBLIC_KEY="$(printf '%s\n' "$key_output" | awk -F': ' '/^Password \(PublicKey\):/ {print $2; exit} /^PublicKey:/ {print $2; exit}')"

  [ -n "$PRIVATE_KEY" ] || fail "cannot parse REALITY private key"
  [ -n "$PUBLIC_KEY" ] || fail "cannot parse REALITY public key"
}

generate_short_id() {
  if [ -n "$SHORT_ID" ]; then
    return
  fi

  if command -v openssl >/dev/null 2>&1; then
    SHORT_ID="$(openssl rand -hex 8)"
  else
    SHORT_ID="$(od -An -N8 -tx1 /dev/urandom | tr -d ' \n')"
  fi

  [ -n "$SHORT_ID" ] || fail "cannot generate shortId"
}

write_server_config() {
  local server_sockopt_json=""
  local candidate_config

  if [ "$ENABLE_XRAY_SOCKOPT" = "1" ]; then
    server_sockopt_json='        "sockopt": {
          "tcpFastOpen": true,
          "tcpNoDelay": true
        },'
  fi

  candidate_config="$(mktemp /tmp/vless-reality-config.XXXXXX.json)"
  mkdir -p "$(dirname "$XRAY_CONFIG")"

  cat > "$candidate_config" <<EOF
{
  "log": {
    "loglevel": "warning"
  },
  "inbounds": [
    {
      "tag": "vless-reality-in",
      "listen": "0.0.0.0",
      "port": ${PORT},
      "protocol": "vless",
      "settings": {
        "clients": [
          {
            "id": "${UUID}",
            "flow": "xtls-rprx-vision",
            "email": "main"
          }
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "tcp",
        "security": "reality",
${server_sockopt_json}
        "realitySettings": {
          "show": false,
          "dest": "${REALITY_DEST_DOMAIN}:${REALITY_DEST_PORT}",
          "xver": 0,
          "serverNames": [
            "${REALITY_DEST_DOMAIN}"
          ],
          "privateKey": "${PRIVATE_KEY}",
          "shortIds": [
            "${SHORT_ID}"
          ]
        }
      }
    }
  ],
  "outbounds": [
    {
      "tag": "direct",
      "protocol": "freedom"
    }
  ]
}
EOF

  if ! "$XRAY_BIN" run -test -config "$candidate_config"; then
    rm -f "$candidate_config"
    fail "candidate Xray config failed validation; current config was not changed"
  fi

  BACKUP_PATH=""
  if [ -f "$XRAY_CONFIG" ]; then
    BACKUP_PATH="${XRAY_CONFIG}.bak-$(date +%Y%m%d-%H%M%S)"
    cp "$XRAY_CONFIG" "$BACKUP_PATH"
    log "backup written: $BACKUP_PATH"
  fi

  install -m 0600 "$candidate_config" "$XRAY_CONFIG"
  rm -f "$candidate_config"
}

append_sysctl_if_exists() {
  local key="$1"
  local value="$2"
  local proc_path="/proc/sys/${key//./\/}"

  if [ -e "$proc_path" ]; then
    printf '%s=%s\n' "$key" "$value" >> "$NETWORK_SYSCTL_FILE"
  else
    log "skip sysctl $key: unsupported by this kernel"
  fi
}

detect_memory_mb() {
  awk '/MemTotal:/ {printf "%d\n", $2 / 1024; found=1} END {if (!found) print 1024}' /proc/meminfo 2>/dev/null
}

detect_cgroup_memory_limit_mb() {
  local limit=""

  if [ -r /sys/fs/cgroup/memory.max ]; then
    limit="$(cat /sys/fs/cgroup/memory.max 2>/dev/null || true)"
  elif [ -r /sys/fs/cgroup/memory/memory.limit_in_bytes ]; then
    limit="$(cat /sys/fs/cgroup/memory/memory.limit_in_bytes 2>/dev/null || true)"
  fi

  awk -v value="$limit" '
    BEGIN {
      if (value ~ /^[0-9]+$/ && value > 0 && value < 9000000000000000000) {
        printf "%d\n", value / 1024 / 1024
      } else {
        print 0
      }
    }
  '
}

detect_swap_mb() {
  awk '/SwapTotal:/ {printf "%d\n", $2 / 1024; found=1} END {if (!found) print 0}' /proc/meminfo 2>/dev/null
}

detect_cpu_count() {
  if command -v nproc >/dev/null 2>&1; then
    nproc 2>/dev/null || printf '1\n'
  else
    awk '/^processor[[:space:]]*:/ {count += 1} END {print count > 0 ? count : 1}' /proc/cpuinfo 2>/dev/null
  fi
}

detect_cpu_quota_milli() {
  if [ -r /sys/fs/cgroup/cpu.max ]; then
    awk '
      NR == 1 {
        if ($1 == "max" || $2 <= 0) {
          print 0
        } else {
          printf "%d\n", ($1 * 1000) / $2
        }
        exit
      }
    ' /sys/fs/cgroup/cpu.max 2>/dev/null
    return
  fi

  if [ -r /sys/fs/cgroup/cpu/cpu.cfs_quota_us ] && [ -r /sys/fs/cgroup/cpu/cpu.cfs_period_us ]; then
    awk '
      NR == FNR {quota = $1; next}
      {period = $1}
      END {
        if (quota <= 0 || period <= 0) {
          print 0
        } else {
          printf "%d\n", (quota * 1000) / period
        }
      }
    ' /sys/fs/cgroup/cpu/cpu.cfs_quota_us /sys/fs/cgroup/cpu/cpu.cfs_period_us 2>/dev/null
    return
  fi

  printf '0\n'
}

detect_cpu_steal_pct() {
  local first second total_a steal_a total_b steal_b total_delta steal_delta

  [ -r /proc/stat ] || {
    printf '0\n'
    return
  }

  first="$(awk '/^cpu / {for (i=2; i<=NF; i++) total += $i; print total, $9; exit}' /proc/stat 2>/dev/null || true)"
  sleep 1
  second="$(awk '/^cpu / {for (i=2; i<=NF; i++) total += $i; print total, $9; exit}' /proc/stat 2>/dev/null || true)"

  total_a="$(printf '%s\n' "$first" | awk '{print $1 + 0}')"
  steal_a="$(printf '%s\n' "$first" | awk '{print $2 + 0}')"
  total_b="$(printf '%s\n' "$second" | awk '{print $1 + 0}')"
  steal_b="$(printf '%s\n' "$second" | awk '{print $2 + 0}')"
  total_delta=$((total_b - total_a))
  steal_delta=$((steal_b - steal_a))

  if [ "$total_delta" -gt 0 ] && [ "$steal_delta" -ge 0 ]; then
    awk -v steal="$steal_delta" -v total="$total_delta" 'BEGIN {printf "%d\n", (steal * 100 / total) + 0.5}'
  else
    printf '0\n'
  fi
}

detect_load_pct() {
  local cpu_count="$1"
  awk -v cpu="$cpu_count" '
    NR == 1 {
      if (cpu < 1) cpu = 1
      printf "%d\n", ($1 * 100 / cpu) + 0.5
      exit
    }
  ' /proc/loadavg 2>/dev/null
}

detect_default_iface() {
  if command -v ip >/dev/null 2>&1; then
    ip route get 1.1.1.1 2>/dev/null | awk '{for (i=1; i<=NF; i++) if ($i == "dev") {print $(i+1); exit}}'
    return
  fi

  find /sys/class/net -mindepth 1 -maxdepth 1 -type l -printf '%f\n' 2>/dev/null | awk '$1 != "lo" {print; exit}'
}

detect_iface_speed_mbps() {
  local iface="$1"
  local speed_file="/sys/class/net/${iface}/speed"
  local speed=""

  if [ -n "$iface" ] && [ -r "$speed_file" ]; then
    speed="$(cat "$speed_file" 2>/dev/null || true)"
  fi

  if printf '%s\n' "$speed" | awk '$1 ~ /^[0-9]+$/ && $1 > 0 && $1 <= 100000 {ok=1} END {exit ok ? 0 : 1}'; then
    printf '%s\n' "$speed"
  else
    printf '0\n'
  fi
}

detect_iface_virtual() {
  local iface="$1"

  if [ -n "$iface" ] && [ -e "/sys/devices/virtual/net/${iface}" ]; then
    printf '1\n'
  else
    printf '0\n'
  fi
}

detect_system_virtualized() {
  if command -v systemd-detect-virt >/dev/null 2>&1; then
    if systemd-detect-virt --quiet 2>/dev/null; then
      printf '1\n'
    else
      printf '0\n'
    fi
    return
  fi

  if [ -r /sys/class/dmi/id/product_name ] &&
    grep -Eiq 'kvm|qemu|virtual|vmware|hyper-v|openstack|bochs|xen|hvm domU' /sys/class/dmi/id/product_name 2>/dev/null; then
    printf '1\n'
  else
    printf '0\n'
  fi
}

normalize_expected_connections() {
  if printf '%s\n' "$EXPECTED_CONNECTIONS" | awk '$1 ~ /^[0-9]+$/ && $1 > 0 {ok=1} END {exit ok ? 0 : 1}'; then
    printf '%s\n' "$EXPECTED_CONNECTIONS"
  else
    printf '128\n'
  fi
}

detect_rtt_ms() {
  if command -v ping >/dev/null 2>&1; then
    local ping_out
    ping_out="$(ping -4 -c 3 -W 1 1.1.1.1 2>/dev/null || true)"
    if [ -n "$ping_out" ]; then
      local avg
      avg="$(printf '%s\n' "$ping_out" | awk -F'/' '/rtt|round-trip/ {print int($5 + 0.5); exit}')"
      if printf '%s\n' "$avg" | awk '$1 ~ /^[0-9]+$/ && $1 > 0 {ok=1} END {exit ok ? 0 : 1}'; then
        printf '%s\n' "$avg"
        return
      fi
    fi
  fi

  if command -v curl >/dev/null 2>&1; then
    local connect_time
    connect_time="$(curl -4 -fsS -o /dev/null -w '%{time_connect}' --connect-timeout 3 --max-time 5 https://www.cloudflare.com/ 2>/dev/null || true)"
    if [ -n "$connect_time" ]; then
      local ms
      ms="$(awk -v seconds="$connect_time" 'BEGIN {printf "%d\n", (seconds * 1000) + 0.5}')"
      if printf '%s\n' "$ms" | awk '$1 ~ /^[0-9]+$/ && $1 > 0 {ok=1} END {exit ok ? 0 : 1}'; then
        printf '%s\n' "$ms"
        return
      fi
    fi
  fi

  printf '120\n'
}

set_tuning_profile_values() {
  local profile="$1"

  case "$profile" in
    compact)
      TUNE_NETDEV_BACKLOG=2048
      TUNE_RMEM_MAX=8388608
      TUNE_WMEM_MAX=8388608
      TUNE_TCP_RMEM="4096 87380 8388608"
      TUNE_TCP_WMEM="4096 65536 8388608"
      TUNE_TCP_NOTSENT_LOWAT=65536
      ;;
    stable)
      TUNE_NETDEV_BACKLOG=4096
      TUNE_RMEM_MAX=16777216
      TUNE_WMEM_MAX=16777216
      TUNE_TCP_RMEM="4096 87380 16777216"
      TUNE_TCP_WMEM="4096 65536 16777216"
      TUNE_TCP_NOTSENT_LOWAT=131072
      ;;
    throughput)
      TUNE_NETDEV_BACKLOG=8192
      TUNE_RMEM_MAX=33554432
      TUNE_WMEM_MAX=33554432
      TUNE_TCP_RMEM="4096 87380 33554432"
      TUNE_TCP_WMEM="4096 65536 33554432"
      TUNE_TCP_NOTSENT_LOWAT=262144
      ;;
    extreme)
      TUNE_NETDEV_BACKLOG=16384
      TUNE_RMEM_MAX=67108864
      TUNE_WMEM_MAX=67108864
      TUNE_TCP_RMEM="4096 87380 67108864"
      TUNE_TCP_WMEM="4096 65536 67108864"
      TUNE_TCP_NOTSENT_LOWAT=262144
      ;;
    *)
      fail "unsupported NETWORK_TUNING_PROFILE=$NETWORK_TUNING_PROFILE; use auto, compact, stable, throughput, or extreme"
      ;;
  esac

  TUNE_PROFILE="$profile"
  TUNE_RMEM_DEFAULT=212992
  TUNE_WMEM_DEFAULT=212992
}

profile_rank() {
  case "$1" in
    compact) printf '0\n' ;;
    stable) printf '1\n' ;;
    throughput) printf '2\n' ;;
    extreme) printf '3\n' ;;
    *) printf '1\n' ;;
  esac
}

profile_at_most() {
  local current="$1"
  local max_profile="$2"

  if [ "$(profile_rank "$current")" -gt "$(profile_rank "$max_profile")" ]; then
    printf '%s\n' "$max_profile"
  else
    printf '%s\n' "$current"
  fi
}

cpu_mask_for_count() {
  local cpu_count="$1"

  if ! printf '%s\n' "$cpu_count" | awk '$1 ~ /^[0-9]+$/ && $1 > 1 && $1 <= 32 {ok=1} END {exit ok ? 0 : 1}'; then
    return 1
  fi

  printf '%x\n' $(((1 << cpu_count) - 1))
}

heuristic_tuning_profile() {
  local profile="stable"

  if [ "$TUNE_MEMORY_MB" -lt 512 ]; then
    profile="compact"
  fi

  if [ "$TUNE_MEMORY_MB" -ge 1024 ] &&
    { [ "$TUNE_SPEED_MBPS" -ge 500 ] || [ "$TUNE_RTT_MS" -ge 80 ]; }; then
    profile="throughput"
  fi

  if [ "$TUNE_MEMORY_MB" -ge 4096 ] &&
    [ "$TUNE_SPEED_MBPS" -ge 900 ] &&
    [ "$TUNE_CPU_COUNT" -ge 2 ]; then
    profile="extreme"
  fi

  if [ "$TUNE_MEMORY_MB" -ge 2048 ] &&
    [ "$TUNE_SPEED_MBPS" -ge 900 ] &&
    [ "$TUNE_RTT_MS" -ge 120 ] &&
    [ "$TUNE_CPU_STEAL_PCT" -lt 10 ]; then
    profile="extreme"
  fi

  if [ "$TUNE_EXPECTED_CONNECTIONS" -ge 512 ] && [ "$TUNE_MEMORY_MB" -lt 2048 ]; then
    profile="$(profile_at_most "$profile" stable)"
  fi

  if [ "$TUNE_CPU_QUOTA_MILLI" -gt 0 ] && [ "$TUNE_CPU_QUOTA_MILLI" -lt 750 ]; then
    profile="$(profile_at_most "$profile" stable)"
  fi

  if [ "$TUNE_CPU_STEAL_PCT" -ge 15 ] || [ "$TUNE_LOAD_PCT" -ge 160 ]; then
    profile="$(profile_at_most "$profile" stable)"
  fi

  if [ "$TUNE_MEMORY_MB" -lt 512 ]; then
    profile="compact"
  fi

  printf '%s\n' "$profile"
}

cap_tuning_by_memory() {
  local cap_bytes min_cap_bytes requested_cap

  min_cap_bytes=4194304
  cap_bytes=$((TUNE_MEMORY_MB * 1024 * 1024 / 64))

  if [ "$TUNE_EXPECTED_CONNECTIONS" -ge 512 ]; then
    cap_bytes=$((TUNE_MEMORY_MB * 1024 * 1024 / 96))
  fi

  [ "$cap_bytes" -ge "$min_cap_bytes" ] || cap_bytes="$min_cap_bytes"
  cap_bytes=$((cap_bytes / 4096 * 4096))
  requested_cap="$TUNE_RMEM_MAX"

  if [ "$requested_cap" -gt "$cap_bytes" ]; then
    TUNE_RMEM_MAX="$cap_bytes"
    TUNE_WMEM_MAX="$cap_bytes"
    TUNE_TCP_RMEM="4096 87380 ${cap_bytes}"
    TUNE_TCP_WMEM="4096 65536 ${cap_bytes}"
    TUNE_BUFFER_CAP_BYTES="$cap_bytes"
  else
    TUNE_BUFFER_CAP_BYTES="$requested_cap"
  fi
}

select_network_tuning() {
  local quota_cpu

  TUNE_IFACE="$(detect_default_iface || true)"
  TUNE_SPEED_MBPS="$(detect_iface_speed_mbps "$TUNE_IFACE")"
  TUNE_IFACE_VIRTUAL="$(detect_iface_virtual "$TUNE_IFACE")"
  TUNE_SYSTEM_VIRTUALIZED="$(detect_system_virtualized)"
  TUNE_RTT_MS="$(detect_rtt_ms)"
  TUNE_MEMORY_TOTAL_MB="$(detect_memory_mb)"
  TUNE_CGROUP_MEMORY_MB="$(detect_cgroup_memory_limit_mb)"
  if [ "$TUNE_CGROUP_MEMORY_MB" -gt 0 ] && [ "$TUNE_CGROUP_MEMORY_MB" -lt "$TUNE_MEMORY_TOTAL_MB" ]; then
    TUNE_MEMORY_MB="$TUNE_CGROUP_MEMORY_MB"
  else
    TUNE_MEMORY_MB="$TUNE_MEMORY_TOTAL_MB"
  fi
  TUNE_SWAP_MB="$(detect_swap_mb)"
  TUNE_CPU_TOTAL_COUNT="$(detect_cpu_count)"
  TUNE_CPU_QUOTA_MILLI="$(detect_cpu_quota_milli)"
  TUNE_CPU_COUNT="$TUNE_CPU_TOTAL_COUNT"
  if [ "$TUNE_CPU_QUOTA_MILLI" -gt 0 ]; then
    quota_cpu=$(((TUNE_CPU_QUOTA_MILLI + 999) / 1000))
    [ "$quota_cpu" -ge 1 ] || quota_cpu=1
    if [ "$quota_cpu" -lt "$TUNE_CPU_COUNT" ]; then
      TUNE_CPU_COUNT="$quota_cpu"
    fi
  fi
  TUNE_LOAD_PCT="$(detect_load_pct "$TUNE_CPU_COUNT")"
  TUNE_CPU_STEAL_PCT="$(detect_cpu_steal_pct)"
  TUNE_EXPECTED_CONNECTIONS="$(normalize_expected_connections)"

  case "$NETWORK_TUNING_PROFILE" in
    auto)
      set_tuning_profile_values "$(heuristic_tuning_profile)"
      ;;
    compact | stable | throughput | extreme)
      set_tuning_profile_values "$NETWORK_TUNING_PROFILE"
      ;;
    *)
      fail "unsupported NETWORK_TUNING_PROFILE=$NETWORK_TUNING_PROFILE; use auto, compact, stable, throughput, or extreme"
      ;;
  esac

  cap_tuning_by_memory

  log "network tuning profile=${TUNE_PROFILE} iface=${TUNE_IFACE:-unknown} speed_mbps=${TUNE_SPEED_MBPS:-0} virtual_iface=${TUNE_IFACE_VIRTUAL} system_virtualized=${TUNE_SYSTEM_VIRTUALIZED} rtt_ms=${TUNE_RTT_MS} memory_mb=${TUNE_MEMORY_MB} memory_total_mb=${TUNE_MEMORY_TOTAL_MB} cgroup_memory_mb=${TUNE_CGROUP_MEMORY_MB} swap_mb=${TUNE_SWAP_MB} cpu_count=${TUNE_CPU_COUNT} cpu_total=${TUNE_CPU_TOTAL_COUNT} cpu_quota_milli=${TUNE_CPU_QUOTA_MILLI} load_pct=${TUNE_LOAD_PCT} steal_pct=${TUNE_CPU_STEAL_PCT} expected_connections=${TUNE_EXPECTED_CONNECTIONS} buffer_cap_bytes=${TUNE_BUFFER_CAP_BYTES}"
}

write_tuning_state() {
  mkdir -p "$TUNING_STATE_DIR"
  chmod 0700 "$TUNING_STATE_DIR"

  {
    printf 'TUNE_PROFILE=%q\n' "$TUNE_PROFILE"
    printf 'TUNE_IFACE=%q\n' "${TUNE_IFACE:-}"
    printf 'TUNE_SPEED_MBPS=%q\n' "${TUNE_SPEED_MBPS:-0}"
    printf 'TUNE_IFACE_VIRTUAL=%q\n' "${TUNE_IFACE_VIRTUAL:-0}"
    printf 'TUNE_SYSTEM_VIRTUALIZED=%q\n' "${TUNE_SYSTEM_VIRTUALIZED:-0}"
    printf 'TUNE_RTT_MS=%q\n' "$TUNE_RTT_MS"
    printf 'TUNE_MEMORY_MB=%q\n' "$TUNE_MEMORY_MB"
    printf 'TUNE_MEMORY_TOTAL_MB=%q\n' "$TUNE_MEMORY_TOTAL_MB"
