#!/usr/bin/env bash
# Minimal single-hop VLESS over TCP/TLS for a server reached by an IPv4 address.
# Replaces /etc/sing-box/config.json after saving a timestamped backup.

set -Eeuo pipefail
umask 077

SERVER_IP="${1:-}"
PORT='443'
CONFIG='/etc/sing-box/config.json'
CERT_DIR='/etc/sing-box/certs'
CERT="${CERT_DIR}/vless-ip.crt"
KEY="${CERT_DIR}/vless-ip.key"
OUTPUT='/root/vless-client.txt'

[[ ${EUID} -eq 0 ]] || { echo 'Run as root.' >&2; exit 1; }
[[ "${SERVER_IP}" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}$ ]] || { echo 'Usage: reinstall-minimal-vless-ip.sh SERVER_IPV4' >&2; exit 1; }

if ! command -v sing-box >/dev/null 2>&1; then
  command -v curl >/dev/null 2>&1 || { echo 'curl is required to install sing-box.' >&2; exit 1; }
  INSTALLER="$(mktemp)"
  trap 'rm -f "${INSTALLER}"' EXIT
  curl --fail --location --proto '=https' --tlsv1.2 --silent --show-error \
    https://sing-box.app/install.sh -o "${INSTALLER}"
  sh "${INSTALLER}"
fi
command -v openssl >/dev/null 2>&1 || { echo 'openssl is required.' >&2; exit 1; }

if ! getent group sing-box >/dev/null; then
  groupadd --system sing-box
fi
if ! id -u sing-box >/dev/null 2>&1; then
  useradd --system --no-create-home --gid sing-box --shell /usr/sbin/nologin sing-box
fi
install -d -o root -g sing-box -m 750 /etc/sing-box
if ! systemctl cat sing-box >/dev/null 2>&1; then
  cat >/etc/systemd/system/sing-box.service <<'EOF'
[Unit]
Description=sing-box service
After=network-online.target
Wants=network-online.target

[Service]
User=sing-box
Group=sing-box
AmbientCapabilities=CAP_NET_BIND_SERVICE
CapabilityBoundingSet=CAP_NET_BIND_SERVICE
ExecStart=/usr/local/bin/sing-box -C /etc/sing-box run
Restart=on-failure
RestartSec=5s
LimitNOFILE=1048576

[Install]
WantedBy=multi-user.target
EOF
  systemctl daemon-reload
fi

UUID="$(cat /proc/sys/kernel/random/uuid)"
BACKUP="${CONFIG}.backup.$(date -u +%Y%m%dT%H%M%SZ)"
[[ -f "${CONFIG}" ]] && cp -a "${CONFIG}" "${BACKUP}"

install -d -o root -g sing-box -m 750 "${CERT_DIR}"
openssl req -x509 -newkey rsa:2048 -sha256 -nodes -days 825 \
  -keyout "${KEY}" \
  -out "${CERT}" \
  -subj "/CN=${SERVER_IP}" \
  -addext "subjectAltName=IP:${SERVER_IP}" \
  >/dev/null 2>&1
chown root:sing-box "${CERT}" "${KEY}"
chmod 640 "${CERT}" "${KEY}"

cat >"${CONFIG}" <<EOF
{
  "log": {
    "level": "warn"
  },
  "inbounds": [
    {
      "type": "vless",
      "tag": "vless-tls-ip",
      "listen": "0.0.0.0",
      "listen_port": ${PORT},
      "users": [
        {
          "uuid": "${UUID}"
        }
      ],
      "tls": {
        "enabled": true,
        "certificate_path": "${CERT}",
        "key_path": "${KEY}"
      }
    }
  ],
  "outbounds": [
    {
      "type": "direct",
      "tag": "direct"
    }
  ]
}
EOF
chown root:sing-box "${CONFIG}"
chmod 640 "${CONFIG}"

sing-box check -c "${CONFIG}"
systemctl enable sing-box
systemctl restart sing-box
systemctl is-active --quiet sing-box

if command -v ufw >/dev/null 2>&1 && ufw status | grep -q '^Status: active'; then
  ufw allow "${PORT}/tcp"
fi

URI="vless://${UUID}@${SERVER_IP}:${PORT}?encryption=none&security=tls&type=tcp&allowInsecure=1#minimal-vless-ip"
cat >"${OUTPUT}" <<EOF
${URI}

Server: ${SERVER_IP}
Port: ${PORT}
Protocol: VLESS
Transport: TCP
Security: TLS (self-signed IP certificate)
UUID: ${UUID}
Client setting: allow insecure certificate = true
EOF
chmod 600 "${OUTPUT}"

echo "BACKUP=${BACKUP}"
echo "URI=${URI}"
echo "STATUS=active"
