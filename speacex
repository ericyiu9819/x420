  chmod 0600 "$TUNING_STATE_FILE"
}

configure_baremetal_net_queues() {
  if [ "$BAREMETAL_MODE" != "1" ]; then
    return
  fi

  case "$ENABLE_BAREMETAL_NET_QUEUES" in
    0 | false | off | no)
      return
      ;;
  esac

  if [ "${TUNE_SYSTEM_VIRTUALIZED:-1}" != "0" ] || [ "${TUNE_IFACE_VIRTUAL:-1}" != "0" ]; then
    log "baremetal net queues skipped: virtualized environment or virtual interface"
    return
  fi

  if [ -z "${TUNE_IFACE:-}" ] || [ "${TUNE_IFACE}" = "lo" ] || [ ! -d "/sys/class/net/${TUNE_IFACE}/queues" ]; then
    log "baremetal net queues skipped: no physical queue path"
    return
  fi

  local mask path changed=0
  if ! mask="$(cpu_mask_for_count "${TUNE_CPU_COUNT:-1}")"; then
    log "baremetal net queues skipped: effective cpu count is not in 2..32"
    return
  fi

  for path in "/sys/class/net/${TUNE_IFACE}/queues"/rx-*/rps_cpus; do
    [ -e "$path" ] || continue
    if [ -w "$path" ] && printf '%s\n' "$mask" > "$path" 2>/dev/null; then
      changed=1
    fi
  done

  for path in "/sys/class/net/${TUNE_IFACE}/queues"/tx-*/xps_cpus; do
    [ -e "$path" ] || continue
    if [ -w "$path" ] && printf '%s\n' "$mask" > "$path" 2>/dev/null; then
      changed=1
    fi
  done

  if [ "$changed" -eq 1 ]; then
    log "baremetal net queues applied: iface=${TUNE_IFACE} cpu_mask=${mask}"
  else
    log "baremetal net queues skipped: no writable queue knobs"
  fi
}

configure_network_performance() {
  if [ "$ENABLE_NETWORK_OPTIMIZATION" != "1" ]; then
    return
  fi

  select_network_tuning

  mkdir -p "$(dirname "$NETWORK_SYSCTL_FILE")"
  : > "$NETWORK_SYSCTL_FILE"

  if [ "$ENABLE_BBR" = "1" ]; then
    append_sysctl_if_exists net.core.default_qdisc fq

    if [ -r /proc/sys/net/ipv4/tcp_available_congestion_control ] &&
      grep -qw bbr /proc/sys/net/ipv4/tcp_available_congestion_control; then
      append_sysctl_if_exists net.ipv4.tcp_congestion_control bbr
    else
      log "skip BBR: kernel does not expose bbr"
    fi
  fi

  append_sysctl_if_exists net.ipv4.tcp_fastopen 3
  append_sysctl_if_exists net.ipv4.tcp_mtu_probing 1
  append_sysctl_if_exists net.ipv4.tcp_slow_start_after_idle 0
  append_sysctl_if_exists net.ipv4.tcp_keepalive_time 600
  append_sysctl_if_exists net.ipv4.tcp_keepalive_intvl 30
  append_sysctl_if_exists net.ipv4.tcp_keepalive_probes 5
  append_sysctl_if_exists net.ipv4.tcp_fin_timeout 15
  append_sysctl_if_exists net.ipv4.tcp_tw_reuse 1
  append_sysctl_if_exists net.ipv4.tcp_max_tw_buckets 2000000
  append_sysctl_if_exists net.ipv4.tcp_syncookies 1
  append_sysctl_if_exists net.ipv4.tcp_no_metrics_save 1
  append_sysctl_if_exists net.core.somaxconn 65535
  append_sysctl_if_exists net.ipv4.tcp_max_syn_backlog 65535
  append_sysctl_if_exists net.ipv4.ip_local_port_range "10000 65000"

  append_sysctl_if_exists net.core.netdev_max_backlog "$TUNE_NETDEV_BACKLOG"
  append_sysctl_if_exists net.core.rmem_default "$TUNE_RMEM_DEFAULT"
  append_sysctl_if_exists net.core.wmem_default "$TUNE_WMEM_DEFAULT"
  append_sysctl_if_exists net.core.rmem_max "$TUNE_RMEM_MAX"
  append_sysctl_if_exists net.core.wmem_max "$TUNE_WMEM_MAX"
  append_sysctl_if_exists net.ipv4.tcp_rmem "$TUNE_TCP_RMEM"
  append_sysctl_if_exists net.ipv4.tcp_wmem "$TUNE_TCP_WMEM"
  append_sysctl_if_exists net.ipv4.tcp_notsent_lowat "$TUNE_TCP_NOTSENT_LOWAT"

  if [ -s "$NETWORK_SYSCTL_FILE" ]; then
    sysctl -p "$NETWORK_SYSCTL_FILE" >/dev/null || true
    write_tuning_state
    configure_baremetal_net_queues
    log "network performance sysctl written: $NETWORK_SYSCTL_FILE"
  else
    rm -f "$NETWORK_SYSCTL_FILE"
    log "network performance sysctl skipped: no supported keys"
  fi
}

configure_systemd_limits() {
  if [ "$ENABLE_SYSTEMD_LIMITS" != "1" ]; then
    return
  fi

  local dropin_dir="/etc/systemd/system/${XRAY_SERVICE}.service.d"
  local gomaxprocs="${XRAY_GOMAXPROCS:-${TUNE_CPU_COUNT:-}}"
  mkdir -p "$dropin_dir"

  {
    cat <<'EOF'
[Service]
LimitNOFILE=1048576
LimitNPROC=262144
TasksMax=infinity
EOF

    if [ "$BAREMETAL_MODE" = "1" ]; then
      cat <<EOF
Nice=${BAREMETAL_XRAY_NICE}
IOSchedulingClass=${BAREMETAL_XRAY_IO_CLASS}
IOSchedulingPriority=${BAREMETAL_XRAY_IO_PRIORITY}
