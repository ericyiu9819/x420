server_direct_rule() {
  case "$SERVER_ADDRESS" in
    *:*)
      printf 'IP-CIDR6,%s/128,DIRECT,no-resolve\n' "$SERVER_ADDRESS"
      ;;
    *)
      if printf '%s\n' "$SERVER_ADDRESS" | awk -F. 'NF == 4 {for (i=1; i<=4; i++) if ($i !~ /^[0-9]+$/ || $i < 0 || $i > 255) exit 1; exit 0} {exit 1}'; then
        printf 'IP-CIDR,%s/32,DIRECT,no-resolve\n' "$SERVER_ADDRESS"
      else
        printf 'DOMAIN,%s,DIRECT\n' "$SERVER_ADDRESS"
      fi
      ;;
  esac
}

