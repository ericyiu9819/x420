#!/usr/bin/env bash
set -euo pipefail

XRAY_BIN="/usr/local/bin/xray"
XRAY_CONFIG="/usr/local/etc/xray/config.json"
STATE_FILE="/etc/fast-diagnostic.env"
XRAY_SYSTEMD_OVERRIDE_DIR="/etc/systemd/system/xray.service.d"
XRAY_SYSTEMD_OVERRIDE="$XRAY_SYSTEMD_OVERRIDE_DIR/10-fast-diagnostic.conf"

ACTION="install"
PORT="443"
UUID_VALUE=""
PRIVATE_KEY=""
PUBLIC_KEY=""
SHORT_ID=""
SNI="www.cloudflare.com"
DEST="www.cloudflare.com:443"
SERVER_ADDR=""
NAME="fast-diagnostic"
SNIFFING_ENABLED="false"
SKIP_APT="0"
SELF_TEST_URL="https://www.gstatic.com/generate_204"
SPEED_TEST_URL="https://speed.cloudflare.com/__down?bytes=1048576"
TEST_URL=""
APPLY_BEST="0"
SNI_CANDIDATES="www.cloudflare.com,www.apple.com,www.amazon.com,www.yahoo.com,www.bing.com"
RETUNE_SNI=""
RETUNE_DEST=""

usage() {
  cat <<'EOF'
fast-diagnostic: single-VPS VLESS + REALITY + TCP/RAW + Vision installer
and data-driven network diagnostic toolkit.

Core idea:
  1. Keep the transport minimal: VLESS + REALITY + TCP/RAW + Vision.
  2. Tune only the single VPS system limits that are actually controllable.
  3. Diagnose before changing: direct path, proxy path, REALITY SNI, and link health.

Usage:
  sudo bash fast-diagnostic.sh install [options]
  sudo bash fast-diagnostic.sh show [--server IP_OR_DOMAIN]
  sudo bash fast-diagnostic.sh status
  sudo bash fast-diagnostic.sh self-test [--server IP_OR_DOMAIN]
  sudo bash fast-diagnostic.sh direct-test [--url URL]
  sudo bash fast-diagnostic.sh proxy-test [--server IP_OR_DOMAIN] [--url URL]
  sudo bash fast-diagnostic.sh speed-test [--server IP_OR_DOMAIN]
  sudo bash fast-diagnostic.sh diagnose [--server IP_OR_DOMAIN]
  sudo bash fast-diagnostic.sh benchmark-sni [--server IP_OR_DOMAIN] [--apply-best]
  sudo bash fast-diagnostic.sh retune-sni --sni DOMAIN [--dest DOMAIN:443] [--server IP_OR_DOMAIN]
  sudo bash fast-diagnostic.sh uninstall

Common options:
  --server IP_OR_DOMAIN
  --port 443
  --name NODE_NAME
  --skip-apt
  --enable-sniffing

Install identity options:
  --id UUID
  --private-key REALITY_PRIVATE_KEY
  --public-key REALITY_PUBLIC_KEY
  --short-id HEX_SHORT_ID
  --sni www.cloudflare.com
  --dest www.cloudflare.com:443

Benchmark options:
  --url URL
  --self-test-url https://www.gstatic.com/generate_204
  --speed-test-url https://speed.cloudflare.com/__down?bytes=1048576
  --sni-candidates "www.cloudflare.com,www.apple.com,www.amazon.com"
  --apply-best

Client recommendations:
  mux: off
  fingerprint: chrome
  flow: xtls-rprx-vision
  transport: tcp first; raw only for newer Xray clients
EOF
}

die() {
  echo "ERROR: $*" >&2
  exit 1
}

need_root() {
  [[ "$(id -u)" == "0" ]] || die "run as root or with sudo"
}

have_cmd() {
  command -v "$1" >/dev/null 2>&1
}

install_base_tools() {
  [[ "$SKIP_APT" == "1" ]] && return

  if have_cmd apt-get; then
    if have_cmd timeout; then
      timeout 90 apt-get update -y || true
    else
      apt-get update -y || true
    fi
    DEBIAN_FRONTEND=noninteractive apt-get install -y curl ca-certificates openssl procps iproute2
  elif have_cmd dnf; then
    dnf install -y curl ca-certificates openssl procps-ng iproute
  elif have_cmd yum; then
    yum install -y curl ca-certificates openssl procps-ng iproute
  else
    die "unsupported package manager; install curl, ca-certificates, openssl manually"
  fi
}

install_xray() {
  if [[ -x "$XRAY_BIN" ]]; then
    return
  fi
  bash -c "$(curl -L https://github.com/XTLS/Xray-install/raw/main/install-release.sh)" @ install
}

enable_tcp_tuning() {
  cat >/etc/sysctl.d/99-fast-diagnostic.conf <<'EOF'
net.core.default_qdisc=fq
net.core.somaxconn=65535
net.core.netdev_max_backlog=250000
net.ipv4.tcp_congestion_control=bbr
net.ipv4.tcp_fastopen=3
net.ipv4.tcp_keepalive_time=60
net.ipv4.tcp_keepalive_intvl=15
net.ipv4.tcp_keepalive_probes=4
net.ipv4.tcp_max_syn_backlog=65535
net.ipv4.tcp_fin_timeout=15
net.ipv4.tcp_tw_reuse=1
net.ipv4.tcp_mtu_probing=1
net.ipv4.tcp_slow_start_after_idle=0
net.ipv4.ip_local_port_range=10000 65000
EOF
  sysctl -p /etc/sysctl.d/99-fast-diagnostic.conf >/dev/null || true
}

enable_systemd_tuning() {
  mkdir -p "$XRAY_SYSTEMD_OVERRIDE_DIR"
  cat >"$XRAY_SYSTEMD_OVERRIDE" <<'EOF'
[Service]
LimitNOFILE=1048576
TasksMax=infinity
EOF
  systemctl daemon-reload
}

gen_uuid() {
  if [[ -n "$UUID_VALUE" ]]; then
    echo "$UUID_VALUE"
  else
    "$XRAY_BIN" uuid
  fi
}

gen_short_id() {
  if [[ -n "$SHORT_ID" ]]; then
    echo "$SHORT_ID"
  else
    openssl rand -hex 8
  fi
}

gen_reality_keys() {
  if [[ -n "$PRIVATE_KEY" && -n "$PUBLIC_KEY" ]]; then
    return
  fi
  local pair
  pair="$("$XRAY_BIN" x25519)"
  PRIVATE_KEY="$(printf '%s\n' "$pair" | awk -F': ' '/PrivateKey:|Private key:/ {print $2; exit}')"
  PUBLIC_KEY="$(printf '%s\n' "$pair" | awk -F': ' '/Password \(PublicKey\):|Public key:/ {print $2; exit}')"
  [[ -n "$PRIVATE_KEY" && -n "$PUBLIC_KEY" ]] || die "failed to generate REALITY keys"
}

json_escape() {
  printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

urlencode() {
  local raw="$1"
  local length="${#raw}"
  local i char out=""
  for ((i = 0; i < length; i++)); do
    char="${raw:i:1}"
    case "$char" in
      [a-zA-Z0-9.~_-]) out+="$char" ;;
      *) printf -v out '%s%%%02X' "$out" "'$char" ;;
    esac
  done
  printf '%s' "$out"
}

detect_public_ip() {
  if [[ -n "$SERVER_ADDR" ]]; then
    echo "$SERVER_ADDR"
    return
  fi
  local ip=""
  ip="$(curl -4fsS --max-time 6 https://api.ipify.org || true)"
  if [[ -z "$ip" ]]; then
    ip="$(curl -4fsS --max-time 6 https://ifconfig.me || true)"
  fi
  echo "$ip"
}

load_state() {
  [[ -f "$STATE_FILE" ]] || die "state file not found; run install first"
  # shellcheck disable=SC1090
  source "$STATE_FILE"
}

write_config() {
  local id private_key public_key short_id sni dest

  id="${UUID_VALUE:-$(gen_uuid)}"
  gen_reality_keys
  private_key="$PRIVATE_KEY"
  public_key="$PUBLIC_KEY"
  short_id="${SHORT_ID:-$(gen_short_id)}"
  sni="$(json_escape "$SNI")"
  dest="$(json_escape "$DEST")"

  mkdir -p "$(dirname "$XRAY_CONFIG")"
  cat >"$XRAY_CONFIG" <<EOF
{
  "log": {
    "loglevel": "warning"
  },
  "inbounds": [
    {
      "tag": "vless-reality-vision",
      "listen": "0.0.0.0",
      "port": $PORT,
      "protocol": "vless",
      "settings": {
        "clients": [
          {
            "id": "$id",
            "flow": "xtls-rprx-vision",
            "email": "fast-diagnostic"
          }
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "raw",
        "security": "reality",
        "realitySettings": {
          "show": false,
          "dest": "$dest",
          "xver": 0,
          "serverNames": ["$sni"],
          "privateKey": "$private_key",
          "shortIds": ["$short_id"]
        }
      },
      "sniffing": {
        "enabled": $SNIFFING_ENABLED
      }
    }
  ],
  "outbounds": [
    {
      "tag": "direct",
      "protocol": "freedom"
    },
    {
      "tag": "block",
      "protocol": "blackhole"
    }
  ],
  "routing": {
    "domainStrategy": "IPIfNonMatch",
    "rules": [
      {
        "type": "field",
        "ip": ["geoip:private"],
        "outboundTag": "block"
      }
    ]
  }
}
EOF

  UUID_VALUE="$id"
  PRIVATE_KEY="$private_key"
  PUBLIC_KEY="$public_key"
  SHORT_ID="$short_id"

  cat >"$STATE_FILE" <<EOF
PORT='$PORT'
UUID_VALUE='$UUID_VALUE'
PRIVATE_KEY='$PRIVATE_KEY'
PUBLIC_KEY='$PUBLIC_KEY'
SHORT_ID='$SHORT_ID'
SNI='$SNI'
DEST='$DEST'
NAME='$NAME'
SNIFFING_ENABLED='$SNIFFING_ENABLED'
SELF_TEST_URL='$SELF_TEST_URL'
SPEED_TEST_URL='$SPEED_TEST_URL'
EOF
  chmod 600 "$STATE_FILE"
}

test_and_restart_xray() {
  "$XRAY_BIN" run -test -c "$XRAY_CONFIG"
  systemctl enable --now xray >/dev/null
  systemctl restart xray
}

make_client_config() {
  local config_path="$1"
  local socks_port="$2"
  local server="$3"

  cat >"$config_path" <<EOF
{
  "log": {
    "loglevel": "warning"
  },
  "inbounds": [
    {
      "tag": "socks",
      "listen": "127.0.0.1",
      "port": $socks_port,
      "protocol": "socks",
      "settings": {
        "udp": true
      }
    }
  ],
  "outbounds": [
    {
      "tag": "proxy",
      "protocol": "vless",
      "settings": {
        "vnext": [
          {
            "address": "$server",
            "port": $PORT,
            "users": [
              {
                "id": "$UUID_VALUE",
                "encryption": "none",
                "flow": "xtls-rprx-vision"
              }
            ]
          }
        ]
      },
      "streamSettings": {
        "network": "raw",
        "security": "reality",
        "realitySettings": {
          "fingerprint": "chrome",
          "serverName": "$SNI",
          "publicKey": "$PUBLIC_KEY",
          "shortId": "$SHORT_ID",
          "spiderX": "/"
        }
      }
    }
  ]
}
EOF
}

run_proxy_curl() {
  local url="$1"
  local metrics_file="$2"
  local output_file="$3"
  local max_time="${4:-15}"

  load_state
  local server socks_port test_config test_log client_pid status
  server="$(detect_public_ip)"
  [[ -n "$server" ]] || die "cannot determine server address; rerun with --server IP_OR_DOMAIN"

  socks_port="$((19080 + RANDOM % 1000))"
  test_config="$(mktemp /tmp/fast-proxy.XXXXXX.json)"
  test_log="$(mktemp /tmp/fast-proxy.XXXXXX.log)"

  make_client_config "$test_config" "$socks_port" "$server"
  "$XRAY_BIN" run -test -c "$test_config" >/dev/null
  "$XRAY_BIN" run -c "$test_config" >"$test_log" 2>&1 &
  client_pid="$!"
  sleep 3

  status=0
  curl -sS -L --max-time "$max_time" --socks5-hostname "127.0.0.1:$socks_port" \
    "$url" -o "$output_file" \
    -w 'http_code=%{http_code}\nsize_download=%{size_download}\nspeed_download_bytes_per_sec=%{speed_download}\ntime_namelookup=%{time_namelookup}\ntime_connect=%{time_connect}\ntime_appconnect=%{time_appconnect}\ntime_starttransfer=%{time_starttransfer}\ntime_total=%{time_total}\n' \
    >"$metrics_file" || status="$?"

  kill "$client_pid" >/dev/null 2>&1 || true
  wait "$client_pid" >/dev/null 2>&1 || true

  if [[ "$status" != "0" ]]; then
    echo "proxy curl failed with exit code $status" >>"$metrics_file"
    echo "client_log_tail<<EOF" >>"$metrics_file"
    tail -80 "$test_log" >>"$metrics_file" || true
    echo "EOF" >>"$metrics_file"
  fi

  rm -f "$test_config" "$test_log"
  return "$status"
}

direct_test() {
  local url="${TEST_URL:-$SELF_TEST_URL}"
  local metrics_file output_file status
  metrics_file="$(mktemp /tmp/fast-direct.XXXXXX.metrics)"
  output_file="$(mktemp /tmp/fast-direct.XXXXXX.out)"

  status=0
  curl -sS -L --max-time 15 "$url" -o "$output_file" \
    -w 'http_code=%{http_code}\nsize_download=%{size_download}\nspeed_download_bytes_per_sec=%{speed_download}\ntime_namelookup=%{time_namelookup}\ntime_connect=%{time_connect}\ntime_appconnect=%{time_appconnect}\ntime_starttransfer=%{time_starttransfer}\ntime_total=%{time_total}\n' \
    >"$metrics_file" || status="$?"

  echo "direct_url=$url"
  cat "$metrics_file"
  rm -f "$metrics_file" "$output_file"
  return "$status"
}

proxy_test() {
  local url="${TEST_URL:-$SELF_TEST_URL}"
  local metrics_file output_file status
  metrics_file="$(mktemp /tmp/fast-proxy-test.XXXXXX.metrics)"
  output_file="$(mktemp /tmp/fast-proxy-test.XXXXXX.out)"

  status=0
  run_proxy_curl "$url" "$metrics_file" "$output_file" 18 || status="$?"

  echo "proxy_url=$url"
  cat "$metrics_file"
  rm -f "$metrics_file" "$output_file"
  return "$status"
}

self_test() {
  TEST_URL="$SELF_TEST_URL"
  proxy_test
}

speed_test() {
  TEST_URL="$SPEED_TEST_URL"
  proxy_test
}

metric_value() {
  local key="$1"
  local file="$2"
  awk -F= -v k="$key" '$1 == k {print $2; exit}' "$file"
}

benchmark_sni() {
  load_state
  need_root

  local original_sni original_dest best_sni best_time best_status candidate metrics_file output_file status total code
  original_sni="$SNI"
  original_dest="$DEST"
  best_sni=""
  best_time="999999"
  best_status="1"

  echo "benchmark_url=$SELF_TEST_URL"
  echo "original_sni=$original_sni"
  echo
  printf '%-28s %-10s %-12s %-12s\n' "sni" "http_code" "total_sec" "result"

  IFS=',' read -r -a candidates <<<"$SNI_CANDIDATES"
  for candidate in "${candidates[@]}"; do
    candidate="$(printf '%s' "$candidate" | xargs)"
    [[ -z "$candidate" ]] && continue

    SNI="$candidate"
    DEST="$candidate:443"
    write_config
    test_and_restart_xray >/dev/null

    metrics_file="$(mktemp /tmp/fast-sni.XXXXXX.metrics)"
    output_file="$(mktemp /tmp/fast-sni.XXXXXX.out)"
    status=0
    run_proxy_curl "$SELF_TEST_URL" "$metrics_file" "$output_file" 18 || status="$?"

    code="$(metric_value http_code "$metrics_file")"
    total="$(metric_value time_total "$metrics_file")"
    [[ -z "$code" ]] && code="000"
    [[ -z "$total" ]] && total="999999"

    if [[ "$status" == "0" && "$code" =~ ^2|3 ]]; then
      printf '%-28s %-10s %-12s %-12s\n' "$candidate" "$code" "$total" "ok"
      if awk "BEGIN {exit !($total < $best_time)}"; then
        best_time="$total"
        best_sni="$candidate"
        best_status="0"
      fi
    else
      printf '%-28s %-10s %-12s %-12s\n' "$candidate" "$code" "$total" "fail"
    fi

    rm -f "$metrics_file" "$output_file"
  done

  if [[ "$best_status" == "0" ]]; then
    echo
    echo "best_sni=$best_sni"
    echo "best_time_total=$best_time"
  else
    echo
    echo "no working SNI candidate found; restoring original"
  fi

  if [[ "$APPLY_BEST" == "1" && "$best_status" == "0" ]]; then
    SNI="$best_sni"
    DEST="$best_sni:443"
    echo "applying_best_sni=$SNI"
  else
    SNI="$original_sni"
    DEST="$original_dest"
    echo "restoring_sni=$SNI"
  fi

  write_config
  test_and_restart_xray >/dev/null
}

retune_sni() {
  local requested_sni requested_dest
  requested_sni="$RETUNE_SNI"
  requested_dest="$RETUNE_DEST"
  [[ -n "$requested_sni" ]] || die "--sni DOMAIN is required"

  load_state
  SNI="$requested_sni"
  DEST="${requested_dest:-$requested_sni:443}"
  write_config
  test_and_restart_xray
  self_test
}

diagnose() {
  load_state
  echo "== status =="
  show_status
  echo

  echo "== direct test: $SELF_TEST_URL =="
  direct_test || true
  echo

  echo "== proxy test: $SELF_TEST_URL =="
  self_test || true
  echo

  echo "== proxy speed test: $SPEED_TEST_URL =="
  speed_test || true
  echo

  cat <<'EOF'
Interpretation:
  direct slow + proxy slow  => VPS egress or upstream route is the bottleneck.
  direct fast + proxy slow  => REALITY target, client settings, or proxy path needs tuning.
  proxy handshake failures  => run benchmark-sni, then retune-sni or benchmark-sni --apply-best.
  all tests slow            => script parameters cannot fix the physical route; change VPS or add relay.
EOF
}

show_links() {
  load_state
  local server label encoded_name encoded_sni encoded_spx tcp_link raw_link
  server="$(detect_public_ip)"
  [[ -n "$server" ]] || server="SERVER_IP_OR_DOMAIN"
  label="${NAME}-${server}"
  encoded_name="$(urlencode "$label")"
  encoded_sni="$(urlencode "$SNI")"
  encoded_spx="$(urlencode "/")"

  tcp_link="vless://${UUID_VALUE}@${server}:${PORT}?encryption=none&security=reality&sni=${encoded_sni}&fp=chrome&pbk=${PUBLIC_KEY}&sid=${SHORT_ID}&type=tcp&flow=xtls-rprx-vision&spx=${encoded_spx}#${encoded_name}"
  raw_link="vless://${UUID_VALUE}@${server}:${PORT}?encryption=none&security=reality&sni=${encoded_sni}&fp=chrome&pbk=${PUBLIC_KEY}&sid=${SHORT_ID}&type=raw&flow=xtls-rprx-vision&spx=${encoded_spx}#${encoded_name}-raw"

  cat <<EOF
VLESS + REALITY + TCP/RAW + Vision is ready.

Server:
  address:   $server
  port:      $PORT
  uuid:      $UUID_VALUE
  publicKey: $PUBLIC_KEY
  shortId:   $SHORT_ID
  sni:       $SNI
  dest:      $DEST
  flow:      xtls-rprx-vision
  sniffing:  $SNIFFING_ENABLED

Import link for most clients:
$tcp_link

Import link for newer Xray clients:
$raw_link

Client recommendations:
  mux: off
  fingerprint: chrome
  flow: xtls-rprx-vision
  transport: tcp first, raw only for newer Xray clients
EOF
}

show_status() {
  systemctl is-active xray || true
  ss -lntp | grep -E ":${PORT}[[:space:]]" || true
  sysctl net.ipv4.tcp_congestion_control net.core.default_qdisc || true
  sysctl net.core.somaxconn net.ipv4.tcp_max_syn_backlog net.ipv4.ip_local_port_range net.ipv4.tcp_tw_reuse net.ipv4.tcp_mtu_probing || true
  systemctl show xray -p LimitNOFILE -p TasksMax --value 2>/dev/null || true
  if [[ -f "$STATE_FILE" ]]; then
    load_state
    echo "sni = $SNI"
    echo "dest = $DEST"
    echo "sniffing = ${SNIFFING_ENABLED:-unknown}"
  fi
}

uninstall() {
  need_root
  systemctl disable --now xray >/dev/null 2>&1 || true
  rm -f "$XRAY_CONFIG" "$STATE_FILE" /etc/sysctl.d/99-fast-diagnostic.conf "$XRAY_SYSTEMD_OVERRIDE"
  systemctl daemon-reload >/dev/null 2>&1 || true
  echo "removed fast-diagnostic config and state; Xray binary/package was left installed"
}

install_all() {
  need_root
  install_base_tools
  install_xray
  enable_tcp_tuning
  enable_systemd_tuning
  write_config
  test_and_restart_xray
  self_test
  show_links
}

parse_args() {
  if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    usage
    exit 0
  fi
  if [[ $# -gt 0 ]]; then
    ACTION="$1"
    shift
  fi
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --server) SERVER_ADDR="$2"; shift 2 ;;
      --port) PORT="$2"; shift 2 ;;
      --name) NAME="$2"; shift 2 ;;
      --id|--uuid) UUID_VALUE="$2"; shift 2 ;;
      --private-key) PRIVATE_KEY="$2"; shift 2 ;;
      --public-key) PUBLIC_KEY="$2"; shift 2 ;;
      --short-id) SHORT_ID="$2"; shift 2 ;;
      --sni) SNI="$2"; DEST="$2:443"; RETUNE_SNI="$2"; shift 2 ;;
      --dest) DEST="$2"; RETUNE_DEST="$2"; shift 2 ;;
      --url) TEST_URL="$2"; shift 2 ;;
      --self-test-url) SELF_TEST_URL="$2"; shift 2 ;;
      --speed-test-url) SPEED_TEST_URL="$2"; shift 2 ;;
      --sni-candidates) SNI_CANDIDATES="$2"; shift 2 ;;
      --apply-best) APPLY_BEST="1"; shift ;;
      --enable-sniffing) SNIFFING_ENABLED="true"; shift ;;
      --skip-apt) SKIP_APT="1"; shift ;;
      -h|--help) usage; exit 0 ;;
      *) die "unknown argument: $1" ;;
    esac
  done
}

main() {
  parse_args "$@"
  case "$ACTION" in
    install) install_all ;;
    show) show_links ;;
    status) show_status ;;
    self-test) need_root; self_test ;;
    direct-test) direct_test ;;
    proxy-test) need_root; proxy_test ;;
    speed-test) need_root; speed_test ;;
    diagnose) need_root; diagnose ;;
    benchmark-sni) benchmark_sni ;;
    retune-sni) retune_sni ;;
    uninstall) uninstall ;;
    *)
      usage
      die "unknown action: $ACTION"
      ;;
  esac
}

main "$@"
