#!/usr/bin/env bash
set -Eeuo pipefail

PROGRAM_NAME="$(basename "$0")"
VERSION="1.0.0-integrated"

# This file is an integration wrapper. It preserves the original two scripts as
# compressed payloads and executes them without rewriting their internal logic or defaults.
INSTALLER_SHA256="026a9082ff24007ecf64b9e3b06dd671ce2c5c204cb3b780dbd2f1eff39e2b0a"
SPEACEX_SHA256="68ee41c02a5dc2e494eb1616b6e8f2d12d67971c6ec92452fdcff6d81014f293"

usage() {
  cat <<USAGE
${PROGRAM_NAME} ${VERSION}

Usage:
  sudo ./${PROGRAM_NAME} [install-vless-reality options] [--speacex -- speaceX apply options]

What it does:
  1) Extract and run the original install-vless-reality.sh with your installer options.
  2) Extract and run the original speaceX as: speaceX apply <optional speaceX apply options>.

What it does not change:
  - It does not modify the original VLESS installer's protocol logic or defaults.
  - It does not modify the original speaceX network tuning logic or defaults.
  - It does not change UUID/key/SNI/port rules beyond the options you pass to the installer.
  - It does not automatically remove old network-scheduler-optimize.sh persistence files.

Default network tuning:
  - speaceX tcp_notsent_lowat default is now 65536.

Examples:
  sudo ./${PROGRAM_NAME} --clean --force --sni www.spacex.com --address 203.0.113.10
  sudo ./${PROGRAM_NAME} --clean --force --sni www.bing.com --address 203.0.113.10
  sudo ./${PROGRAM_NAME} --clean --force --sni www.bing.com --address 203.0.113.10 --speacex -- --notsent-lowat 65536
USAGE
}

fail() {
  echo "ERROR: $*" >&2
  exit 1
}

info() {
  echo "[+] $*"
}

require_root() {
  if [[ "${EUID}" -ne 0 ]]; then
    fail "This integrated installer must be run as root. Use sudo."
  fi
}

sha256_file() {
  local file="$1"
  if command -v sha256sum >/dev/null 2>&1; then
    sha256sum "${file}" | awk '{print $1}'
    return 0
  fi
  if command -v shasum >/dev/null 2>&1; then
    shasum -a 256 "${file}" | awk '{print $1}'
    return 0
  fi
  fail "sha256sum or shasum is required."
}

verify_sha256() {
  local label="$1"
  local file="$2"
  local expected="$3"
  local actual
  actual="$(sha256_file "${file}")"
  if [[ "${actual}" != "${expected}" ]]; then
    fail "${label} checksum mismatch after extraction."
  fi
}

decode_base64_gzip_to() {
  local dest="$1"
  if printf 'H4sIAAAAAAAC/+PiAgD0uR2YAgAAAA==' | base64 -d 2>/dev/null | gzip -t >/dev/null 2>&1; then
    base64 -d | gzip -dc > "${dest}"
  else
    base64 -D | gzip -dc > "${dest}"
  fi
}

