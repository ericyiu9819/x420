parse_args() {
  INSTALLER_ARGS=()
  SPEACEX_APPLY_ARGS=()

  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      -h|--help|help)
        usage
        exit 0
        ;;
      version|--version)
        echo "${PROGRAM_NAME} ${VERSION}"
        exit 0
        ;;
      --speacex)
        shift
        if [[ "${1:-}" == "--" ]]; then
          shift
        fi
        SPEACEX_APPLY_ARGS=("$@")
        break
        ;;
      *)
        INSTALLER_ARGS+=("$1")
        shift
        ;;
    esac
  done
}

main() {
  parse_args "$@"
  require_root

  local tmp_dir
  local installer_script
  local speacex_script

  tmp_dir="$(mktemp -d)"
  trap 'rm -rf "${tmp_dir}"' EXIT

  installer_script="${tmp_dir}/install-vless-reality.sh"
  speacex_script="${tmp_dir}/speaceX"

  info "Extracting original install-vless-reality.sh"
  write_installer_payload "${installer_script}"
  chmod 0755 "${installer_script}"
  verify_sha256 "install-vless-reality.sh" "${installer_script}" "${INSTALLER_SHA256}"

  info "Extracting original speaceX"
  write_speacex_payload "${speacex_script}"
  chmod 0755 "${speacex_script}"
  verify_sha256 "speaceX" "${speacex_script}" "${SPEACEX_SHA256}"

  info "Running original VLESS REALITY installer"
  bash "${installer_script}" "${INSTALLER_ARGS[@]}"

  info "Running original speaceX network scheduler"
  bash "${speacex_script}" apply "${SPEACEX_APPLY_ARGS[@]}"

  info "SpeaceX integrated install finished"
}

main "$@"
