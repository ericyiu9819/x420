From 1b37137caaa03fbefa2865492351328bb8b3c77b Mon Sep 17 00:00:00 2001
From: BBRQ Prototype <bbrq@localhost>
Date: Fri, 24 Jul 2026 11:02:07 +0800
Subject: [PATCH] net: add experimental BBRQ congestion control

Keep the BBR delivery-rate and min-RTT model.

Add a short queue/loss guard.

It exits STARTUP on persistent RTT inflation and caps PROBE_BW gains after material loss.

Register BBRQ independently.

This keeps BBR and CUBIC available for A/B tests and rollback.

Signed-off-by: BBRQ Prototype <bbrq@localhost>
---
 net/ipv4/Kconfig    |   16 +
 net/ipv4/Makefile   |    1 +
 net/ipv4/tcp_bbrq.c | 1279 +++++++++++++++++++++++++++++++++++++++++++
 3 files changed, 1296 insertions(+)
 create mode 100644 net/ipv4/tcp_bbrq.c

diff --git a/net/ipv4/Kconfig b/net/ipv4/Kconfig
index 06cb9c9..edb11df 100644
--- a/net/ipv4/Kconfig
+++ b/net/ipv4/Kconfig
@@ -679,6 +679,22 @@ config TCP_CONG_BBR
 	  AQM schemes that do not provide a delay signal. It requires the fq
 	  ("Fair Queue") pacing packet scheduler.
 
+config TCP_CONG_BBRQ
+	tristate "BBRQ queue-aware TCP"
+	default n
+	help
+
+	  BBRQ is an experimental queue-aware derivative of BBR. It retains
+	  BBR's bottleneck bandwidth and minimum RTT model while using persistent
+	  RTT inflation and material packet loss as guard signals. The guard ends
+	  STARTUP early and temporarily reduces steady-state pacing and cwnd
+	  gains to limit bufferbloat and probe-induced loss.
+
+	  Build this as a module so BBRQ can be compared with BBR and CUBIC and
+	  unloaded without replacing the production congestion controller.
+	  BBRQ requires the fq ("Fair Queue") pacing packet scheduler. It must be
+	  validated under representative traffic before production use.
+
 choice
 	prompt "Default TCP congestion control"
 	default DEFAULT_CUBIC
diff --git a/net/ipv4/Makefile b/net/ipv4/Makefile
index ec36d2e..48dbc65 100644
--- a/net/ipv4/Makefile
+++ b/net/ipv4/Makefile
@@ -45,6 +45,7 @@ obj-$(CONFIG_INET_TCP_DIAG) += tcp_diag.o
 obj-$(CONFIG_INET_UDP_DIAG) += udp_diag.o
 obj-$(CONFIG_INET_RAW_DIAG) += raw_diag.o
 obj-$(CONFIG_TCP_CONG_BBR) += tcp_bbr.o
+obj-$(CONFIG_TCP_CONG_BBRQ) += tcp_bbrq.o
 obj-$(CONFIG_TCP_CONG_BIC) += tcp_bic.o
 obj-$(CONFIG_TCP_CONG_CDG) += tcp_cdg.o
 obj-$(CONFIG_TCP_CONG_CUBIC) += tcp_cubic.o
diff --git a/net/ipv4/tcp_bbrq.c b/net/ipv4/tcp_bbrq.c
new file mode 100644
index 0000000..23a6b8a
--- /dev/null
+++ b/net/ipv4/tcp_bbrq.c
@@ -0,0 +1,1279 @@
+// SPDX-License-Identifier: GPL-2.0 OR BSD-3-Clause
+/* BBRQ: queue-aware Bottleneck Bandwidth and RTT congestion control
+ *
+ * BBRQ congestion control computes the sending rate based on the delivery
+ * rate (throughput) estimated from ACKs. In a nutshell:
+ *
+ *   On each ACK, update our model of the network path:
+ *      bottleneck_bandwidth = windowed_max(delivered / elapsed, 10 round trips)
+ *      min_rtt = windowed_min(rtt, 10 seconds)
+ *   pacing_rate = pacing_gain * bottleneck_bandwidth
+ *   cwnd = max(cwnd_gain * bottleneck_bandwidth * min_rtt, 4)
+ *
+ * BBRQ retains BBR's delivery-rate and propagation-delay model and adds a
+ * conservative queue/loss guard. Persistent RTT inflation or a significant
+ * loss sample ends STARTUP early and temporarily reduces steady-state gains.
+ * This is intended to reduce bufferbloat and probe-induced loss while keeping
+ * the model-based throughput properties of BBR.
+ *
+ * Here is a state transition diagram for BBRQ:
+ *
+ *             |
+ *             V
+ *    +---> STARTUP  ----+
+ *    |        |         |
+ *    |        V         |
+ *    |      DRAIN   ----+
+ *    |        |         |
+ *    |        V         |
+ *    +---> PROBE_BW ----+
+ *    |      ^    |      |
+ *    |      |    |      |
+ *    |      +----+      |
+ *    |                  |
+ *    +---- PROBE_RTT <--+
+ *
+ * A BBRQ flow starts in STARTUP, and ramps up its sending rate quickly.
+ * When it estimates the pipe is full, it enters DRAIN to drain the queue.
+ * In steady state a BBRQ flow only uses PROBE_BW and PROBE_RTT.
+ * A long-lived BBRQ flow spends the vast majority of its time remaining
+ * (repeatedly) in PROBE_BW, fully probing and utilizing the pipe's bandwidth
+ * in a fair manner, with a small, bounded queue. *If* a flow has been
+ * continuously sending for the entire min_rtt window, and hasn't seen an RTT
+ * sample that matches or decreases its min_rtt estimate for 10 seconds, then
+ * it briefly enters PROBE_RTT to cut inflight to a minimum value to re-probe
+ * the path's two-way propagation delay (min_rtt). When exiting PROBE_RTT, if
+ * we estimated that we reached the full bw of the pipe then we enter PROBE_BW;
+ * otherwise we enter STARTUP to try to fill the pipe.
+ *
+ * The BBR foundation is described in:
+ *   "BBR: Congestion-Based Congestion Control",
+ *   Neal Cardwell, Yuchung Cheng, C. Stephen Gunn, Soheil Hassas Yeganeh,
+ *   Van Jacobson. ACM Queue, Vol. 14 No. 5, September-October 2016.
+ *
+ * NOTE: BBRQ might be used with the fq qdisc ("man tc-fq") with pacing enabled,
+ * otherwise TCP stack falls back to an internal pacing using one high
+ * resolution timer per TCP socket and may use more resources.
+ */
+#include <linux/btf.h>
+#include <linux/btf_ids.h>
+#include <linux/module.h>
+#include <net/tcp.h>
+#include <linux/inet_diag.h>
+#include <linux/inet.h>
+#include <linux/random.h>
+#include <linux/win_minmax.h>
+
+/* Scale factor for rate in pkt/uSec unit to avoid truncation in bandwidth
+ * estimation. The rate unit ~= (1500 bytes / 1 usec / 2^24) ~= 715 bps.
+ * This handles bandwidths from 0.06pps (715bps) to 256Mpps (3Tbps) in a u32.
+ * Since the minimum window is >=4 packets, the lower bound isn't
+ * an issue. The upper bound isn't an issue with existing technologies.
+ */
+#define BW_SCALE 24
+#define BW_UNIT (1 << BW_SCALE)
+
+#define BBRQ_SCALE 8	/* scaling factor for fractions in BBRQ (e.g. gains) */
+#define BBRQ_UNIT (1 << BBRQ_SCALE)
+
+/* BBRQ has the following modes for deciding how fast to send: */
+enum bbrq_mode {
+	BBRQ_STARTUP,	/* ramp up sending rate rapidly to fill pipe */
+	BBRQ_DRAIN,	/* drain any queue created during startup */
+	BBRQ_PROBE_BW,	/* discover, share bw: pace around estimated bw */
+	BBRQ_PROBE_RTT,	/* cut inflight to min to probe min_rtt */
+};
+
+/* BBRQ congestion control block */
+struct bbrq {
+	u32	min_rtt_us;	        /* min RTT in min_rtt_win_sec window */
+	u32	min_rtt_stamp;	        /* timestamp of min_rtt_us */
+	u32	probe_rtt_done_stamp;   /* end time for BBRQ_PROBE_RTT mode */
+	struct minmax bw;	/* Max recent delivery rate in pkts/uS << 24 */
+	u32	rtt_cnt;	    /* count of packet-timed rounds elapsed */
+	u32     next_rtt_delivered; /* scb->tx.delivered at end of round */
+	u64	cycle_mstamp;	     /* time of this cycle phase start */
+	u32     mode:3,		     /* current bbrq_mode in state machine */
+		prev_ca_state:3,     /* CA state on previous ACK */
+		packet_conservation:1,  /* use packet conservation? */
+		round_start:1,	     /* start of packet-timed tx->ack round? */
+		idle_restart:1,	     /* restarting after idle? */
+		probe_rtt_round_done:1,  /* a BBRQ_PROBE_RTT round at 4 pkts? */
+		unused:13,
+		lt_is_sampling:1,    /* taking long-term ("LT") samples now? */
+		lt_rtt_cnt:7,	     /* round trips in long-term interval */
+		lt_use_bw:1;	     /* use lt_bw as our bw estimate? */
+	u32	lt_bw;		     /* LT est delivery rate in pkts/uS << 24 */
+	u32	lt_last_delivered;   /* LT intvl start: tp->delivered */
+	u32	lt_last_stamp;	     /* LT intvl start: tp->delivered_mstamp */
+	u32	lt_last_lost;	     /* LT intvl start: tp->lost */
+	u32	pacing_gain:10,	/* current gain for setting pacing rate */
+		cwnd_gain:10,	/* current gain for setting cwnd */
+		full_bw_reached:1,   /* reached full bw in Startup? */
+		full_bw_cnt:2,	/* number of rounds without large bw gains */
+		cycle_idx:3,	/* current index in pacing_gain cycle array */
+		has_seen_rtt:1, /* have we seen an RTT sample yet? */
+		unused_b:5;
+	u32	prior_cwnd;	/* prior cwnd upon entering loss recovery */
+	u32	full_bw;	/* recent bw, to estimate if pipe is full */
+
+	/* For tracking ACK aggregation: */
+	u64	ack_epoch_mstamp;	/* start of ACK sampling epoch */
+	u16	extra_acked[2];		/* max excess data ACKed in epoch */
+	u32	ack_epoch_acked:20,	/* packets (S)ACKed in sampling epoch */
+		extra_acked_win_rtts:5,	/* age of extra_acked, in round trips */
+		extra_acked_win_idx:1,	/* current index in extra_acked array */
+		queue_rounds:3,		/* consecutive RTT-inflated rounds */
+		guard_rounds:3;		/* conservative gain rounds remaining */
+};
+
+#define CYCLE_LEN	8	/* number of phases in a pacing gain cycle */
+
+/* Window length of bw filter (in rounds): */
+static const int bbrq_bw_rtts = CYCLE_LEN + 2;
+/* Window length of min_rtt filter (in sec): */
+static const u32 bbrq_min_rtt_win_sec = 10;
+/* Minimum time (in ms) spent at bbrq_cwnd_min_target in BBRQ_PROBE_RTT mode: */
+static const u32 bbrq_probe_rtt_mode_ms = 200;
+/* Skip TSO below the following bandwidth (bits/sec): */
+static const int bbrq_min_tso_rate = 1200000;
+
+/* Pace at ~1% below estimated bw, on average, to reduce queue at bottleneck.
+ * In order to help drive the network toward lower queues and low latency while
+ * maintaining high utilization, the average pacing rate aims to be slightly
+ * lower than the estimated bandwidth. This is an important aspect of the
+ * design.
+ */
+static const int bbrq_pacing_margin_percent = 1;
+
+/* We use a high_gain value of 2/ln(2) because it's the smallest pacing gain
+ * that will allow a smoothly increasing pacing rate that will double each RTT
+ * and send the same number of packets per RTT that an un-paced, slow-starting
+ * Reno or CUBIC flow would:
+ */
+static const int bbrq_high_gain  = BBRQ_UNIT * 2885 / 1000 + 1;
+/* The pacing gain of 1/high_gain in BBRQ_DRAIN is calculated to typically drain
+ * the queue created in BBRQ_STARTUP in a single round:
+ */
+static const int bbrq_drain_gain = BBRQ_UNIT * 1000 / 2885;
+/* The gain for deriving steady-state cwnd tolerates delayed/stretched ACKs: */
+static const int bbrq_cwnd_gain  = BBRQ_UNIT * 2;
+/* The pacing_gain values for the PROBE_BW gain cycle, to discover/share bw: */
+static const int bbrq_pacing_gain[] = {
+	BBRQ_UNIT * 9 / 8,	/* probe gently for more available bw */
+	BBRQ_UNIT * 7 / 8,	/* drain queue and/or yield bw to other flows */
+	BBRQ_UNIT, BBRQ_UNIT, BBRQ_UNIT,	/* cruise at 1.0*bw to utilize pipe, */
+	BBRQ_UNIT, BBRQ_UNIT, BBRQ_UNIT	/* without creating excess queue... */
+};
+
+/* Randomize the starting gain cycling phase over N phases: */
+static const u32 bbrq_cycle_rand = 7;
+
+/* Try to keep at least this many packets in flight, if things go smoothly. For
+ * smooth functioning, a sliding window protocol ACKing every other packet
+ * needs at least 4 packets in flight:
+ */
+static const u32 bbrq_cwnd_min_target = 4;
+
+/* To estimate if BBRQ_STARTUP mode (i.e. high_gain) has filled pipe... */
+/* If bw has increased significantly (1.25x), there may be more bw available: */
+static const u32 bbrq_full_bw_thresh = BBRQ_UNIT * 5 / 4;
+/* But after 3 rounds w/o significant bw growth, estimate pipe is full: */
+static const u32 bbrq_full_bw_cnt = 3;
+
+/* "long-term" ("LT") bandwidth estimator parameters... */
+/* The minimum number of rounds in an LT bw sampling interval: */
+static const u32 bbrq_lt_intvl_min_rtts = 4;
+/* If lost/delivered ratio > 20%, interval is "lossy" and we may be policed: */
+static const u32 bbrq_lt_loss_thresh = 50;
+/* If 2 intervals have a bw ratio <= 1/8, their bw is "consistent": */
+static const u32 bbrq_lt_bw_ratio = BBRQ_UNIT / 8;
+/* If 2 intervals have a bw diff <= 4 Kbit/sec their bw is "consistent": */
+static const u32 bbrq_lt_bw_diff = 4000 / 8;
+/* If we estimate we're policed, use lt_bw for this many round trips: */
+static const u32 bbrq_lt_bw_max_rtts = 48;
+
+/* Gain factor for adding extra_acked to target cwnd: */
+static const int bbrq_extra_acked_gain = BBRQ_UNIT;
+/* Window length of extra_acked window. */
+static const u32 bbrq_extra_acked_win_rtts = 5;
+/* Max allowed val for ack_epoch_acked, after which sampling epoch is reset */
+static const u32 bbrq_ack_epoch_acked_reset_thresh = 1U << 20;
+/* Time period for clamping cwnd increment due to ack aggregation */
+static const u32 bbrq_extra_acked_max_us = 100 * 1000;
+
+/* Queue/loss guard parameters. Values are writable module parameters so a
+ * deployment can tune them from controlled A/B measurements. rtt_thresh is
+ * scaled by 1024; 1280 means current RTT >= 1.25 * min_rtt. The loss threshold
+ * is per mille; 20 means 2 percent of packets delivered in a rate sample.
+ */
+static u32 bbrq_rtt_thresh = 1280;
+module_param_named(rtt_thresh, bbrq_rtt_thresh, uint, 0644);
+MODULE_PARM_DESC(rtt_thresh, "RTT inflation threshold, scaled by 1024");
+
+static u32 bbrq_loss_thresh = 20;
+module_param_named(loss_thresh, bbrq_loss_thresh, uint, 0644);
+MODULE_PARM_DESC(loss_thresh, "Loss threshold in packets per thousand");
+
+static u32 bbrq_guard_duration = 2;
+module_param_named(guard_duration, bbrq_guard_duration, uint, 0644);
+MODULE_PARM_DESC(guard_duration, "Conservative gain duration in packet-timed rounds");
+
+/* During a guard, pace at 0.90 * estimated bandwidth and cap the steady-state
+ * congestion window at 1.5 BDP. These values deliberately preserve headroom
+ * for cross traffic without turning a single noisy RTT sample into a collapse.
+ */
+static const u32 bbrq_guard_pacing_gain = BBRQ_UNIT * 9 / 10;
+static const u32 bbrq_guard_cwnd_gain = BBRQ_UNIT * 3 / 2;
+
+static void bbrq_check_probe_rtt_done(struct sock *sk);
+
+/* Do we estimate that STARTUP filled the pipe? */
+static bool bbrq_full_bw_reached(const struct sock *sk)
+{
+	const struct bbrq *bbrq = inet_csk_ca(sk);
+
+	return bbrq->full_bw_reached;
+}
+
+/* Return the windowed max recent bandwidth sample, in pkts/uS << BW_SCALE. */
+static u32 bbrq_max_bw(const struct sock *sk)
+{
+	struct bbrq *bbrq = inet_csk_ca(sk);
+
+	return minmax_get(&bbrq->bw);
+}
+
+/* Return the estimated bandwidth of the path, in pkts/uS << BW_SCALE. */
+static u32 bbrq_bw(const struct sock *sk)
+{
+	struct bbrq *bbrq = inet_csk_ca(sk);
+
+	return bbrq->lt_use_bw ? bbrq->lt_bw : bbrq_max_bw(sk);
+}
+
+/* Return maximum extra acked in past k-2k round trips,
+ * where k = bbrq_extra_acked_win_rtts.
+ */
+static u16 bbrq_extra_acked(const struct sock *sk)
+{
+	struct bbrq *bbrq = inet_csk_ca(sk);
+
+	return max(bbrq->extra_acked[0], bbrq->extra_acked[1]);
+}
+
+/* Return rate in bytes per second, optionally with a gain.
+ * The order here is chosen carefully to avoid overflow of u64. This should
+ * work for input rates of up to 2.9Tbit/sec and gain of 2.89x.
+ */
+static u64 bbrq_rate_bytes_per_sec(struct sock *sk, u64 rate, int gain)
+{
+	unsigned int mss = tcp_sk(sk)->mss_cache;
+
+	rate *= mss;
+	rate *= gain;
+	rate >>= BBRQ_SCALE;
+	rate *= USEC_PER_SEC / 100 * (100 - bbrq_pacing_margin_percent);
+	return rate >> BW_SCALE;
+}
+
+/* Convert a BBRQ bw and gain factor to a pacing rate in bytes per second. */
+static unsigned long bbrq_bw_to_pacing_rate(struct sock *sk, u32 bw, int gain)
+{
+	u64 rate = bw;
+
+	rate = bbrq_rate_bytes_per_sec(sk, rate, gain);
+	rate = min_t(u64, rate, READ_ONCE(sk->sk_max_pacing_rate));
+	return rate;
+}
+
+/* Initialize pacing rate to: high_gain * init_cwnd / RTT. */
+static void bbrq_init_pacing_rate_from_rtt(struct sock *sk)
+{
+	struct tcp_sock *tp = tcp_sk(sk);
+	struct bbrq *bbrq = inet_csk_ca(sk);
+	u64 bw;
+	u32 rtt_us;
+
+	if (tp->srtt_us) {		/* any RTT sample yet? */
+		rtt_us = max(tp->srtt_us >> 3, 1U);
+		bbrq->has_seen_rtt = 1;
+	} else {			 /* no RTT sample yet */
+		rtt_us = USEC_PER_MSEC;	 /* use nominal default RTT */
+	}
+	bw = (u64)tcp_snd_cwnd(tp) * BW_UNIT;
+	do_div(bw, rtt_us);
+	WRITE_ONCE(sk->sk_pacing_rate,
+		   bbrq_bw_to_pacing_rate(sk, bw, bbrq_high_gain));
+}
+
+/* Pace using current bw estimate and a gain factor. */
+static void bbrq_set_pacing_rate(struct sock *sk, u32 bw, int gain)
+{
+	struct tcp_sock *tp = tcp_sk(sk);
+	struct bbrq *bbrq = inet_csk_ca(sk);
+	unsigned long rate = bbrq_bw_to_pacing_rate(sk, bw, gain);
+
+	if (unlikely(!bbrq->has_seen_rtt && tp->srtt_us))
+		bbrq_init_pacing_rate_from_rtt(sk);
+	if (bbrq_full_bw_reached(sk) || rate > READ_ONCE(sk->sk_pacing_rate))
+		WRITE_ONCE(sk->sk_pacing_rate, rate);
+}
+
+/* override sysctl_tcp_min_tso_segs */
+__bpf_kfunc static u32 bbrq_min_tso_segs(struct sock *sk)
+{
+	return READ_ONCE(sk->sk_pacing_rate) < (bbrq_min_tso_rate >> 3) ? 1 : 2;
+}
+
+static u32 bbrq_tso_segs_goal(struct sock *sk)
+{
+	struct tcp_sock *tp = tcp_sk(sk);
+	u32 segs, bytes;
+
+	/* Sort of tcp_tso_autosize() but ignoring
+	 * driver provided sk_gso_max_size.
+	 */
+	bytes = min_t(unsigned long,
+		      READ_ONCE(sk->sk_pacing_rate) >> READ_ONCE(sk->sk_pacing_shift),
+		      GSO_LEGACY_MAX_SIZE - 1 - MAX_TCP_HEADER);
+	segs = max_t(u32, bytes / tp->mss_cache, bbrq_min_tso_segs(sk));
+
+	return min(segs, 0x7FU);
+}
+
+/* Save "last known good" cwnd so we can restore it after losses or PROBE_RTT */
+static void bbrq_save_cwnd(struct sock *sk)
+{
+	struct tcp_sock *tp = tcp_sk(sk);
+	struct bbrq *bbrq = inet_csk_ca(sk);
+
+	if (bbrq->prev_ca_state < TCP_CA_Recovery && bbrq->mode != BBRQ_PROBE_RTT)
+		bbrq->prior_cwnd = tcp_snd_cwnd(tp);  /* this cwnd is good enough */
+	else  /* loss recovery or BBRQ_PROBE_RTT have temporarily cut cwnd */
+		bbrq->prior_cwnd = max(bbrq->prior_cwnd, tcp_snd_cwnd(tp));
+}
+
+__bpf_kfunc static void bbrq_cwnd_event(struct sock *sk, enum tcp_ca_event event)
+{
+	struct tcp_sock *tp = tcp_sk(sk);
+	struct bbrq *bbrq = inet_csk_ca(sk);
+
+	if (event == CA_EVENT_TX_START && tp->app_limited) {
+		bbrq->idle_restart = 1;
+		bbrq->ack_epoch_mstamp = tp->tcp_mstamp;
+		bbrq->ack_epoch_acked = 0;
+		/* Avoid pointless buffer overflows: pace at est. bw if we don't
+		 * need more speed (we're restarting from idle and app-limited).
+		 */
+		if (bbrq->mode == BBRQ_PROBE_BW)
+			bbrq_set_pacing_rate(sk, bbrq_bw(sk), BBRQ_UNIT);
+		else if (bbrq->mode == BBRQ_PROBE_RTT)
+			bbrq_check_probe_rtt_done(sk);
+	}
+}
+
+/* Calculate bdp based on min RTT and the estimated bottleneck bandwidth:
+ *
+ * bdp = ceil(bw * min_rtt * gain)
+ *
+ * The key factor, gain, controls the amount of queue. While a small gain
+ * builds a smaller queue, it becomes more vulnerable to noise in RTT
+ * measurements (e.g., delayed ACKs or other ACK compression effects). This
+ * noise may cause BBRQ to under-estimate the rate.
+ */
+static u32 bbrq_bdp(struct sock *sk, u32 bw, int gain)
+{
+	struct bbrq *bbrq = inet_csk_ca(sk);
+	u32 bdp;
+	u64 w;
+
+	/* If we've never had a valid RTT sample, cap cwnd at the initial
+	 * default. This should only happen when the connection is not using TCP
+	 * timestamps and has retransmitted all of the SYN/SYNACK/data packets
+	 * ACKed so far. In this case, an RTO can cut cwnd to 1, in which
+	 * case we need to slow-start up toward something safe: TCP_INIT_CWND.
+	 */
+	if (unlikely(bbrq->min_rtt_us == ~0U))	 /* no valid RTT samples yet? */
+		return TCP_INIT_CWND;  /* be safe: cap at default initial cwnd*/
+
+	w = (u64)bw * bbrq->min_rtt_us;
+
+	/* Apply a gain to the given value, remove the BW_SCALE shift, and
+	 * round the value up to avoid a negative feedback loop.
+	 */
+	bdp = (((w * gain) >> BBRQ_SCALE) + BW_UNIT - 1) / BW_UNIT;
+
+	return bdp;
+}
+
+/* To achieve full performance in high-speed paths, we budget enough cwnd to
+ * fit full-sized skbs in-flight on both end hosts to fully utilize the path:
+ *   - one skb in sending host Qdisc,
+ *   - one skb in sending host TSO/GSO engine
+ *   - one skb being received by receiver host LRO/GRO/delayed-ACK engine
+ * Don't worry, at low rates (bbrq_min_tso_rate) this won't bloat cwnd because
+ * in such cases tso_segs_goal is 1. The minimum cwnd is 4 packets,
+ * which allows 2 outstanding 2-packet sequences, to try to keep pipe
+ * full even with ACK-every-other-packet delayed ACKs.
+ */
+static u32 bbrq_quantization_budget(struct sock *sk, u32 cwnd)
+{
+	struct bbrq *bbrq = inet_csk_ca(sk);
+
+	/* Allow enough full-sized skbs in flight to utilize end systems. */
+	cwnd += 3 * bbrq_tso_segs_goal(sk);
+
+	/* Reduce delayed ACKs by rounding up cwnd to the next even number. */
+	cwnd = (cwnd + 1) & ~1U;
+
+	/* Ensure gain cycling gets inflight above BDP even for small BDPs. */
+	if (bbrq->mode == BBRQ_PROBE_BW && bbrq->cycle_idx == 0)
+		cwnd += 2;
+
+	return cwnd;
+}
+
+/* Find inflight based on min RTT and the estimated bottleneck bandwidth. */
+static u32 bbrq_inflight(struct sock *sk, u32 bw, int gain)
+{
+	u32 inflight;
+
+	inflight = bbrq_bdp(sk, bw, gain);
+	inflight = bbrq_quantization_budget(sk, inflight);
+
+	return inflight;
+}
+
+/* With pacing at lower layers, there's often less data "in the network" than
+ * "in flight". With TSQ and departure time pacing at lower layers (e.g. fq),
+ * we often have several skbs queued in the pacing layer with a pre-scheduled
+ * earliest departure time (EDT). BBRQ adapts its pacing rate based on the
+ * inflight level that it estimates has already been "baked in" by previous
+ * departure time decisions. We calculate a rough estimate of the number of our
+ * packets that might be in the network at the earliest departure time for the
+ * next skb scheduled:
+ *   in_network_at_edt = inflight_at_edt - (EDT - now) * bw
+ * If we're increasing inflight, then we want to know if the transmit of the
+ * EDT skb will push inflight above the target, so inflight_at_edt includes
+ * bbrq_tso_segs_goal() from the skb departing at EDT. If decreasing inflight,
+ * then estimate if inflight will sink too low just before the EDT transmit.
+ */
+static u32 bbrq_packets_in_net_at_edt(struct sock *sk, u32 inflight_now)
+{
+	struct tcp_sock *tp = tcp_sk(sk);
+	struct bbrq *bbrq = inet_csk_ca(sk);
+	u64 now_ns, edt_ns, interval_us;
+	u32 interval_delivered, inflight_at_edt;
+
+	now_ns = tp->tcp_clock_cache;
+	edt_ns = max(tp->tcp_wstamp_ns, now_ns);
+	interval_us = div_u64(edt_ns - now_ns, NSEC_PER_USEC);
+	interval_delivered = (u64)bbrq_bw(sk) * interval_us >> BW_SCALE;
+	inflight_at_edt = inflight_now;
+	if (bbrq->pacing_gain > BBRQ_UNIT)              /* increasing inflight */
+		inflight_at_edt += bbrq_tso_segs_goal(sk);  /* include EDT skb */
+	if (interval_delivered >= inflight_at_edt)
+		return 0;
+	return inflight_at_edt - interval_delivered;
+}
+
+/* Find the cwnd increment based on estimate of ack aggregation */
+static u32 bbrq_ack_aggregation_cwnd(struct sock *sk)
+{
+	u32 max_aggr_cwnd, aggr_cwnd = 0;
+
+	if (bbrq_extra_acked_gain && bbrq_full_bw_reached(sk)) {
+		max_aggr_cwnd = ((u64)bbrq_bw(sk) * bbrq_extra_acked_max_us)
+				/ BW_UNIT;
+		aggr_cwnd = (bbrq_extra_acked_gain * bbrq_extra_acked(sk))
+			     >> BBRQ_SCALE;
+		aggr_cwnd = min(aggr_cwnd, max_aggr_cwnd);
+	}
+
+	return aggr_cwnd;
+}
+
+/* An optimization in BBRQ to reduce losses: On the first round of recovery, we
+ * follow the packet conservation principle: send P packets per P packets acked.
+ * After that, we slow-start and send at most 2*P packets per P packets acked.
+ * After recovery finishes, or upon undo, we restore the cwnd we had when
+ * recovery started (capped by the target cwnd based on estimated BDP).
+ *
+ * TODO(ycheng/ncardwell): implement a rate-based approach.
+ */
+static bool bbrq_set_cwnd_to_recover_or_restore(
+	struct sock *sk, const struct rate_sample *rs, u32 acked, u32 *new_cwnd)
+{
+	struct tcp_sock *tp = tcp_sk(sk);
+	struct bbrq *bbrq = inet_csk_ca(sk);
+	u8 prev_state = bbrq->prev_ca_state, state = inet_csk(sk)->icsk_ca_state;
+	u32 cwnd = tcp_snd_cwnd(tp);
+
+	/* An ACK for P pkts should release at most 2*P packets. We do this
+	 * in two steps. First, here we deduct the number of lost packets.
+	 * Then, in bbrq_set_cwnd() we slow start up toward the target cwnd.
+	 */
+	if (rs->losses > 0)
+		cwnd = max_t(s32, cwnd - rs->losses, 1);
+
+	if (state == TCP_CA_Recovery && prev_state != TCP_CA_Recovery) {
+		/* Starting 1st round of Recovery, so do packet conservation. */
+		bbrq->packet_conservation = 1;
+		bbrq->next_rtt_delivered = tp->delivered;  /* start round now */
+		/* Cut unused cwnd from app behavior, TSQ, or TSO deferral: */
+		cwnd = tcp_packets_in_flight(tp) + acked;
+	} else if (prev_state >= TCP_CA_Recovery && state < TCP_CA_Recovery) {
+		/* Exiting loss recovery; restore cwnd saved before recovery. */
+		cwnd = max(cwnd, bbrq->prior_cwnd);
+		bbrq->packet_conservation = 0;
+	}
+	bbrq->prev_ca_state = state;
+
+	if (bbrq->packet_conservation) {
+		*new_cwnd = max(cwnd, tcp_packets_in_flight(tp) + acked);
+		return true;	/* yes, using packet conservation */
+	}
+	*new_cwnd = cwnd;
+	return false;
+}
+
+/* Slow-start up toward target cwnd (if bw estimate is growing, or packet loss
+ * has drawn us down below target), or snap down to target if we're above it.
+ */
+static void bbrq_set_cwnd(struct sock *sk, const struct rate_sample *rs,
+			 u32 acked, u32 bw, int gain)
+{
+	struct tcp_sock *tp = tcp_sk(sk);
+	struct bbrq *bbrq = inet_csk_ca(sk);
+	u32 cwnd = tcp_snd_cwnd(tp), target_cwnd = 0;
+
+	if (!acked)
+		goto done;  /* no packet fully ACKed; just apply caps */
+
+	if (bbrq_set_cwnd_to_recover_or_restore(sk, rs, acked, &cwnd))
+		goto done;
+
+	target_cwnd = bbrq_bdp(sk, bw, gain);
+
+	/* Increment the cwnd to account for excess ACKed data that seems
+	 * due to aggregation (of data and/or ACKs) visible in the ACK stream.
+	 */
+	target_cwnd += bbrq_ack_aggregation_cwnd(sk);
+	target_cwnd = bbrq_quantization_budget(sk, target_cwnd);
+
+	/* If we're below target cwnd, slow start cwnd toward target cwnd. */
+	if (bbrq_full_bw_reached(sk))  /* only cut cwnd if we filled the pipe */
+		cwnd = min(cwnd + acked, target_cwnd);
+	else if (cwnd < target_cwnd || tp->delivered < TCP_INIT_CWND)
+		cwnd = cwnd + acked;
+	cwnd = max(cwnd, bbrq_cwnd_min_target);
+
+done:
+	tcp_snd_cwnd_set(tp, min(cwnd, tp->snd_cwnd_clamp));	/* apply global cap */
+	if (bbrq->mode == BBRQ_PROBE_RTT)  /* drain queue, refresh min_rtt */
+		tcp_snd_cwnd_set(tp, min(tcp_snd_cwnd(tp), bbrq_cwnd_min_target));
+}
+
+/* End cycle phase if it's time and/or we hit the phase's in-flight target. */
+static bool bbrq_is_next_cycle_phase(struct sock *sk,
+				    const struct rate_sample *rs)
+{
+	struct tcp_sock *tp = tcp_sk(sk);
+	struct bbrq *bbrq = inet_csk_ca(sk);
+	bool is_full_length =
+		tcp_stamp_us_delta(tp->delivered_mstamp, bbrq->cycle_mstamp) >
+		bbrq->min_rtt_us;
+	u32 inflight, bw;
+
+	/* The pacing_gain of 1.0 paces at the estimated bw to try to fully
+	 * use the pipe without increasing the queue.
+	 */
+	if (bbrq->pacing_gain == BBRQ_UNIT)
+		return is_full_length;		/* just use wall clock time */
+
+	inflight = bbrq_packets_in_net_at_edt(sk, rs->prior_in_flight);
+	bw = bbrq_max_bw(sk);
+
+	/* A pacing_gain > 1.0 probes for bw by trying to raise inflight to at
+	 * least pacing_gain*BDP; this may take more than min_rtt if min_rtt is
+	 * small (e.g. on a LAN). We do not persist if packets are lost, since
+	 * a path with small buffers may not hold that much.
+	 */
+	if (bbrq->pacing_gain > BBRQ_UNIT)
+		return is_full_length &&
+			(rs->losses ||  /* perhaps pacing_gain*BDP won't fit */
+			 inflight >= bbrq_inflight(sk, bw, bbrq->pacing_gain));
+
+	/* A pacing_gain < 1.0 tries to drain extra queue we added if bw
+	 * probing didn't find more bw. If inflight falls to match BDP then we
+	 * estimate queue is drained; persisting would underutilize the pipe.
+	 */
+	return is_full_length ||
+		inflight <= bbrq_inflight(sk, bw, BBRQ_UNIT);
+}
+
+static void bbrq_advance_cycle_phase(struct sock *sk)
+{
+	struct tcp_sock *tp = tcp_sk(sk);
+	struct bbrq *bbrq = inet_csk_ca(sk);
+
+	bbrq->cycle_idx = (bbrq->cycle_idx + 1) & (CYCLE_LEN - 1);
+	bbrq->cycle_mstamp = tp->delivered_mstamp;
+}
+
+/* Gain cycling: cycle pacing gain to converge to fair share of available bw. */
+static void bbrq_update_cycle_phase(struct sock *sk,
+				   const struct rate_sample *rs)
+{
+	struct bbrq *bbrq = inet_csk_ca(sk);
+
+	if (bbrq->mode == BBRQ_PROBE_BW && bbrq_is_next_cycle_phase(sk, rs))
+		bbrq_advance_cycle_phase(sk);
+}
+
+static void bbrq_reset_startup_mode(struct sock *sk)
+{
+	struct bbrq *bbrq = inet_csk_ca(sk);
+
+	bbrq->mode = BBRQ_STARTUP;
+}
+
+static void bbrq_reset_probe_bw_mode(struct sock *sk)
+{
+	struct bbrq *bbrq = inet_csk_ca(sk);
+
+	bbrq->mode = BBRQ_PROBE_BW;
+	bbrq->cycle_idx = CYCLE_LEN - 1 - get_random_u32_below(bbrq_cycle_rand);
+	bbrq_advance_cycle_phase(sk);	/* flip to next phase of gain cycle */
+}
+
+static void bbrq_reset_mode(struct sock *sk)
+{
+	if (!bbrq_full_bw_reached(sk))
+		bbrq_reset_startup_mode(sk);
+	else
+		bbrq_reset_probe_bw_mode(sk);
+}
+
+/* Start a new long-term sampling interval. */
+static void bbrq_reset_lt_bw_sampling_interval(struct sock *sk)
+{
+	struct tcp_sock *tp = tcp_sk(sk);
+	struct bbrq *bbrq = inet_csk_ca(sk);
+
+	bbrq->lt_last_stamp = div_u64(tp->delivered_mstamp, USEC_PER_MSEC);
+	bbrq->lt_last_delivered = tp->delivered;
+	bbrq->lt_last_lost = tp->lost;
+	bbrq->lt_rtt_cnt = 0;
+}
+
+/* Completely reset long-term bandwidth sampling. */
+static void bbrq_reset_lt_bw_sampling(struct sock *sk)
+{
+	struct bbrq *bbrq = inet_csk_ca(sk);
+
+	bbrq->lt_bw = 0;
+	bbrq->lt_use_bw = 0;
+	bbrq->lt_is_sampling = false;
+	bbrq_reset_lt_bw_sampling_interval(sk);
+}
+
+/* Long-term bw sampling interval is done. Estimate whether we're policed. */
+static void bbrq_lt_bw_interval_done(struct sock *sk, u32 bw)
+{
+	struct bbrq *bbrq = inet_csk_ca(sk);
+	u32 diff;
+
+	if (bbrq->lt_bw) {  /* do we have bw from a previous interval? */
+		/* Is new bw close to the lt_bw from the previous interval? */
+		diff = abs(bw - bbrq->lt_bw);
+		if ((diff * BBRQ_UNIT <= bbrq_lt_bw_ratio * bbrq->lt_bw) ||
+		    (bbrq_rate_bytes_per_sec(sk, diff, BBRQ_UNIT) <=
+		     bbrq_lt_bw_diff)) {
+			/* All criteria are met; estimate we're policed. */
+			bbrq->lt_bw = (bw + bbrq->lt_bw) >> 1;  /* avg 2 intvls */
+			bbrq->lt_use_bw = 1;
+			bbrq->pacing_gain = BBRQ_UNIT;  /* try to avoid drops */
+			bbrq->lt_rtt_cnt = 0;
+			return;
+		}
+	}
+	bbrq->lt_bw = bw;
+	bbrq_reset_lt_bw_sampling_interval(sk);
+}
+
+/* Token-bucket traffic policers are common (see "An Internet-Wide Analysis of
+ * Traffic Policing", SIGCOMM 2016). BBRQ detects token-bucket policers and
+ * explicitly models their policed rate, to reduce unnecessary losses. We
+ * estimate that we're policed if we see 2 consecutive sampling intervals with
+ * consistent throughput and high packet loss. If we think we're being policed,
+ * set lt_bw to the "long-term" average delivery rate from those 2 intervals.
+ */
+static void bbrq_lt_bw_sampling(struct sock *sk, const struct rate_sample *rs)
+{
+	struct tcp_sock *tp = tcp_sk(sk);
+	struct bbrq *bbrq = inet_csk_ca(sk);
+	u32 lost, delivered;
+	u64 bw;
+	u32 t;
+
+	if (bbrq->lt_use_bw) {	/* already using long-term rate, lt_bw? */
+		if (bbrq->mode == BBRQ_PROBE_BW && bbrq->round_start &&
+		    ++bbrq->lt_rtt_cnt >= bbrq_lt_bw_max_rtts) {
+			bbrq_reset_lt_bw_sampling(sk);    /* stop using lt_bw */
+			bbrq_reset_probe_bw_mode(sk);  /* restart gain cycling */
+		}
+		return;
+	}
+
+	/* Wait for the first loss before sampling, to let the policer exhaust
+	 * its tokens and estimate the steady-state rate allowed by the policer.
+	 * Starting samples earlier includes bursts that over-estimate the bw.
+	 */
+	if (!bbrq->lt_is_sampling) {
+		if (!rs->losses)
+			return;
+		bbrq_reset_lt_bw_sampling_interval(sk);
+		bbrq->lt_is_sampling = true;
+	}
+
+	/* To avoid underestimates, reset sampling if we run out of data. */
+	if (rs->is_app_limited) {
+		bbrq_reset_lt_bw_sampling(sk);
+		return;
+	}
+
+	if (bbrq->round_start)
+		bbrq->lt_rtt_cnt++;	/* count round trips in this interval */
+	if (bbrq->lt_rtt_cnt < bbrq_lt_intvl_min_rtts)
+		return;		/* sampling interval needs to be longer */
+	if (bbrq->lt_rtt_cnt > 4 * bbrq_lt_intvl_min_rtts) {
+		bbrq_reset_lt_bw_sampling(sk);  /* interval is too long */
+		return;
+	}
+
+	/* End sampling interval when a packet is lost, so we estimate the
+	 * policer tokens were exhausted. Stopping the sampling before the
+	 * tokens are exhausted under-estimates the policed rate.
+	 */
+	if (!rs->losses)
+		return;
+
+	/* Calculate packets lost and delivered in sampling interval. */
+	lost = tp->lost - bbrq->lt_last_lost;
+	delivered = tp->delivered - bbrq->lt_last_delivered;
+	/* Is loss rate (lost/delivered) >= lt_loss_thresh? If not, wait. */
+	if (!delivered || (lost << BBRQ_SCALE) < bbrq_lt_loss_thresh * delivered)
+		return;
+
+	/* Find average delivery rate in this sampling interval. */
+	t = div_u64(tp->delivered_mstamp, USEC_PER_MSEC) - bbrq->lt_last_stamp;
+	if ((s32)t < 1)
+		return;		/* interval is less than one ms, so wait */
+	/* Check if can multiply without overflow */
+	if (t >= ~0U / USEC_PER_MSEC) {
+		bbrq_reset_lt_bw_sampling(sk);  /* interval too long; reset */
+		return;
+	}
+	t *= USEC_PER_MSEC;
+	bw = (u64)delivered * BW_UNIT;
+	do_div(bw, t);
+	bbrq_lt_bw_interval_done(sk, bw);
+}
+
+/* Estimate the bandwidth based on how fast packets are delivered */
+static void bbrq_update_bw(struct sock *sk, const struct rate_sample *rs)
+{
+	struct tcp_sock *tp = tcp_sk(sk);
+	struct bbrq *bbrq = inet_csk_ca(sk);
+	u64 bw;
+
+	bbrq->round_start = 0;
+	if (rs->delivered < 0 || rs->interval_us <= 0)
+		return; /* Not a valid observation */
+
+	/* See if we've reached the next RTT */
+	if (!before(rs->prior_delivered, bbrq->next_rtt_delivered)) {
+		bbrq->next_rtt_delivered = tp->delivered;
+		bbrq->rtt_cnt++;
+		bbrq->round_start = 1;
+		bbrq->packet_conservation = 0;
+	}
+
+	bbrq_lt_bw_sampling(sk, rs);
+
+	/* Divide delivered by the interval to find a (lower bound) bottleneck
+	 * bandwidth sample. Delivered is in packets and interval_us in uS and
+	 * ratio will be <<1 for most connections. So delivered is first scaled.
+	 */
+	bw = div64_long((u64)rs->delivered * BW_UNIT, rs->interval_us);
+
+	/* If this sample is application-limited, it is likely to have a very
+	 * low delivered count that represents application behavior rather than
+	 * the available network rate. Such a sample could drag down estimated
+	 * bw, causing needless slow-down. Thus, to continue to send at the
+	 * last measured network rate, we filter out app-limited samples unless
+	 * they describe the path bw at least as well as our bw model.
+	 *
+	 * So the goal during app-limited phase is to proceed with the best
+	 * network rate no matter how long. We automatically leave this
+	 * phase when app writes faster than the network can deliver :)
+	 */
+	if (!rs->is_app_limited || bw >= bbrq_max_bw(sk)) {
+		/* Incorporate new sample into our max bw filter. */
+		minmax_running_max(&bbrq->bw, bbrq_bw_rtts, bbrq->rtt_cnt, bw);
+	}
+}
+
+/* Estimates the windowed max degree of ack aggregation.
+ * This is used to provision extra in-flight data to keep sending during
+ * inter-ACK silences.
+ *
+ * Degree of ack aggregation is estimated as extra data acked beyond expected.
+ *
+ * max_extra_acked = "maximum recent excess data ACKed beyond max_bw * interval"
+ * cwnd += max_extra_acked
+ *
+ * Max extra_acked is clamped by cwnd and bw * bbrq_extra_acked_max_us (100 ms).
+ * Max filter is an approximate sliding window of 5-10 (packet timed) round
+ * trips.
+ */
+static void bbrq_update_ack_aggregation(struct sock *sk,
+				       const struct rate_sample *rs)
+{
+	u32 epoch_us, expected_acked, extra_acked;
+	struct bbrq *bbrq = inet_csk_ca(sk);
+	struct tcp_sock *tp = tcp_sk(sk);
+
+	if (!bbrq_extra_acked_gain || rs->acked_sacked <= 0 ||
+	    rs->delivered < 0 || rs->interval_us <= 0)
+		return;
+
+	if (bbrq->round_start) {
+		bbrq->extra_acked_win_rtts = min(0x1F,
+						bbrq->extra_acked_win_rtts + 1);
+		if (bbrq->extra_acked_win_rtts >= bbrq_extra_acked_win_rtts) {
+			bbrq->extra_acked_win_rtts = 0;
+			bbrq->extra_acked_win_idx = bbrq->extra_acked_win_idx ?
+						   0 : 1;
+			bbrq->extra_acked[bbrq->extra_acked_win_idx] = 0;
+		}
+	}
+
+	/* Compute how many packets we expected to be delivered over epoch. */
+	epoch_us = tcp_stamp_us_delta(tp->delivered_mstamp,
+				      bbrq->ack_epoch_mstamp);
+	expected_acked = ((u64)bbrq_bw(sk) * epoch_us) / BW_UNIT;
+
+	/* Reset the aggregation epoch if ACK rate is below expected rate or
+	 * significantly large no. of ack received since epoch (potentially
+	 * quite old epoch).
+	 */
+	if (bbrq->ack_epoch_acked <= expected_acked ||
+	    (bbrq->ack_epoch_acked + rs->acked_sacked >=
+	     bbrq_ack_epoch_acked_reset_thresh)) {
+		bbrq->ack_epoch_acked = 0;
+		bbrq->ack_epoch_mstamp = tp->delivered_mstamp;
+		expected_acked = 0;
+	}
+
+	/* Compute excess data delivered, beyond what was expected. */
+	bbrq->ack_epoch_acked = min_t(u32, 0xFFFFF,
+				     bbrq->ack_epoch_acked + rs->acked_sacked);
+	extra_acked = bbrq->ack_epoch_acked - expected_acked;
+	extra_acked = min(extra_acked, tcp_snd_cwnd(tp));
+	if (extra_acked > bbrq->extra_acked[bbrq->extra_acked_win_idx])
+		bbrq->extra_acked[bbrq->extra_acked_win_idx] = extra_acked;
+}
+
+/* Estimate when the pipe is full, using the change in delivery rate: BBRQ
+ * estimates that STARTUP filled the pipe if the estimated bw hasn't changed by
+ * at least bbrq_full_bw_thresh (25%) after bbrq_full_bw_cnt (3) non-app-limited
+ * rounds. Why 3 rounds: 1: rwin autotuning grows the rwin, 2: we fill the
+ * higher rwin, 3: we get higher delivery rate samples. Or transient
+ * cross-traffic or radio noise can go away. CUBIC Hystart shares a similar
+ * design goal, but uses delay and inter-ACK spacing instead of bandwidth.
+ */
+static void bbrq_check_full_bw_reached(struct sock *sk,
+				      const struct rate_sample *rs)
+{
+	struct bbrq *bbrq = inet_csk_ca(sk);
+	u32 bw_thresh;
+
+	if (bbrq_full_bw_reached(sk) || !bbrq->round_start || rs->is_app_limited)
+		return;
+
+	bw_thresh = (u64)bbrq->full_bw * bbrq_full_bw_thresh >> BBRQ_SCALE;
+	if (bbrq_max_bw(sk) >= bw_thresh) {
+		bbrq->full_bw = bbrq_max_bw(sk);
+		bbrq->full_bw_cnt = 0;
+		return;
+	}
+	++bbrq->full_bw_cnt;
+	bbrq->full_bw_reached = bbrq->full_bw_cnt >= bbrq_full_bw_cnt;
+}
+
+/* If pipe is probably full, drain the queue and then enter steady-state. */
+static void bbrq_check_drain(struct sock *sk, const struct rate_sample *rs)
+{
+	struct bbrq *bbrq = inet_csk_ca(sk);
+
+	if (bbrq->mode == BBRQ_STARTUP && bbrq_full_bw_reached(sk)) {
+		bbrq->mode = BBRQ_DRAIN;	/* drain queue we created */
+		WRITE_ONCE(tcp_sk(sk)->snd_ssthresh,
+			   bbrq_inflight(sk, bbrq_max_bw(sk), BBRQ_UNIT));
+	}	/* fall through to check if in-flight is already small: */
+	if (bbrq->mode == BBRQ_DRAIN &&
+	    bbrq_packets_in_net_at_edt(sk, tcp_packets_in_flight(tcp_sk(sk))) <=
+	    bbrq_inflight(sk, bbrq_max_bw(sk), BBRQ_UNIT))
+		bbrq_reset_probe_bw_mode(sk);  /* we estimate queue is drained */
+}
+
+static void bbrq_check_probe_rtt_done(struct sock *sk)
+{
+	struct tcp_sock *tp = tcp_sk(sk);
+	struct bbrq *bbrq = inet_csk_ca(sk);
+
+	if (!(bbrq->probe_rtt_done_stamp &&
+	      after(tcp_jiffies32, bbrq->probe_rtt_done_stamp)))
+		return;
+
+	bbrq->min_rtt_stamp = tcp_jiffies32;  /* wait a while until PROBE_RTT */
+	tcp_snd_cwnd_set(tp, max(tcp_snd_cwnd(tp), bbrq->prior_cwnd));
+	bbrq_reset_mode(sk);
+}
+
+/* The goal of PROBE_RTT mode is to have BBRQ flows cooperatively and
+ * periodically drain the bottleneck queue, to converge to measure the true
+ * min_rtt (unloaded propagation delay). This allows the flows to keep queues
+ * small (reducing queuing delay and packet loss) and achieve fairness among
+ * BBRQ flows.
+ *
+ * The min_rtt filter window is 10 seconds. When the min_rtt estimate expires,
+ * we enter PROBE_RTT mode and cap the cwnd at bbrq_cwnd_min_target=4 packets.
+ * After at least bbrq_probe_rtt_mode_ms=200ms and at least one packet-timed
+ * round trip elapsed with that flight size <= 4, we leave PROBE_RTT mode and
+ * re-enter the previous mode. BBRQ uses 200ms to approximately bound the
+ * performance penalty of PROBE_RTT's cwnd capping to roughly 2% (200ms/10s).
+ *
+ * Note that flows need only pay 2% if they are busy sending over the last 10
+ * seconds. Interactive applications (e.g., Web, RPCs, video chunks) often have
+ * natural silences or low-rate periods within 10 seconds where the rate is low
+ * enough for long enough to drain its queue in the bottleneck. We pick up
+ * these min RTT measurements opportunistically with our min_rtt filter. :-)
+ */
+static void bbrq_update_min_rtt(struct sock *sk, const struct rate_sample *rs)
+{
+	struct tcp_sock *tp = tcp_sk(sk);
+	struct bbrq *bbrq = inet_csk_ca(sk);
+	bool filter_expired;
+
+	/* Track min RTT seen in the min_rtt_win_sec filter window: */
+	filter_expired = after(tcp_jiffies32,
+			       bbrq->min_rtt_stamp + bbrq_min_rtt_win_sec * HZ);
+	if (rs->rtt_us >= 0 &&
+	    (rs->rtt_us < bbrq->min_rtt_us ||
+	     (filter_expired && !rs->is_ack_delayed))) {
+		bbrq->min_rtt_us = rs->rtt_us;
+		bbrq->min_rtt_stamp = tcp_jiffies32;
+	}
+
+	if (bbrq_probe_rtt_mode_ms > 0 && filter_expired &&
+	    !bbrq->idle_restart && bbrq->mode != BBRQ_PROBE_RTT) {
+		bbrq->mode = BBRQ_PROBE_RTT;  /* dip, drain queue */
+		bbrq_save_cwnd(sk);  /* note cwnd so we can restore it */
+		bbrq->probe_rtt_done_stamp = 0;
+	}
+
+	if (bbrq->mode == BBRQ_PROBE_RTT) {
+		/* Ignore low rate samples during this mode. */
+		tp->app_limited =
+			(tp->delivered + tcp_packets_in_flight(tp)) ? : 1;
+		/* Maintain min packets in flight for max(200 ms, 1 round). */
+		if (!bbrq->probe_rtt_done_stamp &&
+		    tcp_packets_in_flight(tp) <= bbrq_cwnd_min_target) {
+			bbrq->probe_rtt_done_stamp = tcp_jiffies32 +
+				msecs_to_jiffies(bbrq_probe_rtt_mode_ms);
+			bbrq->probe_rtt_round_done = 0;
+			bbrq->next_rtt_delivered = tp->delivered;
+		} else if (bbrq->probe_rtt_done_stamp) {
+			if (bbrq->round_start)
+				bbrq->probe_rtt_round_done = 1;
+			if (bbrq->probe_rtt_round_done)
+				bbrq_check_probe_rtt_done(sk);
+		}
+	}
+	/* Restart after idle ends only once we process a new S/ACK for data */
+	if (rs->delivered > 0)
+		bbrq->idle_restart = 0;
+}
+
+static void bbrq_update_gains(struct sock *sk)
+{
+	struct bbrq *bbrq = inet_csk_ca(sk);
+
+	switch (bbrq->mode) {
+	case BBRQ_STARTUP:
+		bbrq->pacing_gain = bbrq_high_gain;
+		bbrq->cwnd_gain	 = bbrq_high_gain;
+		break;
+	case BBRQ_DRAIN:
+		bbrq->pacing_gain = bbrq_drain_gain;	/* slow, to drain */
+		bbrq->cwnd_gain	 = bbrq_high_gain;	/* keep cwnd */
+		break;
+	case BBRQ_PROBE_BW:
+		bbrq->pacing_gain = (bbrq->lt_use_bw ?
+				    BBRQ_UNIT :
+				    bbrq_pacing_gain[bbrq->cycle_idx]);
+		bbrq->cwnd_gain	 = bbrq_cwnd_gain;
+		if (bbrq->guard_rounds) {
+			bbrq->pacing_gain = min_t(u32, bbrq->pacing_gain,
+						 bbrq_guard_pacing_gain);
+			bbrq->cwnd_gain = min_t(u32, bbrq->cwnd_gain,
+					       bbrq_guard_cwnd_gain);
+		}
+		break;
+	case BBRQ_PROBE_RTT:
+		bbrq->pacing_gain = BBRQ_UNIT;
+		bbrq->cwnd_gain	 = BBRQ_UNIT;
+		break;
+	default:
+		WARN_ONCE(1, "BBRQ bad mode: %u\n", bbrq->mode);
+		break;
+	}
+}
+
+/* Update the queue/loss guard once per packet-timed round. We require two
+ * consecutive inflated RTT rounds to filter delayed ACK and scheduler noise.
+ * A rate sample whose loss ratio crosses the configured threshold is a
+ * stronger signal and enables the guard immediately.
+ */
+static void bbrq_update_guard(struct sock *sk, const struct rate_sample *rs)
+{
+	struct bbrq *bbrq = inet_csk_ca(sk);
+	bool loss_signal = false;
+	bool queue_signal = false;
+	u32 duration;
+
+	if (!bbrq->round_start)
+		return;
+
+	if (bbrq->guard_rounds)
+		bbrq->guard_rounds--;
+
+	if (rs->rtt_us > 0 && bbrq->min_rtt_us != ~0U)
+		queue_signal = (u64)rs->rtt_us * 1024 >=
+			       (u64)bbrq->min_rtt_us *
+			       max_t(u32, bbrq_rtt_thresh, 1024);
+
+	if (queue_signal)
+		bbrq->queue_rounds = min_t(u32, bbrq->queue_rounds + 1, 7);
+	else
+		bbrq->queue_rounds = 0;
+
+	if (rs->delivered > 0 && rs->losses > 0)
+		loss_signal = (u64)rs->losses * 1000 >=
+			      (u64)rs->delivered *
+			      min_t(u32, bbrq_loss_thresh, 1000);
+
+	if (loss_signal || bbrq->queue_rounds >= 2) {
+		duration = clamp_t(u32, bbrq_guard_duration, 1, 7);
+		bbrq->guard_rounds = duration;
+
+		/* Do not keep exponentially probing a path that is already
+		 * showing a persistent queue or material loss.
+		 */
+		if (bbrq->mode == BBRQ_STARTUP)
+			bbrq->full_bw_reached = 1;
+	}
+}
+
+static void bbrq_update_model(struct sock *sk, const struct rate_sample *rs)
+{
+	bbrq_update_bw(sk, rs);
+	bbrq_update_ack_aggregation(sk, rs);
+	bbrq_update_cycle_phase(sk, rs);
+	bbrq_check_full_bw_reached(sk, rs);
+	bbrq_update_guard(sk, rs);
+	bbrq_check_drain(sk, rs);
+	bbrq_update_min_rtt(sk, rs);
+	bbrq_update_gains(sk);
+}
+
+__bpf_kfunc static void bbrq_main(struct sock *sk, u32 ack, int flag, const struct rate_sample *rs)
+{
+	struct bbrq *bbrq = inet_csk_ca(sk);
+	u32 bw;
+
+	bbrq_update_model(sk, rs);
+
+	bw = bbrq_bw(sk);
+	bbrq_set_pacing_rate(sk, bw, bbrq->pacing_gain);
+	bbrq_set_cwnd(sk, rs, rs->acked_sacked, bw, bbrq->cwnd_gain);
+}
+
+__bpf_kfunc static void bbrq_init(struct sock *sk)
+{
+	struct tcp_sock *tp = tcp_sk(sk);
+	struct bbrq *bbrq = inet_csk_ca(sk);
+
+	bbrq->prior_cwnd = 0;
+	WRITE_ONCE(tp->snd_ssthresh, TCP_INFINITE_SSTHRESH);
+	bbrq->rtt_cnt = 0;
+	bbrq->next_rtt_delivered = tp->delivered;
+	bbrq->prev_ca_state = TCP_CA_Open;
+	bbrq->packet_conservation = 0;
+
+	bbrq->probe_rtt_done_stamp = 0;
+	bbrq->probe_rtt_round_done = 0;
+	bbrq->min_rtt_us = tcp_min_rtt(tp);
+	bbrq->min_rtt_stamp = tcp_jiffies32;
+
+	minmax_reset(&bbrq->bw, bbrq->rtt_cnt, 0);  /* init max bw to 0 */
+
+	bbrq->has_seen_rtt = 0;
+	bbrq_init_pacing_rate_from_rtt(sk);
+
+	bbrq->round_start = 0;
+	bbrq->idle_restart = 0;
+	bbrq->full_bw_reached = 0;
+	bbrq->full_bw = 0;
+	bbrq->full_bw_cnt = 0;
+	bbrq->cycle_mstamp = 0;
+	bbrq->cycle_idx = 0;
+	bbrq_reset_lt_bw_sampling(sk);
+	bbrq_reset_startup_mode(sk);
+
+	bbrq->ack_epoch_mstamp = tp->tcp_mstamp;
+	bbrq->ack_epoch_acked = 0;
+	bbrq->extra_acked_win_rtts = 0;
+	bbrq->extra_acked_win_idx = 0;
+	bbrq->extra_acked[0] = 0;
+	bbrq->extra_acked[1] = 0;
+	bbrq->queue_rounds = 0;
+	bbrq->guard_rounds = 0;
+
+	cmpxchg(&sk->sk_pacing_status, SK_PACING_NONE, SK_PACING_NEEDED);
+}
+
+__bpf_kfunc static u32 bbrq_sndbuf_expand(struct sock *sk)
+{
+	/* Provision 3 * cwnd since BBRQ may slow-start even during recovery. */
+	return 3;
+}
+
+/* In theory BBRQ does not need to undo the cwnd since it does not
+ * always reduce cwnd on losses (see bbrq_main()). Keep it for now.
+ */
+__bpf_kfunc static u32 bbrq_undo_cwnd(struct sock *sk)
+{
+	struct bbrq *bbrq = inet_csk_ca(sk);
+
+	bbrq->full_bw = 0;   /* spurious slow-down; reset full pipe detection */
+	bbrq->full_bw_cnt = 0;
+	bbrq_reset_lt_bw_sampling(sk);
+	return tcp_snd_cwnd(tcp_sk(sk));
+}
+
+/* Entering loss recovery, so save cwnd for when we exit or undo recovery. */
+__bpf_kfunc static u32 bbrq_ssthresh(struct sock *sk)
+{
+	bbrq_save_cwnd(sk);
+	return tcp_sk(sk)->snd_ssthresh;
+}
+
+static size_t bbrq_get_info(struct sock *sk, u32 ext, int *attr,
+			   union tcp_cc_info *info)
+{
+	if (ext & (1 << (INET_DIAG_BBRINFO - 1)) ||
+	    ext & (1 << (INET_DIAG_VEGASINFO - 1))) {
+		struct tcp_sock *tp = tcp_sk(sk);
+		struct bbrq *bbrq = inet_csk_ca(sk);
+		u64 bw = bbrq_bw(sk);
+
+		bw = bw * tp->mss_cache * USEC_PER_SEC >> BW_SCALE;
+		memset(&info->bbr, 0, sizeof(info->bbr));
+		info->bbr.bbr_bw_lo		= (u32)bw;
+		info->bbr.bbr_bw_hi		= (u32)(bw >> 32);
+		info->bbr.bbr_min_rtt		= bbrq->min_rtt_us;
+		info->bbr.bbr_pacing_gain	= bbrq->pacing_gain;
+		info->bbr.bbr_cwnd_gain		= bbrq->cwnd_gain;
+		*attr = INET_DIAG_BBRINFO;
+		return sizeof(info->bbr);
+	}
+	return 0;
+}
+
+__bpf_kfunc static void bbrq_set_state(struct sock *sk, u8 new_state)
+{
+	struct bbrq *bbrq = inet_csk_ca(sk);
+
+	if (new_state == TCP_CA_Loss) {
+		struct rate_sample rs = { .losses = 1 };
+
+		bbrq->prev_ca_state = TCP_CA_Loss;
+		bbrq->full_bw = 0;
+		bbrq->round_start = 1;	/* treat RTO like end of a round */
+		bbrq_lt_bw_sampling(sk, &rs);
+	}
+}
+
+static struct tcp_congestion_ops tcp_bbrq_cong_ops __read_mostly = {
+	.flags		= TCP_CONG_NON_RESTRICTED,
+	.name		= "bbrq",
+	.owner		= THIS_MODULE,
+	.init		= bbrq_init,
+	.cong_control	= bbrq_main,
+	.sndbuf_expand	= bbrq_sndbuf_expand,
+	.undo_cwnd	= bbrq_undo_cwnd,
+	.cwnd_event	= bbrq_cwnd_event,
+	.ssthresh	= bbrq_ssthresh,
+	.min_tso_segs	= bbrq_min_tso_segs,
+	.get_info	= bbrq_get_info,
+	.set_state	= bbrq_set_state,
+};
+
+BTF_KFUNCS_START(tcp_bbrq_check_kfunc_ids)
+BTF_ID_FLAGS(func, bbrq_init)
+BTF_ID_FLAGS(func, bbrq_main)
+BTF_ID_FLAGS(func, bbrq_sndbuf_expand)
+BTF_ID_FLAGS(func, bbrq_undo_cwnd)
+BTF_ID_FLAGS(func, bbrq_cwnd_event)
+BTF_ID_FLAGS(func, bbrq_ssthresh)
+BTF_ID_FLAGS(func, bbrq_min_tso_segs)
+BTF_ID_FLAGS(func, bbrq_set_state)
+BTF_KFUNCS_END(tcp_bbrq_check_kfunc_ids)
+
+static const struct btf_kfunc_id_set tcp_bbrq_kfunc_set = {
+	.owner = THIS_MODULE,
+	.set   = &tcp_bbrq_check_kfunc_ids,
+};
+
+static int __init bbrq_register(void)
+{
+	int ret;
+
+	BUILD_BUG_ON(sizeof(struct bbrq) > ICSK_CA_PRIV_SIZE);
+
+	ret = register_btf_kfunc_id_set(BPF_PROG_TYPE_STRUCT_OPS, &tcp_bbrq_kfunc_set);
+	if (ret < 0)
+		return ret;
+	return tcp_register_congestion_control(&tcp_bbrq_cong_ops);
+}
+
+static void __exit bbrq_unregister(void)
+{
+	tcp_unregister_congestion_control(&tcp_bbrq_cong_ops);
+}
+
+module_init(bbrq_register);
+module_exit(bbrq_unregister);
